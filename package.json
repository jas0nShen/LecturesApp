{
  "name": "hong-kong-course-planner-mvp",
  "version": "0.1.0",
  "private": true,
  "description": "MVP for a WeChat mini program helping Hong Kong university students plan courses.",
  "scripts": {
    "dev:api": "node server/index.js",
    "import:hku:cds": "node scripts/import-hku-cds-offerings.js",
    "import:hku:details": "node scripts/import-hku-cds-details.js",
    "import:hku:ug": "node scripts/import-hku-ug-programmes.js",
    "sync:ug-catalog": "node scripts/generate-ug-catalog.js",
    "status:ug-sources": "node scripts/report-ug-source-coverage.js",
    "sync:tpg": "node scripts/generate-tpg-catalog.js",
    "sync:data": "node scripts/generate-mock-data.js",
    "check:release": "node scripts/check-release-readiness.js",
    "status:release": "node scripts/print-release-status.js",
    "check:ship": "npm run check && npm run check:release",
    "test": "node --test",
    "check": "node scripts/validate-data.js && node server/index.js --check && node --test"
  },
  "engines": {
    "node": ">=18"
  }
}
