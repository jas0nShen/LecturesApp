page {
  background: #f6f7f5;
  color: #17231f;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}

.section {
  margin-bottom: 28rpx;
}

.panel {
  background: #ffffff;
  border: 1rpx solid #e2e7e1;
  border-radius: 12rpx;
  padding: 28rpx;
  box-sizing: border-box;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.25;
}

.subtitle {
  color: #64716b;
  font-size: 26rpx;
  line-height: 1.45;
  margin-top: 10rpx;
}

.button {
  align-items: center;
  background: #1f6f5b;
  border-radius: 10rpx;
  color: #ffffff;
  display: flex;
  font-size: 28rpx;
  font-weight: 600;
  height: 88rpx;
  justify-content: center;
  width: 100%;
}

.button.secondary {
  background: #e7f0ec;
  color: #1f6f5b;
}

.row {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.tag {
  background: #e7f0ec;
  border-radius: 999rpx;
  color: #1f6f5b;
  display: inline-flex;
  font-size: 22rpx;
  line-height: 1;
  margin-right: 12rpx;
  padding: 10rpx 14rpx;
}

.muted {
  color: #64716b;
}

.input {
  background: #ffffff;
  border: 1rpx solid #d7ded8;
  border-radius: 10rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  height: 82rpx;
  padding: 0 22rpx;
  width: 100%;
}
