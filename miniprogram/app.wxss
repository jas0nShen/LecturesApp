page {
  background: #eef3f0;
  color: #14231e;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Segoe UI", sans-serif;
}

.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 30rpx 28rpx calc(44rpx + env(safe-area-inset-bottom));
}

.section {
  margin-bottom: 24rpx;
}

.panel {
  background: #fbfcfa;
  border: 1rpx solid #dce6e0;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 26rpx rgba(15, 64, 51, 0.055);
  box-sizing: border-box;
  padding: 30rpx;
}

.title {
  color: #102a22;
  font-size: 42rpx;
  font-weight: 800;
  letter-spacing: -1rpx;
  line-height: 1.22;
}

.subtitle {
  color: #66776f;
  font-size: 25rpx;
  line-height: 1.55;
  margin-top: 9rpx;
}

.button {
  align-items: center;
  background: #0b6b55;
  border-radius: 14rpx;
  box-shadow: 0 8rpx 20rpx rgba(11, 107, 85, 0.16);
  color: #ffffff;
  display: flex;
  font-size: 28rpx;
  font-weight: 700;
  height: 88rpx;
  justify-content: center;
  width: 100%;
}

.button:active {
  opacity: 0.86;
  transform: scale(0.99);
}

.button.secondary {
  background: #e2eee9;
  box-shadow: none;
  color: #0b6b55;
}

.row {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.tag {
  background: #e2eee9;
  border-radius: 999rpx;
  color: #0b6b55;
  display: inline-flex;
  font-size: 22rpx;
  line-height: 1;
  margin-right: 12rpx;
  padding: 10rpx 14rpx;
}

.muted {
  color: #66776f;
}

.input {
  background: #fbfcfa;
  border: 1rpx solid #cad8d1;
  border-radius: 14rpx;
  box-shadow: inset 0 1rpx 2rpx rgba(15, 64, 51, 0.03);
  box-sizing: border-box;
  font-size: 28rpx;
  height: 86rpx;
  padding: 0 24rpx;
  width: 100%;
}
