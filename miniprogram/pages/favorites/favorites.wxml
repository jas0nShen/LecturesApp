<view class="page {{selectedCodes.length ? 'has-compare-dock' : ''}}">
  <view class="section">
    <view class="title">我的课程夹</view>
    <view class="subtitle">收好想进一步了解的课程，回来时不必重新搜索。</view>
  </view>

  <view class="folder-switch">
    <view class="folder-tab {{viewMode === 'offerings' ? 'active' : ''}}" data-value="offerings" bindtap="onModeTap">
      <view class="folder-count">{{offerings.length}}</view>
      <view class="folder-label">官方开课</view>
    </view>
    <view class="folder-tab {{viewMode === 'curriculum' ? 'active' : ''}}" data-value="curriculum" bindtap="onModeTap">
      <view class="folder-count">{{courses.length}}</view>
      <view class="folder-label">培养方案</view>
    </view>
    <view class="folder-tab {{viewMode === 'tpg' ? 'active' : ''}}" data-value="tpg" bindtap="onModeTap">
      <view class="folder-count">{{tpgCourses.length}}</view>
      <view class="folder-label">授课硕士</view>
    </view>
  </view>

  <view wx:if="{{viewMode === 'offerings'}}" class="section">
    <view wx:for="{{offerings}}" wx:key="courseCode" class="course-card official-card" data-code="{{item.courseCode}}" bindtap="goOfferingDetail">
      <view class="row">
        <view class="code">{{item.courseCode}}</view>
        <view class="card-tools">
          <view wx:if="{{item.planned}}" class="planned-mark">◆ 已计划</view>
          <view class="credits">Sem {{item.termLabel}}</view>
          <view class="compare-check {{item.selected ? 'selected' : ''}}" data-code="{{item.courseCode}}" catchtap="toggleCompare">{{item.selected ? '✓' : ''}}</view>
        </view>
      </view>
      <view class="course-title">{{item.title}}</view>
      <view class="record-line">{{item.categoryLabel}}</view>
    </view>
    <view wx:if="{{offerings.length === 0}}" class="empty">
      <view class="empty-title">课程夹还是空的</view>
      <view class="empty-copy">去官方开课目录，收藏想进一步了解的课程。</view>
      <view class="empty-action" bindtap="goCourses">浏览官方开课</view>
    </view>
  </view>

  <view wx:elif="{{viewMode === 'curriculum'}}" class="section">
    <view wx:for="{{courses}}" wx:key="id" class="course-card" data-id="{{item.id}}" bindtap="goDetail">
      <view class="row">
        <view class="code">{{item.courseCode}}</view>
        <view class="credits">{{item.credits}} credits</view>
      </view>
      <view class="course-title">{{item.titleEn}}</view>
      <view class="subtitle">{{item.semester}}</view>
    </view>
    <view wx:if="{{courses.length === 0}}" class="empty">
      <view class="empty-title">还没有培养方案收藏</view>
      <view class="empty-copy">在课程详情中收藏后，会出现在这里。</view>
      <view class="empty-action" bindtap="goCourses">查看培养方案</view>
    </view>
  </view>

  <view wx:elif="{{viewMode === 'tpg' && tpgLoadError}}" class="section empty">
    <view class="empty-title">硕士课程数据加载失败</view>
    <view class="empty-copy">收藏记录仍保存在本机，请重新加载课程分包。</view>
    <view class="empty-action" bindtap="retryTpgLoad">重新加载</view>
  </view>

  <view wx:else class="section">
    <view wx:for="{{tpgCourses}}" wx:key="rowKey" class="course-card" data-programme-id="{{item.programmeId}}" data-code="{{item.code}}" bindtap="goTpgCourseDetail">
      <view class="row">
        <view class="code">{{item.code}}</view>
        <view class="credits">{{item.credits}} credits</view>
      </view>
      <view class="course-title">{{item.name}}</view>
      <view class="subtitle">{{item.programmeName}}</view>
    </view>
    <view wx:if="{{tpgCourses.length === 0}}" class="empty">
      <view class="empty-title">还没有授课硕士收藏</view>
      <view class="empty-copy">在授课硕士课程详情中收藏后，会出现在这里。</view>
      <view class="empty-action" bindtap="goCourses">查看课程</view>
    </view>
  </view>

  <view wx:if="{{viewMode === 'offerings' && selectedCodes.length}}" class="compare-dock">
    <view>
      <view class="compare-count">已选择 {{selectedCodes.length}} / 3</view>
      <view class="compare-hint">{{compareReady ? '可以开始比较' : '再选 1 门课程'}}</view>
    </view>
    <view class="compare-button {{compareReady ? '' : 'disabled'}}" bindtap="goCompare">对比课程</view>
  </view>
</view>
