.folder-switch {
  border-bottom: 1rpx solid #dce4df;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-bottom: 28rpx;
}

.folder-tab {
  color: #718079;
  padding: 18rpx 8rpx;
  position: relative;
  text-align: center;
}

.folder-tab.active {
  color: #1f6f5b;
}

.folder-tab.active::after {
  background: #1f6f5b;
  bottom: -1rpx;
  content: "";
  height: 5rpx;
  left: 24%;
  position: absolute;
  width: 52%;
}

.folder-count {
  font-size: 36rpx;
  font-weight: 800;
}

.folder-label {
  font-size: 22rpx;
  margin-top: 3rpx;
}

.course-card {
  background: #fbfcfa;
  border: 1rpx solid #dbe5df;
  border-radius: 18rpx;
  box-shadow: 0 7rpx 20rpx rgba(15, 64, 51, 0.045);
  margin-bottom: 18rpx;
  padding: 24rpx;
}

.official-card {
  border-left: 6rpx solid #0b6b55;
}

.code {
  color: #1f6f5b;
  font-size: 28rpx;
  font-weight: 800;
}

.credits {
  color: #64716b;
  font-size: 24rpx;
}

.course-title {
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
  margin-top: 12rpx;
}

.record-line {
  color: #718079;
  font-size: 22rpx;
  margin-top: 16rpx;
}

.planned-mark {
  color: #3f5d75;
  font-size: 20rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
  text-align: right;
}

.empty {
  background: #eef4f1;
  border: 1rpx dashed #bed2c8;
  padding: 62rpx 34rpx;
  text-align: center;
}

.empty-title {
  color: #29433a;
  font-size: 30rpx;
  font-weight: 750;
}

.empty-copy {
  color: #64716b;
  font-size: 24rpx;
  line-height: 1.5;
  margin-top: 10rpx;
}

.empty-action {
  color: #1f6f5b;
  font-size: 25rpx;
  font-weight: 750;
  margin-top: 24rpx;
}

.folder-switch {
  background: #dfeae5;
  border: 0;
  border-radius: 18rpx;
  gap: 6rpx;
  padding: 7rpx;
}
.folder-tab { border-radius: 13rpx; }
.folder-tab.active { background: #fbfcfa; box-shadow: 0 5rpx 16rpx rgba(15, 64, 51, 0.06); }
.folder-tab.active::after { display: none; }
.code { color: #0b6b55; }
.course-title { color: #132a22; font-weight: 800; }
.empty { background: #e8f1ed; border-color: #b9d2c7; border-radius: 18rpx; }

.card-tools {
  align-items: flex-end;
  display: flex;
  flex-direction: column;
  padding-right: 54rpx;
  position: relative;
}

.compare-check {
  align-items: center;
  border: 2rpx solid #aebdb6;
  border-radius: 50%;
  color: #ffffff;
  display: flex;
  font-size: 20rpx;
  font-weight: 800;
  height: 34rpx;
  justify-content: center;
  position: absolute;
  right: 0;
  top: 1rpx;
  width: 34rpx;
}

.compare-check.selected {
  background: #0b6b55;
  border-color: #0b6b55;
}

.compare-dock {
  align-items: center;
  background: #17352c;
  border-radius: 18rpx;
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  box-shadow: 0 16rpx 34rpx rgba(8, 45, 35, 0.25);
  display: flex;
  justify-content: space-between;
  left: 28rpx;
  padding: 20rpx 22rpx;
  position: fixed;
  right: 28rpx;
  z-index: 5;
}

.compare-count {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 750;
}

.compare-hint {
  color: #9fc0b5;
  font-size: 19rpx;
  margin-top: 4rpx;
}

.compare-button {
  background: #dcebe5;
  border-radius: 11rpx;
  color: #0b5d4b;
  font-size: 24rpx;
  font-weight: 800;
  padding: 18rpx 26rpx;
}

.compare-button.disabled {
  opacity: 0.45;
}

.has-compare-dock {
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}
