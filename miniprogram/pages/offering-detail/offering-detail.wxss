.state {
  color: #64716b;
  padding: 180rpx 30rpx;
  text-align: center;
}

.state-title {
  color: #17231f;
  font-size: 34rpx;
  font-weight: 750;
}

.state-copy {
  font-size: 25rpx;
  margin-top: 12rpx;
}

.record-head {
  border-bottom: 1rpx solid #dce4df;
  padding: 12rpx 2rpx 30rpx;
}

.record-kicker {
  color: #1f6f5b;
  font-size: 22rpx;
  font-weight: 750;
  letter-spacing: 2rpx;
}

.record-code {
  color: #1f6f5b;
  font-size: 52rpx;
  font-weight: 850;
  margin-top: 24rpx;
}

.record-title {
  font-size: 38rpx;
  font-weight: 750;
  line-height: 1.25;
  margin-top: 10rpx;
}

.record-source {
  color: #64716b;
  font-size: 23rpx;
  margin-top: 14rpx;
}

.proof-card {
  align-items: center;
  background: #eaf3ef;
  border: 1rpx solid #bed8cd;
  display: flex;
  gap: 26rpx;
  margin-top: 28rpx;
  padding: 26rpx;
}

.proof-seal {
  border: 3rpx double #1f6f5b;
  color: #1f6f5b;
  font-size: 20rpx;
  font-weight: 850;
  letter-spacing: 2rpx;
  padding: 16rpx 10rpx;
  transform: rotate(-3deg);
}

.proof-main {
  flex: 1;
}

.proof-label,
.fact-label {
  color: #718079;
  font-size: 22rpx;
}

.proof-value {
  color: #173d33;
  font-size: 32rpx;
  font-weight: 750;
  margin-top: 4rpx;
}

.proof-meta {
  color: #58665f;
  font-size: 22rpx;
  margin-top: 7rpx;
}

.panel-title {
  font-size: 29rpx;
  font-weight: 750;
  margin-bottom: 18rpx;
}

.section-row {
  align-items: center;
  border-top: 1rpx solid #edf0ee;
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
}

.section-row:first-of-type {
  border-top: 0;
}

.section-code {
  color: #1f6f5b;
  font-size: 26rpx;
  font-weight: 750;
}

.section-term {
  color: #64716b;
  font-size: 23rpx;
}

.fact-grid {
  display: grid;
  gap: 16rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.fact {
  background: #f4f7f5;
  padding: 20rpx;
}

.fact-value {
  font-size: 28rpx;
  font-weight: 750;
  margin-top: 6rpx;
}

.detail-block {
  border-top: 1rpx solid #edf0ee;
  margin-top: 22rpx;
  padding-top: 22rpx;
}

.detail-copy {
  color: #33413a;
  font-size: 26rpx;
  line-height: 1.55;
  margin-top: 8rpx;
}

.quiet-panel {
  background: #f9faf9;
}

.source-note {
  color: #87928d;
  font-size: 21rpx;
  margin-top: 14rpx;
  text-align: center;
}
