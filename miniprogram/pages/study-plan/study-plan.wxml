<view class="page">
  <view wx:if="{{loading}}" class="section plan-message">
    <view class="plan-kicker">LOADING PLAN</view>
    <view class="title">正在加载选课计划</view>
    <view class="subtitle">课程资料保存在本机分包中，请稍候。</view>
  </view>
  <view wx:elif="{{!supported}}" class="section">
    <view class="plan-kicker">PLANNING STATUS</view>
    <view class="title">Study Plan 暂不可用</view>
    <view class="subtitle">{{unsupportedMessage}}</view>
    <view wx:if="{{loadError}}" class="plan-export retry-export" bindtap="retryPlanLoad"><view><view class="export-title">重试加载</view><view class="export-copy">重新加载当前课程分包</view></view><view class="export-mark">RETRY →</view></view>
    <view class="plan-export" bindtap="goCourses"><view><view class="export-title">去查看课程</view><view class="export-copy">浏览已公开的课程资料</view></view><view class="export-mark">→</view></view>
    <view class="plan-export status-export" bindtap="goSettings"><view><view class="export-title">修改学校与专业</view><view class="export-copy">查看或更新你的课程范围</view></view><view class="export-mark">SET →</view></view>
  </view>
  <block wx:else>
  <block wx:if="{{mode === 'tpg-course-plan'}}">
    <view class="section">
      <view class="plan-kicker">TPG COURSE PLAN</view>
      <view class="title">我的选课计划</view>
      <view class="subtitle">{{tpgPlan.programmeName}}</view>
      <view wx:if="{{tpgPlan.trackName}}" class="tpg-track">当前 Track · {{tpgPlan.trackName}}</view>
    </view>

    <view class="summary-strip tpg-summary-strip">
      <view class="summary-item"><view class="summary-value">{{tpgPlan.courseCount}}</view><view class="summary-label">计划课程</view></view>
      <view class="summary-item"><view class="summary-value">{{tpgPlan.totalCredits}}</view><view class="summary-label">计划学分</view></view>
      <view class="summary-item"><view class="summary-value">{{tpgPlan.completedCount}}</view><view class="summary-label">已修课程</view></view>
      <view class="summary-item"><view class="summary-value">{{tpgPlan.officialCredits || '-'}}</view><view class="summary-label">官方总学分</view></view>
    </view>

    <view class="plan-export {{tpgPlan.courseCount ? '' : 'disabled'}}" bindtap="copyTpgPlan">
      <view><view class="export-title">复制选课计划</view><view class="export-copy">包含 Programme、Track、课程组、学分与已修状态</view></view>
      <view class="export-mark">COPY ↗</view>
    </view>

    <view wx:if="{{tpgPlan.courseCount}}" class="tpg-groups">
      <view wx:for="{{tpgPlan.groups}}" wx:key="id" class="tpg-group">
        <view class="tpg-group-head">
          <view class="tpg-group-name">{{item.name}}</view>
          <view class="tpg-group-meta">{{item.courseCount}} 门 · {{item.credits}} credits</view>
        </view>
        <view wx:for="{{item.courses}}" wx:for-item="course" wx:key="code" class="plan-course tpg-plan-course">
          <view class="plan-row" data-code="{{course.code}}" bindtap="openTpgDetail">
            <view>
              <view class="course-code">{{course.code}}</view>
              <view class="course-title">{{course.name}}</view>
              <view class="course-credits">{{course.creditLabel}}</view>
              <view wx:if="{{course.completed}}" class="course-tags"><text class="course-tag completed">✓ 已修</text></view>
            </view>
            <view class="detail-mark">详情 →</view>
          </view>
          <view class="plan-actions tpg-plan-actions">
            <view class="plan-action" data-code="{{course.code}}" catchtap="toggleTpgCompleted">{{course.completed ? '取消已修' : '标记已修'}}</view>
            <view class="plan-action" data-code="{{course.code}}" catchtap="openTpgDetail">打开详情</view>
            <view class="plan-action danger" data-code="{{course.code}}" catchtap="removeTpgCourse">移出计划</view>
          </view>
        </view>
      </view>
    </view>

    <view wx:else class="tpg-empty">
      <view class="tpg-empty-title">当前 Programme 还没有计划课程</view>
      <view class="tpg-empty-copy">从已核验课程详情加入计划；其他 Track 的旧记录会保留，但不计入当前统计。</view>
    </view>
    <view class="section add-course" bindtap="goTpgCourses">＋ 从已核验课程添加</view>
    <view class="tpg-disclaimer">本页只整理本机选课清单，不生成毕业百分比、学分差额或通过判断。</view>
  </block>
  <block wx:elif="{{mode === 'ug-course-plan'}}">
    <view class="section">
      <view class="plan-kicker">UG COURSE PLAN</view>
      <view class="title">我的本科课程计划</view>
      <view class="subtitle">{{ugPlan.programmeName}}</view>
      <view class="tpg-track">当前 Major · {{ugPlan.majorName}}</view>
    </view>

    <view class="summary-strip tpg-summary-strip">
      <view class="summary-item"><view class="summary-value">{{ugPlan.courseCount}}</view><view class="summary-label">计划课程</view></view>
      <view class="summary-item"><view class="summary-value">{{ugPlan.knownCreditsDisplay}}</view><view class="summary-label">已知学分</view></view>
      <view class="summary-item"><view class="summary-value">{{ugPlan.groups.length}}</view><view class="summary-label">年级分组</view></view>
      <view class="summary-item"><view class="summary-value">{{ugPlan.curriculumYear || '-'}}</view><view class="summary-label">课程年份</view></view>
    </view>

    <view class="plan-export {{ugPlan.courseCount ? '' : 'disabled'}}" bindtap="copyUgPlan">
      <view><view class="export-title">复制本科课程计划</view><view class="export-copy">包含 Programme、Major、推荐年级、学期与已知学分</view></view>
      <view class="export-mark">COPY ↗</view>
    </view>

    <view wx:if="{{ugPlan.courseCount}}" class="tpg-groups">
      <view wx:for="{{ugPlan.groups}}" wx:key="id" class="tpg-group">
        <view class="tpg-group-head">
          <view class="tpg-group-name">{{item.name}}</view>
          <view class="tpg-group-meta">{{item.courseCount}} 门<text wx:if="{{item.knownCredits}}"> · {{item.knownCredits}} credits</text></view>
        </view>
        <view wx:for="{{item.courses}}" wx:for-item="course" wx:key="id" class="plan-course tpg-plan-course">
          <view class="plan-row" data-id="{{course.id}}" bindtap="openUgDetail">
            <view>
              <view class="course-code">{{course.courseCode}}</view>
              <view class="course-title">{{course.titleEn}}</view>
              <view class="course-credits">{{course.semester}}<text wx:if="{{course.creditLabel}}"> · {{course.creditLabel}}</text></view>
              <view class="course-tags"><text class="course-tag">{{ugPlan.majorName}}</text></view>
            </view>
            <view class="detail-mark">详情 →</view>
          </view>
          <view class="plan-actions ug-plan-actions">
            <view class="plan-action" data-id="{{course.id}}" catchtap="openUgDetail">打开详情</view>
            <view class="plan-action danger" data-id="{{course.id}}" catchtap="removeUgCourse">移出计划</view>
          </view>
        </view>
      </view>
    </view>

    <view wx:else class="tpg-empty">
      <view class="tpg-empty-title">当前 Major 还没有计划课程</view>
      <view class="tpg-empty-copy">从本科课程详情加入计划；其他 Major 的旧记录会保留，但不计入当前计划。</view>
    </view>
    <view class="section add-course" bindtap="goUgCourses">＋ 从本科课程清单添加</view>
    <view class="tpg-disclaimer">本页只整理本机课程清单，不计算毕业百分比、学分差额或毕业资格。</view>
  </block>
  <block wx:else>
  <view class="section">
    <view class="plan-kicker">FOUR-YEAR ROUTE</view>
    <view class="title">我的 Study Plan</view>
    <view class="subtitle">先安排方向，再根据正式课表和先修要求逐步调整。</view>
  </view>

  <view class="summary-strip">
    <view class="summary-item">
      <view class="summary-value">{{review.courseCount}}</view>
      <view class="summary-label">计划课程</view>
    </view>
    <view class="summary-item">
      <view class="summary-value">{{review.totalCredits}}</view>
      <view class="summary-label">计划学分</view>
    </view>
    <view class="summary-item {{review.noticeCount ? 'attention' : ''}}">
      <view class="summary-value">{{review.noticeCount}}</view>
      <view class="summary-label">待核对</view>
    </view>
  </view>

  <view wx:if="{{review.courseCount}}" class="plan-state-strip">
    <view class="plan-state completed">已修 {{review.completedCount}}</view>
    <view class="plan-state favorite">收藏 {{review.favoriteCount}}</view>
    <view class="plan-state note">笔记 {{review.noteCount}}</view>
  </view>

  <view wx:if="{{review.categoryStats.length}}" class="category-card">
    <view class="category-head">
      <view>
        <view class="category-kicker">COURSE MIX</view>
        <view class="category-title">课程类别统计</view>
      </view>
      <view class="category-total">{{review.totalCredits}} credits</view>
    </view>
    <view class="category-grid">
      <view wx:for="{{review.categoryStats}}" wx:key="key" class="category-pill {{item.key}}">
        <view class="category-label">{{item.label}}</view>
        <view class="category-value">{{item.courseCount}} 门 · {{item.credits}} credits</view>
        <view wx:if="{{item.completedCount}}" class="category-completed">已修 {{item.completedCount}}</view>
      </view>
    </view>
  </view>

  <view class="plan-export {{review.courseCount ? '' : 'disabled'}}" bindtap="copyPlan">
    <view>
      <view class="export-title">复制四年计划</view>
      <view class="export-copy">按学年和学期整理成可分享文本</view>
    </view>
    <view class="export-mark">COPY ↗</view>
  </view>

  <view class="plan-export status-export {{review.courseCount ? '' : 'disabled'}}" bindtap="copyPlanStatus">
    <view>
      <view class="export-title">复制状态摘要</view>
      <view class="export-copy">只包含数量、学分和类别统计，不复制笔记内容</view>
    </view>
    <view class="export-mark">SAFE ↗</view>
  </view>

  <view wx:if="{{review.notices.length}}" class="review-notes">
    <view class="review-head">
      <view class="review-title">计划检查</view>
      <view class="review-copy-action" bindtap="copyPlanChecks">复制检查清单</view>
    </view>
    <view class="notice-legend">
      <view wx:if="{{review.noticeCounts.offering}}" class="legend-item offering">开课 {{review.noticeCounts.offering}}</view>
      <view wx:if="{{review.noticeCounts.prerequisite}}" class="legend-item prerequisite">先修 {{review.noticeCounts.prerequisite}}</view>
      <view wx:if="{{review.noticeCounts.corequisite}}" class="legend-item corequisite">共修 {{review.noticeCounts.corequisite}}</view>
      <view wx:if="{{review.noticeCounts.load}}" class="legend-item load">负担 {{review.noticeCounts.load}}</view>
    </view>
    <view wx:for="{{review.notices}}" wx:key="id" class="review-note">
      <view class="notice-type {{item.type}}">{{item.type === 'offering' ? '开课' : item.type === 'prerequisite' ? '先修' : item.type === 'corequisite' ? '共修' : '负担'}}</view>
      <view class="notice-message">{{item.message}}</view>
    </view>
    <view wx:if="{{review.loadSuggestions.length}}" class="load-suggestions">
      <view class="load-title">可尝试调整</view>
      <view wx:for="{{review.loadSuggestions}}" wx:key="id" class="load-suggestion">
        <view class="load-message">{{item.message}}</view>
        <view wx:for="{{item.candidates}}" wx:for-item="candidate" wx:key="courseCode" class="load-candidate" data-code="{{candidate.courseCode}}" bindtap="editCourse">
          <view>
            <view class="load-code">{{candidate.courseCode}}</view>
            <view class="load-name">{{candidate.title}}</view>
            <view class="load-route">{{candidate.fromLabel}} → {{candidate.toLabel}}</view>
          </view>
          <view class="load-action">调整</view>
        </view>
      </view>
    </view>
    <view class="review-disclaimer">根据 2025–26 开课资料、已修记录和计划顺序提示；等价课程、成绩门槛、正式课表及学院审批仍以官方信息为准。</view>
  </view>

  <view wx:if="{{suggestions.length}}" class="suggestion-card">
    <view class="suggestion-head">
      <view>
        <view class="suggestion-kicker">NEXT CORE COURSES</view>
        <view class="suggestion-title">未安排的核心课</view>
      </view>
      <view class="suggestion-count">{{coreGapSummary.courseCount}}</view>
    </view>
    <view class="suggestion-copy">根据当前已修记录和 Study Plan，还有 {{coreGapSummary.courseCount}} 门 core 未安排，共 {{coreGapSummary.credits}} credits；正式毕业要求仍以学校审核为准。</view>
    <view class="core-gap-copy-action" bindtap="copyCoreGap">复制核心课清单</view>
    <view wx:if="{{coreGapSummary.groups.length}}" class="gap-groups">
      <view wx:for="{{coreGapSummary.groups}}" wx:key="yearLabel" class="gap-group">
        <view class="gap-year">{{item.yearLabel}}</view>
        <view class="gap-meta">{{item.courseCount}} 门 · {{item.credits}} credits</view>
      </view>
    </view>
    <view wx:for="{{suggestions}}" wx:key="courseCode" class="suggestion-row" data-code="{{item.courseCode}}" bindtap="planSuggestion">
      <view>
        <view class="suggestion-code">{{item.courseCode}} · Year {{item.recommendedYear || '-'}}</view>
        <view class="suggestion-name">{{item.title}}</view>
        <view class="suggestion-meta">{{item.credits}} credits · {{item.termLabel}}</view>
      </view>
      <view class="suggestion-action">安排</view>
    </view>
  </view>

  <view class="timeline">
    <view wx:for="{{groups}}" wx:key="year" class="year-group">
      <view class="year-rail">
        <view class="year-dot">{{item.year}}</view>
        <view class="year-line"></view>
      </view>
      <view class="year-content">
        <view class="year-heading">
          <text>Year {{item.year}}</text>
          <text class="year-credits">{{item.credits}} credits</text>
        </view>
        <view class="term-loads">
          <view class="term-load {{item.semesterOne.overloaded ? 'overloaded' : ''}}">S1 · {{item.semesterOne.credits}} cu</view>
          <view class="term-load {{item.semesterTwo.overloaded ? 'overloaded' : ''}}">S2 · {{item.semesterTwo.credits}} cu</view>
        </view>
        <view wx:for="{{item.courses}}" wx:for-item="course" wx:key="courseCode" class="plan-course {{course.hasIssue ? 'has-issue' : ''}}">
          <view class="plan-row" data-code="{{course.courseCode}}" bindtap="editCourse">
            <view>
              <view class="course-code">{{course.courseCode}} <text wx:if="{{course.hasIssue}}" class="issue-mark">需核对</text></view>
              <view class="course-title">{{course.offering.title}}</view>
              <view class="course-credits">{{course.credits}} credits · {{course.categoryLabel}}</view>
              <view class="course-tags">
                <text wx:if="{{course.completed}}" class="course-tag completed">✓ 已修</text>
                <text wx:if="{{course.favorite}}" class="course-tag favorite">★ 收藏</text>
                <text wx:if="{{course.hasNote}}" class="course-tag note">✎ 笔记</text>
              </view>
              <view wx:if="{{course.notePreview}}" class="note-preview">{{course.notePreview}}</view>
            </view>
            <view class="term">{{course.termLabel}}</view>
          </view>
          <view class="plan-actions">
            <view class="plan-action" data-code="{{course.courseCode}}" catchtap="toggleCompleted">{{course.completed ? '取消已修' : '标记已修'}}</view>
            <view class="plan-action" data-code="{{course.courseCode}}" catchtap="toggleFavorite">{{course.favorite ? '取消收藏' : '收藏'}}</view>
            <view class="plan-action" data-code="{{course.courseCode}}" catchtap="openDetail">详情/笔记</view>
            <view class="plan-action danger" data-code="{{course.courseCode}}" catchtap="removeCourse">移除</view>
          </view>
        </view>
        <view wx:if="{{item.courses.length === 0}}" class="year-empty">还没有安排课程</view>
      </view>
    </view>
  </view>

  <view class="section add-course" bindtap="goCourses">＋ 从官方开课目录添加课程</view>
  </block>
  </block>
</view>
