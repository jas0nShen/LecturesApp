<view class="page">
  <view class="section">
    <view class="plan-kicker">FOUR-YEAR ROUTE</view>
    <view class="title">我的 Study Plan</view>
    <view class="subtitle">先安排方向，再根据正式课表和先修要求逐步调整。</view>
  </view>

  <view class="summary-strip">
    <view class="summary-item">
      <view class="summary-value">{{review.courseCount}}</view>
      <view class="summary-label">计划课程</view>
    </view>
    <view class="summary-item">
      <view class="summary-value">{{review.totalCredits}}</view>
      <view class="summary-label">计划学分</view>
    </view>
    <view class="summary-item {{review.noticeCount ? 'attention' : ''}}">
      <view class="summary-value">{{review.noticeCount}}</view>
      <view class="summary-label">待核对</view>
    </view>
  </view>

  <view class="plan-export {{review.courseCount ? '' : 'disabled'}}" bindtap="copyPlan">
    <view>
      <view class="export-title">复制四年计划</view>
      <view class="export-copy">按学年和学期整理成可分享文本</view>
    </view>
    <view class="export-mark">COPY ↗</view>
  </view>

  <view wx:if="{{review.notices.length}}" class="review-notes">
    <view class="review-title">计划检查</view>
    <view class="notice-legend">
      <view wx:if="{{review.noticeCounts.offering}}" class="legend-item offering">开课 {{review.noticeCounts.offering}}</view>
      <view wx:if="{{review.noticeCounts.prerequisite}}" class="legend-item prerequisite">先修 {{review.noticeCounts.prerequisite}}</view>
      <view wx:if="{{review.noticeCounts.corequisite}}" class="legend-item corequisite">共修 {{review.noticeCounts.corequisite}}</view>
      <view wx:if="{{review.noticeCounts.load}}" class="legend-item load">负担 {{review.noticeCounts.load}}</view>
    </view>
    <view wx:for="{{review.notices}}" wx:key="id" class="review-note">
      <view class="notice-type {{item.type}}">{{item.type === 'offering' ? '开课' : item.type === 'prerequisite' ? '先修' : item.type === 'corequisite' ? '共修' : '负担'}}</view>
      <view class="notice-message">{{item.message}}</view>
    </view>
    <view class="review-disclaimer">根据 2025–26 开课资料、已修记录和计划顺序提示；等价课程、成绩门槛、正式课表及学院审批仍以官方信息为准。</view>
  </view>

  <view class="timeline">
    <view wx:for="{{groups}}" wx:key="year" class="year-group">
      <view class="year-rail">
        <view class="year-dot">{{item.year}}</view>
        <view class="year-line"></view>
      </view>
      <view class="year-content">
        <view class="year-heading">
          <text>Year {{item.year}}</text>
          <text class="year-credits">{{item.credits}} credits</text>
        </view>
        <view class="term-loads">
          <view class="term-load {{item.semesterOne.overloaded ? 'overloaded' : ''}}">S1 · {{item.semesterOne.credits}} cu</view>
          <view class="term-load {{item.semesterTwo.overloaded ? 'overloaded' : ''}}">S2 · {{item.semesterTwo.credits}} cu</view>
        </view>
        <view wx:for="{{item.courses}}" wx:for-item="course" wx:key="courseCode" class="plan-course {{course.hasIssue ? 'has-issue' : ''}}">
          <view class="plan-row" data-code="{{course.courseCode}}" bindtap="editCourse">
            <view>
              <view class="course-code">{{course.courseCode}} <text wx:if="{{course.hasIssue}}" class="issue-mark">需核对</text></view>
              <view class="course-title">{{course.offering.title}}</view>
              <view class="course-credits">{{course.credits}} credits</view>
            </view>
            <view class="term">{{course.termLabel}}</view>
          </view>
          <view class="remove" data-code="{{course.courseCode}}" catchtap="removeCourse">移除</view>
        </view>
        <view wx:if="{{item.courses.length === 0}}" class="year-empty">还没有安排课程</view>
      </view>
    </view>
  </view>

  <view class="section add-course" bindtap="goCourses">＋ 从官方开课目录添加课程</view>
</view>
