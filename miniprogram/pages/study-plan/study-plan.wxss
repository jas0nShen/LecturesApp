  align-items: center;
  background: #0b5d4b;
  border: 6rpx solid #d9ebe3;
  border-radius: 50%;
  color: #ffffff;
  display: flex;
  font-size: 23rpx;
  font-weight: 850;
  height: 48rpx;
  justify-content: center;
  width: 48rpx;
}
.year-line { background: #cbdad3; flex: 1; width: 2rpx; }
