.plan-kicker { color: #0b6b55; font-size: 20rpx; font-weight: 800; letter-spacing: 3rpx; margin-bottom: 12rpx; }
.summary-strip {
  background: #fbfcfa;
  border: 1rpx solid #dbe5df;
  border-radius: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin: 28rpx 0;
  padding: 20rpx 0;
}
.summary-item { border-left: 1rpx solid #e3e9e6; text-align: center; }
.summary-item:first-child { border-left: 0; }
.summary-value { color: #17352c; font-size: 34rpx; font-weight: 850; }
.summary-label { color: #7a8982; font-size: 20rpx; margin-top: 4rpx; }
.summary-item.attention .summary-value { color: #a66b13; }
.plan-export {
  align-items: center;
  background: #17352c;
  border-radius: 16rpx;
  color: #ffffff;
  display: flex;
  justify-content: space-between;
  margin: -10rpx 0 26rpx;
  padding: 22rpx 24rpx;
}
.plan-export.disabled { opacity: 0.45; }
.export-title { font-size: 25rpx; font-weight: 800; }
.export-copy { color: #a9c1b8; font-size: 19rpx; margin-top: 4rpx; }
.export-mark { border: 1rpx solid #66887c; color: #b9d4ca; font-size: 16rpx; font-weight: 800; letter-spacing: 1rpx; padding: 8rpx; }
.review-notes {
  background: #fff7e8;
  border: 1rpx solid #ecd5a9;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  padding: 24rpx;
}
.review-title { color: #80520e; font-size: 25rpx; font-weight: 800; }
.notice-legend { display: flex; flex-wrap: wrap; gap: 8rpx; margin-top: 14rpx; }
.legend-item { background: #f4e4c7; border-radius: 999rpx; color: #80520e; font-size: 19rpx; padding: 8rpx 12rpx; }
.legend-item.offering { background: #f1ded8; color: #8b4b3f; }
.legend-item.corequisite { background: #e4e7f0; color: #505f82; }
.legend-item.load { background: #eee0d3; color: #875938; }
.review-note { align-items: flex-start; border-top: 1rpx solid #f0dfbd; display: flex; gap: 12rpx; margin-top: 14rpx; padding-top: 14rpx; }
.notice-type { border: 1rpx solid #c99547; color: #80520e; flex: none; font-size: 17rpx; font-weight: 800; padding: 4rpx 7rpx; }
.notice-type.offering { border-color: #bd7a6d; color: #8b4b3f; }
.notice-type.corequisite { border-color: #7d89a7; color: #505f82; }
.notice-type.load { border-color: #aa7652; color: #875938; }
.notice-message { color: #684d24; font-size: 23rpx; line-height: 1.5; }
.review-disclaimer { color: #967a4f; font-size: 19rpx; line-height: 1.5; margin-top: 18rpx; }
.timeline { margin-top: 34rpx; }
.year-group { display: flex; min-height: 150rpx; }
.year-rail { align-items: center; display: flex; flex-direction: column; margin-right: 22rpx; width: 54rpx; }
.year-dot {
  align-items: center;
  background: #0b5d4b;
  border: 6rpx solid #d9ebe3;
  border-radius: 50%;
  color: #ffffff;
  display: flex;
  font-size: 23rpx;
  font-weight: 850;
  height: 48rpx;
  justify-content: center;
  width: 48rpx;
}
.year-line { background: #cbdad3; flex: 1; width: 2rpx; }
.year-group:last-child .year-line { background: transparent; }
.year-content { flex: 1; padding-bottom: 28rpx; }
.year-heading { align-items: baseline; color: #17352c; display: flex; font-size: 28rpx; font-weight: 850; justify-content: space-between; margin: 8rpx 0 16rpx; }
.year-credits { color: #829088; font-size: 20rpx; font-weight: 600; }
.term-loads { display: flex; gap: 8rpx; margin: -6rpx 0 14rpx; }
.term-load { background: #e7efeb; border-radius: 999rpx; color: #71827a; font-size: 18rpx; padding: 7rpx 11rpx; }
.term-load.overloaded { background: #f3e1d3; color: #955b35; font-weight: 750; }
.plan-course {
  background: #fbfcfa;
  border: 1rpx solid #dbe5df;
  border-radius: 16rpx;
  box-shadow: 0 7rpx 20rpx rgba(15, 64, 51, 0.045);
  margin-bottom: 12rpx;
  overflow: hidden;
}
.plan-course.has-issue { border-color: #ddb87e; }
.plan-row { display: flex; justify-content: space-between; padding: 22rpx; }
.course-code { color: #0b6b55; font-size: 24rpx; font-weight: 850; }
.issue-mark { background: #fff0d5; border-radius: 999rpx; color: #966014; font-size: 17rpx; margin-left: 7rpx; padding: 5rpx 9rpx; }
.course-title { font-size: 25rpx; font-weight: 750; line-height: 1.35; margin-top: 6rpx; max-width: 390rpx; }
.course-credits { color: #829088; font-size: 20rpx; margin-top: 8rpx; }
.term { color: #687970; font-size: 20rpx; white-space: nowrap; }
.remove { border-top: 1rpx solid #e7ece9; color: #8b5b51; font-size: 21rpx; padding: 12rpx 22rpx; text-align: right; }
.year-empty { border: 1rpx dashed #c6d5ce; border-radius: 14rpx; color: #89978f; font-size: 23rpx; padding: 24rpx; }
.add-course {
  background: #e2eee9;
  border-radius: 16rpx;
  color: #0b6b55;
  font-size: 26rpx;
  font-weight: 750;
  padding: 26rpx;
  text-align: center;
}
