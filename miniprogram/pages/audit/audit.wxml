<view class="page">
  <block wx:if="{{needsSetup}}">
    <view class="section setup-card">
      <view class="audit-kicker light">TPG FIRST</view>
      <view class="setup-title">先选择 Programme，再看毕业检查</view>
      <view class="setup-copy">授课硕士毕业要求必须按 Programme 判断。未设置前，这里不会默认显示其他示例数据。</view>
    </view>

    <view class="tpg-actions">
      <view class="tpg-action" bindtap="goTpgCatalog">浏览 Programme 目录</view>
      <view class="tpg-action primary" bindtap="goOnboarding">开始选择</view>
    </view>
  </block>

  <block wx:elif="{{dataSource === 'error'}}">
    <view class="section setup-card">
      <view class="audit-kicker light">LOCAL DATA</view>
      <view class="setup-title">本科课程数据加载失败</view>
      <view class="setup-copy">请稍后重试；已保存的学校和专业资料不会丢失。</view>
    </view>
    <view class="tpg-actions">
      <view class="tpg-action primary" bindtap="retryUgLoad">重新加载</view>
      <view class="tpg-action" bindtap="goOnboarding">检查资料</view>
    </view>
  </block>

  <block wx:elif="{{isTpg && tpgAudit}}">
    <view class="section tpg-audit-hero">
      <view class="audit-kicker light">{{tpgAudit.programme.universityCode}} · {{tpgAudit.university.academicYear}}</view>
      <view class="tpg-audit-title">{{tpgAudit.programme.name}}</view>
      <view class="tpg-audit-faculty">{{tpgAudit.programme.faculty || 'Faculty 待确认'}}</view>
      <view class="tpg-audit-meter">
        <view>
          <view class="big-number">{{tpgAudit.totalCredits || '--'}}</view>
          <view class="subtitle">毕业学分 / units</view>
        </view>
        <view class="verified-seal">{{tpgAudit.hasCourseGroups ? 'STRUCTURE' : 'REVIEW'}}<br/>TPG</view>
      </view>
      <view class="curriculum-note">{{tpgAudit.statusCopy}}</view>
      <view class="source-line">数据源：授课硕士本地资料库</view>
    </view>

    <view class="section tpg-snapshot">
      <view wx:for="{{tpgAudit.snapshot}}" wx:key="label" class="tpg-snapshot-item">
        <view class="tpg-snapshot-value">{{item.value}}</view>
        <view class="tpg-snapshot-label">{{item.label}}</view>
        <view class="tpg-snapshot-state">{{item.state}}</view>
      </view>
    </view>

    <view class="section completed-entry" bindtap="goTpgProgramme">
      <view class="completed-icon">↗</view>
      <view class="completed-copy">
        <view class="panel-title">{{tpgAudit.statusTitle}}</view>
        <view class="subtitle">{{tpgAudit.detailEntryCopy}}</view>
      </view>
      <view class="completed-arrow">›</view>
    </view>

    <view wx:if="{{tpgAudit.hasCourseGroups}}" class="section">
      <view class="section-heading">已录入的课程组</view>
      <view wx:for="{{tpgAudit.groups}}" wx:key="name" class="panel requirement tpg-group">
        <view class="row">
          <view class="panel-title">{{item.name}}</view>
          <view class="muted">{{item.courseCount}} 门</view>
        </view>
        <view wx:if="{{item.creditsRequired}}" class="partial-label">{{item.creditsRequired}} CREDITS / UNITS REQUIRED</view>
        <view class="tpg-course-preview">
          <view wx:for="{{item.courses}}" wx:key="rowKey" wx:for-item="course" class="missing-course">{{course.code}} · {{course.name}}</view>
        </view>
      </view>
    </view>

    <view wx:else class="section panel tpg-pending-panel">
      <view class="audit-kicker">NEXT DATA STEP</view>
      <view class="panel-title">先不计算毕业进度</view>
      <view class="subtitle">这个 Programme 的必修/选修课程组尚未开放。当前先展示资料收录状态，不生成毕业完成度。</view>
      <view class="recommendation">
        <view class="course-code">下一步</view>
        <view class="subtitle">课程组复核完成后，再开放逐项毕业检查。</view>
      </view>
    </view>

    <view class="section panel tpg-next-panel">
      <view class="audit-kicker">WHAT TO DO NEXT</view>
      <view wx:for="{{tpgAudit.nextChecks}}" wx:key="index" class="tpg-next-row">
        <view class="tpg-next-index">{{index + 1}}</view>
        <view class="subtitle">{{item}}</view>
      </view>
    </view>

    <view class="tpg-actions">
      <view class="tpg-action" bindtap="goTpgCatalog">浏览 Programme 目录</view>
      <view class="tpg-action primary" bindtap="copyTpgSource">{{tpgAudit.programme.sourceUrl ? '复制官方链接' : '复制资料来源'}}</view>
    </view>
  </block>

  <block wx:elif="{{isUgCatalogue && ugAudit}}">
    <view class="section tpg-audit-hero">
      <view class="audit-kicker light">{{ugAudit.profile.university.code}} · {{ugAudit.profile.curriculumYear}}</view>
      <view class="tpg-audit-title">{{ugAudit.profile.programme.nameEn}}</view>
      <view class="tpg-audit-faculty">{{ugAudit.profile.major.nameEn}}</view>
      <view class="tpg-audit-meter">
        <view>
          <view class="big-number">{{ugAudit.hasCourses ? ugAudit.courseCount : '--'}}</view>
          <view class="subtitle">已开放课程</view>
        </view>
        <view class="verified-seal">{{ugAudit.hasCourses ? 'COURSES' : 'REVIEW'}}<br/>UG</view>
      </view>
      <view class="curriculum-note">{{ugAudit.statusCopy}}</view>
      <view class="source-line">数据源：本科本地资料库</view>
    </view>

    <view class="section completed-entry" bindtap="goOnboarding">
      <view class="completed-icon">↗</view>
      <view class="completed-copy">
        <view class="panel-title">{{ugAudit.statusTitle}}</view>
        <view class="subtitle">点击可切换本科 Programme / Major。</view>
      </view>
      <view class="completed-arrow">›</view>
    </view>

    <view class="section panel tpg-pending-panel">
      <view class="audit-kicker">GRAD CHECK</view>
      <view class="panel-title">暂不计算毕业进度</view>
      <view class="subtitle">本科不同学校和专业的毕业规则差异很大。规则没有完成复核前，这里只展示资料收录状态，不生成百分比。</view>
      <view class="recommendation">
        <view class="course-code">当前状态</view>
        <view class="subtitle">{{ugAudit.statusTitle}}</view>
      </view>
    </view>

    <view class="section panel tpg-next-panel">
      <view class="audit-kicker">WHAT TO DO NEXT</view>
      <view wx:for="{{ugAudit.nextChecks}}" wx:key="index" class="tpg-next-row">
        <view class="tpg-next-index">{{index + 1}}</view>
        <view class="subtitle">{{item}}</view>
      </view>
    </view>

    <view class="tpg-actions">
      <view class="tpg-action" bindtap="goOnboarding">修改本科范围</view>
      <view class="tpg-action primary" bindtap="copyUgSource">复制官方链接</view>
    </view>
  </block>

  <block wx:else>
  <view class="section panel">
    <view class="audit-kicker">RECORDED CREDITS</view>
    <view class="panel-title">已录入学分</view>
    <view class="big-number">{{audit.totalProgress}}%</view>
    <view class="progress-wrap">
      <view class="progress-bar" style="width: {{audit.totalProgress}}%;"></view>
    </view>
    <view class="subtitle">已记录 {{audit.completedCredits}} / {{audit.totalCreditRequired}} credits；此比例不是学校官方审核结果。</view>
    <view class="source-line">数据源：{{dataSource === 'api' ? '开发环境服务' : '离线数据'}}</view>
  </view>

  <view class="section curriculum-card">
    <view class="curriculum-head">
      <view>
        <view class="audit-kicker light">VERIFIED STRUCTURE</view>
        <view class="curriculum-title">HKU BEng(CompSc) · {{audit.curriculumYear}}</view>
      </view>
      <view class="verified-seal">240<br/>CU</view>
    </view>
    <view class="structure-grid">
      <view wx:for="{{audit.curriculumStructure}}" wx:key="type" class="structure-item">
        <view class="structure-credits">{{item.credits}}</view>
        <view class="structure-name">{{item.name}}</view>
      </view>
    </view>
    <view class="curriculum-note">{{audit.trackingNotice}}</view>
    <view class="source-action" bindtap="copyCurriculumSource">复制 HKU 官方培养方案链接</view>
  </view>

  <view class="section completed-entry" bindtap="goCompletedCourses">
    <view class="completed-icon">✓</view>
    <view class="completed-copy">
      <view class="panel-title">管理已修课程</view>
      <view class="subtitle">搜索完整官方课程目录，集中录入或修改修读记录。</view>
    </view>
    <view class="completed-arrow">›</view>
  </view>

  <view class="section">
    <view class="section-heading">当前可逐门追踪的要求</view>
    <view wx:for="{{audit.sections}}" wx:key="type" class="panel requirement">
      <view class="row">
        <view class="panel-title">{{item.name}}</view>
        <view class="muted">{{item.completedCredits}} / {{item.requiredCredits}}</view>
      </view>
      <view wx:if="{{item.trackingScope === 'partial'}}" class="partial-label">PARTIAL COVERAGE · 尚未收录该类别全部课程</view>
      <view class="progress-wrap small">
        <view class="progress-bar" style="width: {{item.progress}}%;"></view>
      </view>
      <view wx:if="{{item.missingCourses.length}}" class="missing">
        <view class="missing-title">还缺</view>
        <view wx:for="{{item.missingCourses}}" wx:for-item="course" wx:key="id" class="missing-course">{{course.courseCode}} · {{course.titleEn}}</view>
      </view>
    </view>
  </view>

  <view class="section panel">
    <view class="panel-title">优先建议</view>
    <view wx:for="{{audit.recommendations}}" wx:key="index" class="recommendation">
      <view class="course-code">{{item.course.courseCode}}</view>
      <view class="subtitle">{{item.reason}}</view>
    </view>
    <view wx:if="{{audit.recommendations.length === 0}}" class="subtitle">当前规则下暂无明显缺口。</view>
  </view>
  </block>
</view>
