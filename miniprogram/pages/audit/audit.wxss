.panel-title {
  font-size: 30rpx;
  font-weight: 700;
}

.big-number {
  color: #1f6f5b;
  font-size: 72rpx;
  font-weight: 800;
  margin-top: 12rpx;
}

.progress-wrap {
  background: #e7ece8;
  border-radius: 999rpx;
  height: 18rpx;
  margin-top: 20rpx;
  overflow: hidden;
}

.progress-wrap.small {
  height: 14rpx;
}

.progress-bar {
  background: #1f6f5b;
  height: 100%;
}

.source-line {
  color: #87928d;
  font-size: 22rpx;
  margin-top: 10rpx;
}

.course-row {
  align-items: center;
  border-top: 1rpx solid #edf0ee;
  display: flex;
  justify-content: space-between;
  padding: 22rpx 0;
}

.course-row:first-of-type {
  border-top: 0;
}

.course-code {
  color: #1f6f5b;
  font-size: 27rpx;
  font-weight: 800;
}

.check {
  border: 1rpx solid #d8dfda;
  border-radius: 999rpx;
  color: #64716b;
  font-size: 24rpx;
  padding: 10rpx 16rpx;
}

.check.active {
  background: #1f6f5b;
  border-color: #1f6f5b;
  color: #ffffff;
}

.requirement {
  margin-bottom: 18rpx;
}

.missing {
  margin-top: 18rpx;
}

.missing-title {
  color: #64716b;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.missing-course,
.recommendation {
  border-top: 1rpx solid #edf0ee;
  font-size: 26rpx;
  padding: 16rpx 0;
}

/* Visual system overrides */
.panel-title { color: #17352c; font-weight: 800; }
.big-number { color: #0b6b55; font-size: 82rpx; font-weight: 850; letter-spacing: -3rpx; }
.progress-wrap { background: #e0e9e5; height: 14rpx; }
.progress-bar { background: #0b6b55; }
.course-row { padding: 24rpx 0; }
.course-code { color: #0b6b55; }
.check { background: #f2f5f3; border-color: #d2ddd7; }
.check.active { background: #0b6b55; border-color: #0b6b55; }
.requirement { margin-bottom: 16rpx; overflow: hidden; }
.missing { background: #f5f7f6; border-radius: 12rpx; padding: 18rpx; }
.recommendation { background: #f7f9f8; border-radius: 12rpx; margin-top: 10rpx; padding: 18rpx; }
