.panel-title {
  font-size: 30rpx;
  font-weight: 700;
}

.big-number {
  color: #1f6f5b;
  font-size: 72rpx;
  font-weight: 800;
  margin-top: 12rpx;
}

.progress-wrap {
  background: #e7ece8;
  border-radius: 999rpx;
  height: 18rpx;
  margin-top: 20rpx;
  overflow: hidden;
}

.progress-wrap.small {
  height: 14rpx;
}

.progress-bar {
  background: #1f6f5b;
  height: 100%;
}

.source-line {
  color: #87928d;
  font-size: 22rpx;
  margin-top: 10rpx;
}

.course-row {
  align-items: center;
  border-top: 1rpx solid #edf0ee;
  display: flex;
  justify-content: space-between;
  padding: 22rpx 0;
}

.course-row:first-of-type {
  border-top: 0;
}

.course-code {
  color: #1f6f5b;
  font-size: 27rpx;
  font-weight: 800;
}

.check {
  border: 1rpx solid #d8dfda;
  border-radius: 999rpx;
  color: #64716b;
  font-size: 24rpx;
  padding: 10rpx 16rpx;
}

.check.active {
  background: #1f6f5b;
  border-color: #1f6f5b;
  color: #ffffff;
}

.requirement {
  margin-bottom: 18rpx;
}

.missing {
  margin-top: 18rpx;
}

.missing-title {
  color: #64716b;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.missing-course,
.recommendation {
  border-top: 1rpx solid #edf0ee;
  font-size: 26rpx;
  padding: 16rpx 0;
}

/* Visual system overrides */
.panel-title { color: #17352c; font-weight: 800; }
.big-number { color: #0b6b55; font-size: 82rpx; font-weight: 850; letter-spacing: -3rpx; }
.progress-wrap { background: #e0e9e5; height: 14rpx; }
.progress-bar { background: #0b6b55; }
.course-row { padding: 24rpx 0; }
.course-code { color: #0b6b55; }
.check { background: #f2f5f3; border-color: #d2ddd7; }
.check.active { background: #0b6b55; border-color: #0b6b55; }
.requirement { margin-bottom: 16rpx; overflow: hidden; }
.missing { background: #f5f7f6; border-radius: 12rpx; padding: 18rpx; }
.recommendation { background: #f7f9f8; border-radius: 12rpx; margin-top: 10rpx; padding: 18rpx; }

.audit-kicker {
  color: #0b6b55;
  font-size: 18rpx;
  font-weight: 850;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.audit-kicker.light {
  color: #9fd1c2;
}

.curriculum-card {
  background: #17352c;
  border-radius: 22rpx;
  box-shadow: 0 14rpx 32rpx rgba(8, 45, 35, 0.18);
  padding: 30rpx;
}

.curriculum-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.curriculum-title {
  color: #ffffff;
  font-size: 29rpx;
  font-weight: 800;
}

.verified-seal {
  border: 2rpx solid #82b4a5;
  color: #b9d8cf;
  font-size: 18rpx;
  font-weight: 850;
  line-height: 1.2;
  padding: 10rpx 13rpx;
  text-align: center;
  transform: rotate(3deg);
}

.structure-grid {
  display: grid;
  gap: 1rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 26rpx;
}

.structure-item {
  border-top: 1rpx solid #426258;
  display: flex;
  gap: 13rpx;
  padding: 17rpx 4rpx;
}

.structure-credits {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 850;
  min-width: 48rpx;
}

.structure-name {
  color: #b9d0c8;
  font-size: 21rpx;
  line-height: 1.35;
}

.curriculum-note {
  color: #a9c1b8;
  font-size: 21rpx;
  line-height: 1.55;
  margin-top: 18rpx;
}

.source-action {
  border-top: 1rpx solid #426258;
  color: #dcebe5;
  font-size: 22rpx;
  font-weight: 750;
  margin-top: 20rpx;
  padding-top: 19rpx;
}

.section-heading {
  color: #53665d;
  font-size: 23rpx;
  font-weight: 750;
  margin-bottom: 14rpx;
}

.partial-label {
  color: #9a7340;
  font-size: 17rpx;
  font-weight: 750;
  letter-spacing: 1rpx;
  margin-top: 8rpx;
}
