.code {
  color: #1f6f5b;
  font-size: 32rpx;
  font-weight: 800;
}

.course-heading {
  font-size: 38rpx;
  margin-top: 18rpx;
}

.meta-grid {
  display: grid;
  gap: 24rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 30rpx;
}

.source-line {
  color: #87928d;
  font-size: 22rpx;
  margin-top: 12rpx;
}

.meta-label {
  color: #64716b;
  font-size: 22rpx;
}

.meta-value {
  font-size: 26rpx;
  font-weight: 650;
  line-height: 1.35;
  margin-top: 6rpx;
}

.action-row {
  display: grid;
  gap: 18rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.tpg-action-row {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.plan-button {
  background: #dcece5;
  color: #0b5d4b;
}

.button-disabled {
  background: #e8ece9;
  color: #7b8681;
}

.planning-note {
  color: #6b756f;
  font-size: 24rpx;
  line-height: 1.5;
  margin-top: -16rpx;
}

.panel-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.body {
  color: #25312c;
  font-size: 27rpx;
  line-height: 1.55;
}

.link {
  color: #1f6f5b;
  word-break: break-all;
}

.copy-hint {
  color: #1f6f5b;
  font-size: 24rpx;
  font-weight: 650;
  margin: 14rpx 0;
}

.code { color: #0b6b55; font-size: 34rpx; font-weight: 850; letter-spacing: 1rpx; }
.course-heading { font-size: 40rpx; }
.meta-grid { gap: 14rpx; }
.meta-grid > view { background: #f0f5f2; border-radius: 12rpx; padding: 18rpx; }
.panel-title { color: #17352c; font-weight: 800; }
.link,
.copy-hint { color: #0b6b55; }
