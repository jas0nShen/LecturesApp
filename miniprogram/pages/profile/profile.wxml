<view class="page">
  <view class="section">
    <view class="title">我的资料</view>
    <view class="subtitle">资料暂时保存在本机，可使用下方数据保险箱备份。</view>
  </view>

  <view class="section panel" wx:if="{{profile}}">
    <view class="profile-row">
      <view class="label">大学</view>
      <view>{{profile.universityCode}}</view>
    </view>
    <view class="profile-row">
      <view class="label">Programme</view>
      <view>{{profile.programmeName}}</view>
    </view>
    <view wx:if="{{profile.profileType !== 'tpg'}}" class="profile-row">
      <view class="label">Major</view>
      <view>{{profile.majorName}}</view>
    </view>
    <view class="profile-row">
      <view class="label">Curriculum Year</view>
      <view>{{profile.curriculumYear}}</view>
    </view>
    <view wx:if="{{profile.profileType !== 'tpg'}}" class="profile-row">
      <view class="label">当前年级</view>
      <view>Year {{profile.currentYear}}</view>
    </view>
    <view wx:if="{{profile.profileType === 'tpg'}}" class="profile-row">
      <view class="label">课程资料</view>
      <view>{{profile.courseCount ? '已录入 ' + profile.courseCount + ' 门' : '核验中'}}</view>
    </view>
  </view>

  <view class="section panel" wx:else>
    <view class="panel-title">还没有设置专业</view>
    <view class="subtitle">设置后可以查看匹配课程和毕业要求。</view>
  </view>

  <view class="section">
    <view class="button" bindtap="goOnboarding">{{profile ? '修改资料' : '开始设置'}}</view>
  </view>

  <view class="section notes-entry" bindtap="goCourseNotes">
    <view class="notes-mark">NOTES</view>
    <view class="notes-main">
      <view class="panel-title">我的课程笔记</view>
      <view class="subtitle">{{noteSummary}}</view>
    </view>
    <view class="notes-arrow">›</view>
  </view>

  <view class="section data-entry" bindtap="goDataStatus">
    <view class="data-dot {{dataStatus.status}}"></view>
    <view class="notes-main">
      <view class="panel-title">数据状态</view>
      <view class="subtitle">{{dataStatus.statusLabel}} · 开课目录更新于 {{dataStatus.offering.updatedDate}}</view>
    </view>
    <view class="notes-arrow">›</view>
  </view>

  <view class="section data-entry" bindtap="goPrivacyData">
    <view class="privacy-icon">LOCAL</view>
    <view class="notes-main">
      <view class="panel-title">数据与隐私</view>
      <view class="subtitle">查看本机数据、备份或彻底清除</view>
    </view>
    <view class="notes-arrow">›</view>
  </view>

  <view class="section vault">
    <view class="vault-mark">LOCAL VAULT</view>
    <view class="panel-title">数据保险箱</view>
    <view class="vault-copy">把资料、收藏、已修记录和 Study Plan 复制成一份文本备份。数据不会上传服务器。</view>
    <view class="vault-actions">
      <view class="vault-button primary" bindtap="copyBackup">复制备份</view>
      <view class="vault-button" bindtap="restoreBackup">从剪贴板恢复</view>
    </view>
  </view>

  <view class="section panel">
    <view class="panel-title">数据说明</view>
    <view class="subtitle">官方开课数据来自香港大学官网；毕业检查规则仍在持续核验，仅供规划参考，以大学官方要求为准。</view>
  </view>
</view>
