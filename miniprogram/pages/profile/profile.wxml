<view class="page">
  <view class="section">
    <view class="title">我的资料</view>
    <view class="subtitle">资料保存在本机，不会自动同步到云端；换设备前可使用下方数据保险箱备份。</view>
  </view>

  <view wx:if="{{isTpg && tpgProfile}}" class="section tpg-profile-card" bindtap="goSelectedTpg">
    <view class="tpg-profile-head">
      <view>
        <view class="tpg-kicker">{{profile.universityCode}} · {{tpgProfile.yearLabel}}</view>
        <view class="tpg-name">{{profile.programmeName}}</view>
      </view>
      <view class="tpg-profile-seal">TPG</view>
    </view>
    <view class="tpg-profile-meta">{{tpgProfile.schoolLabel}} · {{tpgProfile.creditsLabel}}</view>
    <view class="tpg-profile-foot">
      <view>
        <view class="tpg-status">{{tpgProfile.statusLabel}}</view>
        <view class="tpg-hint">点击查看 Programme 课程结构和官方来源</view>
      </view>
      <view class="notes-arrow">›</view>
    </view>
  </view>

  <view class="section panel" wx:if="{{profile}}">
    <view class="profile-row">
      <view class="label">大学</view>
      <view>{{profile.universityCode}}</view>
    </view>
    <view class="profile-row">
      <view class="label">Programme</view>
      <view>{{profile.programmeName}}</view>
    </view>
    <view wx:if="{{profile.profileType !== 'tpg'}}" class="profile-row">
      <view class="label">Major</view>
      <view>{{profile.majorName}}</view>
    </view>
    <view class="profile-row">
      <view class="label">Curriculum Year</view>
      <view>{{profile.curriculumYear}}</view>
    </view>
    <view wx:if="{{profile.profileType !== 'tpg'}}" class="profile-row">
      <view class="label">当前年级</view>
      <view>Year {{profile.currentYear}}</view>
    </view>
    <view wx:if="{{profile.profileType === 'tpg'}}" class="profile-row">
      <view class="label">课程资料</view>
      <view>{{profile.courseCount ? '已开放 ' + profile.courseCount + ' 门' : '课程清单待开放'}}</view>
    </view>
    <view wx:if="{{profile.profileType === 'tpg' && profile.trackId}}" class="profile-row">
      <view class="profile-key">Track</view>
      <view>{{profile.trackName}}</view>
    </view>
    <view wx:if="{{isUgCatalogue && ugProfile}}" class="profile-row">
      <view class="label">本科资料</view>
      <view>{{ugProfile.codedCourseCount ? '已开放 ' + ugProfile.codedCourseCount + ' 门' : 'Programme / Major 已收录'}}</view>
    </view>
  </view>

  <view class="section panel" wx:else>
    <view class="panel-title">还没有设置专业</view>
    <view class="subtitle">设置后可以查看匹配课程和毕业要求。</view>
  </view>

  <view class="section">
    <view class="button" bindtap="goOnboarding">{{profile ? '修改资料' : '开始设置'}}</view>
  </view>

  <view wx:if="{{ugLoadError}}" class="section panel">
    <view class="panel-title">本科课程数据暂时无法加载</view>
    <view class="subtitle">你的本机资料仍已保留，可重新加载后查看课程状态。</view>
    <view class="button" bindtap="retryUgLoad">重新加载</view>
  </view>

  <view wx:if="{{isTpg}}" class="section tpg-mini-actions">
    <view class="mini-action" bindtap="goTpgCatalog">浏览 Programme</view>
    <view class="mini-action primary" bindtap="goDataStatus">查看资料来源</view>
  </view>

  <view class="section notes-entry" bindtap="goCourseNotes">
    <view class="notes-mark">NOTES</view>
    <view class="notes-main">
      <view class="panel-title">我的课程笔记</view>
      <view class="subtitle">{{noteSummary}}</view>
    </view>
    <view class="notes-arrow">›</view>
  </view>

  <view class="section data-entry" bindtap="goDataStatus">
    <view class="data-dot {{dataStatus.status}}"></view>
    <view class="notes-main">
      <view class="panel-title">数据状态</view>
    <view class="subtitle">{{isTpg ? 'Programme 资料来源、版本与本地数据状态' : (isUgCatalogue ? '本科 Programme / Major 索引与本地数据状态' : dataStatus.statusLabel + ' · 开课目录更新于 ' + dataStatus.offering.updatedDate)}}</view>
    </view>
    <view class="notes-arrow">›</view>
  </view>

  <view class="section data-entry" bindtap="goPrivacyData">
    <view class="privacy-icon">LOCAL</view>
    <view class="notes-main">
      <view class="panel-title">数据与隐私</view>
      <view class="subtitle">查看本机数据、备份或彻底清除</view>
    </view>
    <view class="notes-arrow">›</view>
  </view>

  <view class="section feedback-entry">
    <view class="feedback-head">
      <view>
        <view class="feedback-kicker">FEEDBACK</view>
        <view class="panel-title">反馈与纠错</view>
      </view>
      <view class="feedback-tag">不上云</view>
    </view>
    <view class="feedback-copy">发现 Programme、课程组或页面显示有问题，可以复制一份带当前资料范围的反馈模板，再发给开发者。</view>
    <view class="feedback-button" bindtap="copyFeedbackTemplate">复制反馈模板</view>
  </view>

  <view class="section vault">
    <view class="vault-mark">LOCAL VAULT</view>
    <view class="panel-title">数据保险箱</view>
    <view class="vault-copy">把资料、收藏、已修记录和 Study Plan 复制成一份文本备份。数据不会上传服务器，也不会自动同步到其他设备。</view>
    <view wx:if="{{userSummary}}" class="vault-summary">
      <view class="vault-summary-item">
        <view class="vault-summary-value">{{userSummary.favoriteCount}}</view>
        <view class="vault-summary-label">收藏</view>
      </view>
      <view class="vault-summary-item">
        <view class="vault-summary-value">{{userSummary.studyPlanCount}}</view>
        <view class="vault-summary-label">计划</view>
      </view>
      <view class="vault-summary-item">
        <view class="vault-summary-value">{{userSummary.noteCount}}</view>
        <view class="vault-summary-label">笔记</view>
      </view>
      <view class="vault-summary-item">
        <view class="vault-summary-value">{{userSummary.searchCount}}</view>
        <view class="vault-summary-label">搜索</view>
      </view>
    </view>
    <view class="vault-actions">
      <view class="vault-button primary" bindtap="copyBackup">复制备份</view>
      <view class="vault-button" bindtap="restoreBackup">从剪贴板恢复</view>
    </view>
  </view>

  <view class="section panel">
    <view class="panel-title">数据说明</view>
    <view class="subtitle">{{isTpg ? '授课硕士资料来自公开资料与本地复核；课程组尚未开放的 Programme 只展示索引与来源，暂不生成毕业判断。' : (isUgCatalogue ? '本科资料先展示 Programme / Major 索引和已公开课程代码；毕业规则完成复核前不会生成进度判断。' : '官方开课数据来自香港大学官网；毕业检查仅供规划参考，以大学官方要求为准。')}}</view>
  </view>
</view>
