.profile-row {
  align-items: center;
  border-top: 1rpx solid #edf0ee;
  display: flex;
  font-size: 28rpx;
  justify-content: space-between;
  padding: 22rpx 0;
  text-align: right;
}

.profile-row:first-of-type {
  border-top: 0;
}

.label {
  color: #64716b;
  margin-right: 24rpx;
  text-align: left;
}

.panel-title {
  font-size: 30rpx;
  font-weight: 700;
}

.profile-row { padding: 25rpx 0; }
.label { color: #687970; font-size: 23rpx; font-weight: 650; }
.panel-title { color: #17352c; font-weight: 800; }

.vault {
  background: #17352c;
  border-radius: 20rpx;
  box-shadow: 0 12rpx 28rpx rgba(15, 64, 51, 0.12);
  padding: 30rpx;
}
.vault .panel-title { color: #ffffff; margin-top: 18rpx; }
.vault-mark { color: #8fc8b7; font-size: 19rpx; font-weight: 800; letter-spacing: 3rpx; }
.vault-copy { color: #bfd4cc; font-size: 23rpx; line-height: 1.55; margin-top: 12rpx; }
.vault-actions { display: grid; gap: 12rpx; grid-template-columns: repeat(2, minmax(0, 1fr)); margin-top: 24rpx; }
.vault-button {
  align-items: center;
  border: 1rpx solid #5a796d;
  border-radius: 12rpx;
  color: #dce9e4;
  display: flex;
  font-size: 23rpx;
  font-weight: 700;
  justify-content: center;
  min-height: 76rpx;
  text-align: center;
}
.vault-button.primary { background: #e2eee9; border-color: #e2eee9; color: #0b5d4b; }

.notes-entry {
  align-items: center;
  background: #fbfcfa;
  border: 1rpx solid #dce6e0;
  border-radius: 18rpx;
  display: flex;
  padding: 26rpx;
}

.data-entry {
  align-items: center;
  background: #fbfcfa;
  border: 1rpx solid #dce6e0;
  border-radius: 18rpx;
  display: flex;
  padding: 24rpx 26rpx;
}

.data-dot {
  background: #0b6b55;
  border: 7rpx solid #dcece6;
  border-radius: 50%;
  height: 22rpx;
  width: 22rpx;
}

.data-dot.review {
  background: #b26d20;
  border-color: #f1e3d1;
}

.privacy-icon {
  border: 2rpx solid #71877d;
  color: #60766c;
  font-size: 15rpx;
  font-weight: 850;
  letter-spacing: 1rpx;
  padding: 10rpx 7rpx;
}

.notes-mark {
  border: 2rpx solid #0b6b55;
  color: #0b6b55;
  font-size: 17rpx;
  font-weight: 850;
  letter-spacing: 2rpx;
  padding: 14rpx 9rpx;
  transform: rotate(-3deg);
}

.notes-main {
  flex: 1;
  margin-left: 22rpx;
}

.notes-main .subtitle {
  font-size: 22rpx;
  margin-top: 5rpx;
}

.notes-arrow {
  color: #789087;
  font-size: 42rpx;
}
