.profile-row {
  align-items: center;
  border-top: 1rpx solid #edf0ee;
  display: flex;
  font-size: 28rpx;
  justify-content: space-between;
  padding: 22rpx 0;
  text-align: right;
}

.profile-row:first-of-type {
  border-top: 0;
}

.label {
  color: #64716b;
  margin-right: 24rpx;
  text-align: left;
}

.panel-title {
  font-size: 30rpx;
  font-weight: 700;
}

.profile-row { padding: 25rpx 0; }
.label { color: #687970; font-size: 23rpx; font-weight: 650; }
.panel-title { color: #17352c; font-weight: 800; }

.tpg-profile-card {
  background: #17352c;
  border-radius: 22rpx;
  box-shadow: 0 14rpx 32rpx rgba(8, 45, 35, 0.18);
  color: #ffffff;
  overflow: hidden;
  padding: 32rpx;
  position: relative;
}

.tpg-profile-card::after {
  border: 1rpx solid rgba(180, 215, 203, 0.28);
  border-radius: 50%;
  content: '';
  height: 210rpx;
  position: absolute;
  right: -70rpx;
  top: -72rpx;
  width: 210rpx;
}

.tpg-profile-head {
  align-items: flex-start;
  display: flex;
  gap: 18rpx;
  justify-content: space-between;
  position: relative;
  z-index: 1;
}

.tpg-kicker {
  color: #9fd1c2;
  font-size: 19rpx;
  font-weight: 850;
  letter-spacing: 2rpx;
}

.tpg-name {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 850;
  letter-spacing: -1rpx;
  line-height: 1.2;
  margin-top: 12rpx;
}

.tpg-profile-seal {
  border: 2rpx solid #82b4a5;
  color: #dcebe5;
  flex: none;
  font-size: 18rpx;
  font-weight: 850;
  letter-spacing: 1rpx;
  padding: 10rpx 13rpx;
  transform: rotate(3deg);
}

.tpg-profile-meta {
  color: #bdd6ce;
  font-size: 22rpx;
  line-height: 1.45;
  margin-top: 16rpx;
}

.tpg-profile-foot {
  align-items: center;
  border-top: 1rpx solid #426258;
  display: flex;
  justify-content: space-between;
  margin-top: 24rpx;
  padding-top: 20rpx;
}

.tpg-status {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
}

.tpg-hint {
  color: #a9c1b8;
  font-size: 20rpx;
  margin-top: 6rpx;
}

.tpg-profile-card .notes-arrow {
  color: #a9c1b8;
}

.tpg-mini-actions {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.mini-action {
  align-items: center;
  background: #e4f0eb;
  border-radius: 14rpx;
  color: #0b6b55;
  display: flex;
  font-size: 24rpx;
  font-weight: 800;
  justify-content: center;
  min-height: 76rpx;
  text-align: center;
}

.mini-action.primary {
  background: #0b6b55;
  color: #ffffff;
}

.vault {
  background: #17352c;
  border-radius: 20rpx;
  box-shadow: 0 12rpx 28rpx rgba(15, 64, 51, 0.12);
  padding: 30rpx;
}
.vault .panel-title { color: #ffffff; margin-top: 18rpx; }
.vault-mark { color: #8fc8b7; font-size: 19rpx; font-weight: 800; letter-spacing: 3rpx; }
.vault-copy { color: #bfd4cc; font-size: 23rpx; line-height: 1.55; margin-top: 12rpx; }
.vault-actions { display: grid; gap: 12rpx; grid-template-columns: repeat(2, minmax(0, 1fr)); margin-top: 24rpx; }
.vault-button {
  align-items: center;
  border: 1rpx solid #5a796d;
  border-radius: 12rpx;
  color: #dce9e4;
  display: flex;
  font-size: 23rpx;
  font-weight: 700;
  justify-content: center;
  min-height: 76rpx;
  text-align: center;
}
.vault-button.primary { background: #e2eee9; border-color: #e2eee9; color: #0b5d4b; }

.notes-entry {
  align-items: center;
  background: #fbfcfa;
  border: 1rpx solid #dce6e0;
  border-radius: 18rpx;
  display: flex;
  padding: 26rpx;
}

.data-entry {
  align-items: center;
  background: #fbfcfa;
  border: 1rpx solid #dce6e0;
  border-radius: 18rpx;
  display: flex;
  padding: 24rpx 26rpx;
}

.data-dot {
  background: #0b6b55;
  border: 7rpx solid #dcece6;
  border-radius: 50%;
  height: 22rpx;
  width: 22rpx;
}

.data-dot.review {
  background: #b26d20;
  border-color: #f1e3d1;
}

.privacy-icon {
  border: 2rpx solid #71877d;
  color: #60766c;
  font-size: 15rpx;
  font-weight: 850;
  letter-spacing: 1rpx;
  padding: 10rpx 7rpx;
}

.notes-mark {
  border: 2rpx solid #0b6b55;
  color: #0b6b55;
  font-size: 17rpx;
  font-weight: 850;
  letter-spacing: 2rpx;
  padding: 14rpx 9rpx;
  transform: rotate(-3deg);
}

.notes-main {
  flex: 1;
  margin-left: 22rpx;
}

.notes-main .subtitle {
  font-size: 22rpx;
  margin-top: 5rpx;
}

.notes-arrow {
  color: #789087;
  font-size: 42rpx;
}
