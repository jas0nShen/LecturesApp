<view wx:if="{{loadError}}" class="page pending">
  <view class="pending-title">硕士课程数据加载失败</view>
  <view class="pending-copy">请重新加载；已保存的 Programme、收藏和已修记录不会丢失。</view>
  <button class="save-button" bindtap="retryLoad">重新加载</button>
</view>
<view wx:elif="{{programme}}" class="page">
  <view class="identity">
    <view class="identity-top">
      <view class="school-stamp">{{programme.universityCode}}</view>
      <view class="year">{{university.academicYear}}</view>
    </view>
    <view class="programme-name">{{programme.name}}</view>
    <view wx:if="{{programme.faculty}}" class="faculty">{{programme.faculty}}</view>
    <view class="identity-rule"></view>
    <view class="facts">
      <view class="fact">
        <view class="fact-label">Programme code</view>
        <view class="fact-value">{{programme.programmeCode || '待确认'}}</view>
      </view>
      <view class="fact">
        <view class="fact-label">毕业学分</view>
        <view class="fact-value">{{programme.creditsRequired ? programme.creditsRequired + ' credits / units' : '待确认'}}</view>
      </view>
    </view>
  </view>

  <view class="status-card {{hasCourseGroups ? 'status-ready' : ''}}">
    <view class="status-mark">{{hasCourseGroups ? '已开放' : '复核中'}}</view>
    <view class="status-content">
      <view class="status-title">{{statusTitle}}</view>
      <view class="status-copy">{{statusCopy}}</view>
    </view>
  </view>

  <view class="current-range-card {{isCurrentProgramme ? 'current-range-active' : ''}}">
    <view class="current-range-mark">{{isCurrentProgramme ? '本机已保存' : '尚未保存'}}</view>
    <view class="current-range-main">
      <view class="current-range-title">{{isCurrentProgramme ? '这是你当前的课程范围' : '保存后可作为你的课程范围'}}</view>
      <view class="current-range-copy">
        {{isCurrentProgramme ? '首页、资料库和毕业检查会优先使用这个 Programme；数据只保存在本机。' : '设为我的 Programme 后，首页和资料库会高亮它，收藏、计划与笔记仍只保存在本机。'}}
      </view>
    </view>
  </view>

  <view wx:if="{{hasCourseGroups}}" class="section">
    <view class="section-kicker">课程结构</view>
    <view
      wx:for="{{programme.courseGroups}}"
      wx:key="name"
      wx:for-item="group"
      class="course-group"
    >
      <view class="group-head">
        <view class="group-name">{{group.name}}</view>
        <view wx:if="{{group.creditsRequired}}" class="group-credit">{{group.creditsRequired}} credits</view>
      </view>
      <view wx:for="{{group.courses}}" wx:key="code" wx:for-item="course" class="course-row">
        <view class="course-code">{{course.code}}</view>
        <view class="course-name">{{course.name}}</view>
      </view>
    </view>
  </view>

  <view wx:else class="section pending">
    <view class="section-kicker">课程结构</view>
    <view class="pending-title">课程清单待开放</view>
    <view class="pending-copy">课程组会按必修、选修及项目要求展示。复核完成前，这里先保留 Programme 与来源信息。</view>
    <view class="pending-steps">
      <view class="pending-step"><text>01</text> 对照 Programme 官方页面</view>
      <view class="pending-step"><text>02</text> 拆分必修与选修课程</view>
      <view class="pending-step"><text>03</text> 复核学分与毕业要求</view>
    </view>
  </view>

  <view class="source-card">
    <view>
      <view class="source-label">资料来源</view>
      <view class="source-name">{{university.shortName}} · {{university.sourceFile}}</view>
    </view>
    <view class="source-status">PDF 已导入</view>
  </view>

  <view class="action-grid">
    <button
      class="save-button {{isCurrentProgramme ? 'save-button-current' : ''}}"
      bindtap="saveAsMyProgramme"
    >{{isCurrentProgramme ? '当前 Programme' : '设为我的 Programme'}}</button>
    <button
      class="official-button {{programme.sourceUrl ? '' : 'official-button-muted'}}"
      bindtap="copyOfficialLink"
    >{{programme.sourceUrl ? '复制官方链接' : '复制资料来源'}}</button>
  </view>

  <button class="feedback-button" bindtap="copyFeedbackTemplate">反馈这个 Programme</button>

  <button wx:if="{{isCurrentProgramme}}" class="home-button" bindtap="goHome">返回首页查看我的 Programme</button>

  <view class="disclaimer">资料用于辅助规划，不替代学校官网、选课系统或学校正式审核结果。</view>
</view>
