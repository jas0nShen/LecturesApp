<view class="page">
  <view class="section compare-head">
    <view class="compare-kicker">SIDE BY SIDE · HKU</view>
    <view class="title">课程对比</view>
    <view class="subtitle">并排核对开课安排与修读要求，最终信息仍以学校官网为准。</view>
  </view>

  <view wx:if="{{courses.length < 2}}" class="section empty">
    <view class="empty-title">没有足够的课程可比较</view>
    <view class="empty-copy">请返回收藏页，至少选择 2 门官方开课。</view>
  </view>

  <scroll-view wx:else scroll-x class="compare-scroll" enhanced>
    <view class="compare-sheet columns-{{courses.length}}">
      <view class="metric-column">
        <view class="metric-head">比较项目</view>
        <view class="metric-cell title-cell">课程</view>
        <view class="metric-cell">开课学期</view>
        <view class="metric-cell">学分</view>
        <view class="metric-cell">建议年级</view>
        <view class="metric-cell requirement-cell">先修要求</view>
        <view class="metric-cell requirement-cell">共修要求</view>
        <view class="metric-cell requirement-cell">互斥课程</view>
        <view class="metric-cell">我的状态</view>
      </view>

      <view wx:for="{{courses}}" wx:key="courseCode" class="course-column">
        <view class="course-head">{{item.courseCode}}</view>
        <view class="course-cell title-cell">
          <view class="course-title">{{item.title}}</view>
          <view class="course-category">{{item.categoryLabel}}</view>
        </view>
        <view class="course-cell">Semester {{item.termLabel}}</view>
        <view class="course-cell emphasis">{{item.credits}}</view>
        <view class="course-cell">{{item.recommendedYear}}</view>
        <view class="course-cell requirement-cell">{{item.prerequisites}}</view>
        <view class="course-cell requirement-cell">{{item.corequisites}}</view>
        <view class="course-cell requirement-cell">{{item.exclusions}}</view>
        <view class="course-cell status-cell">
          <view wx:if="{{item.completed}}" class="status done">✓ 已修</view>
          <view wx:elif="{{item.planned}}" class="status planned">◆ 已计划</view>
          <view wx:else class="status">未安排</view>
          <view class="open-course" data-code="{{item.courseCode}}" bindtap="goCourse">查看详情 ›</view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
