<view class="page">
  <view class="section">
    <view class="title">选择你的课程范围</view>
    <view class="subtitle">本科与授课硕士使用不同的培养方案结构，请先选择类型。</view>
  </view>

  <view class="section mode-switch">
    <view
      class="mode-option {{mode === 'undergraduate' ? 'mode-option-active' : ''}}"
      data-mode="undergraduate"
      bindtap="selectMode"
    >
      <view class="mode-mark">UG</view>
      <view>本科</view>
    </view>
    <view
      class="mode-option {{mode === 'tpg' ? 'mode-option-active' : ''}}"
      data-mode="tpg"
      bindtap="selectMode"
    >
      <view class="mode-mark">TPG</view>
      <view>授课硕士</view>
    </view>
  </view>

  <view wx:if="{{mode === 'undergraduate'}}" class="section panel">
    <view class="scope-note ug-note">
      选择你的大学、Programme 和 Major；课程清单未开放时，也可以先保存资料。
    </view>

    <view wx:if="{{savedUgProfile}}" class="saved-scope-card ug-saved-scope-card" bindtap="previewSavedUgProfile">
      <view class="saved-scope-mark">CURRENT</view>
      <view class="saved-scope-main">
        <view class="saved-scope-title">当前本机保存：{{savedUgProfile.programme.nameEn}}</view>
        <view class="saved-scope-copy">{{savedUgProfile.university.nameZh || savedUgProfile.university.code}} · {{savedUgProfile.major.nameEn}} · {{savedUgProfile.codedCourseCount ? '已开放 ' + savedUgProfile.codedCourseCount + ' 门课程' : '课程清单待开放'}}</view>
      </view>
      <view class="saved-scope-arrow">›</view>
    </view>

    <view wx:if="{{selectedUgCoverage}}" class="ug-coverage-card">
      <view>
        <view class="coverage-kicker">当前学校数据</view>
        <view class="coverage-title">{{selectedUniversity.nameZh}}</view>
        <view class="coverage-copy">{{selectedUgCoverage.programmeCount}} Programme · {{selectedUgCoverage.majorCount}} Major / Track</view>
      </view>
      <view class="coverage-status {{selectedUgCoverage.codedCourseCount ? 'coverage-status-ready' : ''}}">
        <view class="coverage-badge">{{selectedUgCoverage.badge}}</view>
        <view class="coverage-count">{{selectedUgCoverage.codedCourseCount ? selectedUgCoverage.codedCourseCount + ' codes' : '课程待开放'}}</view>
      </view>
    </view>

    <view class="field">
      <view class="label">大学</view>
      <view class="select select-arrow" bindtap="openUgUniversitySheet">{{selectedUniversity.nameZh || '请选择你的学校'}}</view>
    </view>

    <view wx:if="{{!selectedUniversity.id}}" class="programme-empty">
      <view>请先选择你的学校，然后再选择 Programme 和 Major。</view>
    </view>

    <view wx:if="{{selectedUniversity.id}}" class="field">
      <view class="label">Programme</view>
      <view class="programme-search">
        <input
          class="programme-input"
          value="{{ugKeyword}}"
          placeholder="搜索 Programme、代码、学院"
          confirm-type="search"
          bindinput="onUgKeyword"
        />
        <view wx:if="{{ugKeyword}}" class="programme-clear" bindtap="clearUgKeyword">×</view>
      </view>
      <view wx:if="{{filteredUgProgrammes.length}}" class="select select-programme select-arrow" bindtap="openUgProgrammeSheet">
        <view class="select-programme-name">{{selectedProgramme.nameZh || '请选择 Programme'}}</view>
        <view class="select-programme-meta">{{filteredUgProgrammes.length}} 个匹配结果 · 当前 {{ugSelectedIndexLabel}}</view>
      </view>
    </view>

    <view wx:if="{{selectedUniversity.id && filteredUgProgrammes.length}}" class="programme-results">
      <view
        wx:for="{{visibleUgProgrammes}}"
        wx:key="id"
        class="programme-result {{selectedProgramme.id === item.id ? 'programme-result-active' : ''}}"
        data-id="{{item.id}}"
        bindtap="selectUgProgramme"
      >
        <view class="result-code">{{item.code || item.jupasCode || selectedUniversity.code}}</view>
        <view class="result-main">
          <view class="result-name">{{item.nameZh}}</view>
          <view class="result-meta">{{item.faculty || 'Faculty 待确认'}} · {{item.courseStatusLabel}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{selectedUniversity.id && !filteredUgProgrammes.length}}" class="programme-empty">
      <view>没有找到匹配 Programme。试试输入 Computer、Engineering、Business 或代码。</view>
      <view wx:if="{{ugKeyword}}" class="programme-empty-action" bindtap="clearUgKeyword">清除搜索</view>
    </view>

    <view wx:if="{{selectedProgramme.id}}">
      <view class="field">
        <view class="label">Major</view>
        <view class="select select-arrow" bindtap="openUgMajorSheet">{{selectedMajor.nameZh || '请选择 Major'}}</view>
      </view>

      <view class="field">
        <view class="label">Curriculum Year</view>
        <view class="select select-arrow" bindtap="openUgCurriculumYearSheet">{{curriculumYear}}</view>
      </view>

      <view class="field">
        <view class="label">当前年级</view>
        <view class="select select-arrow" bindtap="openCurrentYearSheet">Year {{currentYear}}</view>
      </view>

      <view class="ug-proof">
        <view class="proof-stamp">{{selectedUniversity.code || 'UG'}}</view>
        <view class="proof-main">
          <view class="proof-label">本科资料状态</view>
          <view class="proof-value">{{ugCourseStatus}}</view>
          <view class="proof-meta">{{selectedProgramme.nameEn || 'Programme 待选择'}} · {{selectedMajor.nameEn || 'Major 待选择'}}</view>
        </view>
      </view>

      <view class="button-space">
        <view class="button" bindtap="save">保存本科培养方案</view>
      </view>
    </view>
  </view>

  <view wx:else class="section panel tpg-panel">
    <view class="scope-note tpg-note">选择学校与 Programme 后，已开放课程组的项目会显示课程结构；未开放的项目会保留资料来源。</view>

    <view wx:if="{{savedTpgProfile}}" class="saved-scope-card" bindtap="previewSavedTpgProgramme">
      <view class="saved-scope-mark">CURRENT</view>
      <view class="saved-scope-main">
        <view class="saved-scope-title">当前本机保存：{{savedTpgProfile.programme.name}}</view>
        <view class="saved-scope-copy">{{savedTpgProfile.schoolLabel}} · {{savedTpgProfile.yearLabel}} · {{savedTpgProfile.statusLabel}}</view>
      </view>
      <view class="saved-scope-arrow">›</view>
    </view>

    <view wx:if="{{selectedTpgCoverage}}" class="ug-coverage-card tpg-coverage-card">
      <view>
        <view class="coverage-kicker">当前学校数据</view>
        <view class="coverage-title">{{selectedTpgUniversity.shortName}}</view>
        <view class="coverage-copy">{{selectedTpgCoverage.programmeCount}} Programme · {{selectedTpgCoverage.programmeWithCoursesCount}} 个已开放课程组</view>
      </view>
      <view class="coverage-status {{selectedTpgCoverage.courseCount ? 'coverage-status-ready' : ''}}">
        <view class="coverage-badge">{{selectedTpgCoverage.badge}}</view>
        <view class="coverage-count">{{selectedTpgCoverage.courseCount ? selectedTpgCoverage.courseCount + ' courses' : '课程待开放'}}</view>
      </view>
    </view>

    <view class="field">
      <view class="label">大学</view>
      <view class="select select-arrow" bindtap="openTpgUniversitySheet">{{selectedTpgUniversity.shortName || '请选择你的学校'}}</view>
    </view>

    <view wx:if="{{!selectedTpgUniversity.code}}" class="programme-empty">
      <view>请先选择你的学校，然后再搜索或选择 Programme。</view>
    </view>

    <view wx:if="{{selectedTpgUniversity.code}}" class="field">
      <view class="label">Programme</view>
      <view class="programme-search">
        <input
          class="programme-input"
          value="{{tpgKeyword}}"
          placeholder="搜索 Programme 名称、代码或学院"
          confirm-type="search"
          bindinput="onTpgKeyword"
        />
        <view wx:if="{{tpgKeyword}}" class="programme-clear" bindtap="clearTpgKeyword">×</view>
      </view>
      <view wx:if="{{filteredTpgProgrammes.length}}" class="select select-programme select-arrow" bindtap="openTpgProgrammeSheet">
        <view class="select-programme-name">{{selectedTpgProgramme.name || '请选择 Programme'}}</view>
        <view class="select-programme-meta">{{filteredTpgProgrammes.length}} 个匹配结果 · 当前 {{tpgSelectedIndexLabel}}</view>
      </view>
    </view>

    <view wx:if="{{selectedTpgUniversity.code && filteredTpgProgrammes.length}}" class="programme-results">
      <view
        wx:for="{{visibleTpgProgrammes}}"
        wx:key="id"
        class="programme-result {{selectedTpgProgramme.id === item.id ? 'programme-result-active' : ''}}"
        data-id="{{item.id}}"
        bindtap="selectTpgProgramme"
      >
        <view class="result-code">{{item.programmeCode || item.universityCode}}</view>
        <view class="result-main">
          <view class="result-name">{{item.name}}</view>
          <view class="result-meta">{{item.faculty || 'Faculty 待确认'}} · {{item.creditsRequired ? item.creditsRequired + ' credits / units' : '学分待确认'}} · {{item.courseStatusLabel}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{selectedTpgUniversity.code && !filteredTpgProgrammes.length}}" class="programme-empty">
      <view>{{tpgEmptyTitle}}</view>
      <view class="programme-empty-copy">{{tpgEmptyCopy}}</view>
      <view wx:if="{{tpgKeyword && tpgProgrammes.length}}" class="programme-empty-action" bindtap="clearTpgKeyword">清除搜索</view>
    </view>

    <view wx:if="{{selectedTpgProgramme.id}}">
      <view wx:if="{{tpgTracks.length}}" class="field">
        <view class="label">Track</view>
        <view class="select select-arrow" bindtap="openTpgTrackSheet">{{selectedTpgTrack.name || '请选择 Track'}}</view>
      </view>
      <view class="programme-proof">
        <view class="proof-stamp">{{selectedTpgUniversity.code}}</view>
        <view class="proof-main">
          <view class="proof-label">当前数据状态</view>
          <view class="proof-value">{{tpgCourseStatus}}</view>
          <view class="proof-meta">{{selectedTpgProgramme.academicYear || selectedTpgUniversity.academicYear}} · {{selectedTpgProgramme.creditsRequired ? selectedTpgProgramme.creditsRequired + ' credits / units' : '学分待确认'}}</view>
        </view>
      </view>

      <view class="tpg-explain">授课硕士方向按学校官方名称显示为 Track；没有官方 Stream、Specialism 或 Concentration 的 Programme 不创建占位 Track。</view>

      <view class="button-space tpg-actions">
        <view class="preview-button" bindtap="previewTpgProgramme">预览 Programme</view>
        <view class="button" bindtap="save">保存授课硕士 Programme</view>
      </view>
    </view>
  </view>

  <view wx:if="{{showUgUniversitySheet}}" class="sheet-mask" bindtap="closeUgUniversitySheet">
    <view class="sheet" catchtap="noop">
      <view class="sheet-head">
        <view class="sheet-cancel" bindtap="closeUgUniversitySheet">取消</view>
        <view class="sheet-title">选择大学</view>
        <view class="sheet-placeholder"></view>
      </view>
      <scroll-view class="sheet-list" scroll-y>
        <view
          wx:for="{{universityOptions}}"
          wx:key="*this"
          class="sheet-option {{ugUniversityIndex === index ? 'sheet-option-active' : ''}}"
          data-index="{{index}}"
          bindtap="selectUgUniversity"
        >{{item}}</view>
      </scroll-view>
    </view>
  </view>

  <view wx:if="{{showUgProgrammeSheet}}" class="sheet-mask" bindtap="closeUgProgrammeSheet">
    <view class="sheet" catchtap="noop">
      <view class="sheet-head">
        <view class="sheet-cancel" bindtap="closeUgProgrammeSheet">取消</view>
        <view class="sheet-title">选择 Programme</view>
        <view class="sheet-placeholder"></view>
      </view>
      <scroll-view class="sheet-list sheet-list-tall" scroll-y>
        <view
          wx:for="{{programmeOptions}}"
          wx:key="*this"
          class="sheet-option sheet-option-multiline {{ugProgrammeIndex === index ? 'sheet-option-active' : ''}}"
          data-index="{{index}}"
          bindtap="selectUgProgrammeFromSheet"
        >{{item}}</view>
      </scroll-view>
    </view>
  </view>

  <view wx:if="{{showUgMajorSheet}}" class="sheet-mask" bindtap="closeUgMajorSheet">
    <view class="sheet" catchtap="noop">
      <view class="sheet-head">
        <view class="sheet-cancel" bindtap="closeUgMajorSheet">取消</view>
        <view class="sheet-title">选择 Major</view>
        <view class="sheet-placeholder"></view>
      </view>
      <scroll-view class="sheet-list" scroll-y>
        <view
          wx:for="{{majorOptions}}"
          wx:key="*this"
          class="sheet-option sheet-option-multiline {{ugMajorIndex === index ? 'sheet-option-active' : ''}}"
          data-index="{{index}}"
          bindtap="selectUgMajor"
        >{{item}}</view>
      </scroll-view>
    </view>
  </view>

  <view wx:if="{{showUgCurriculumYearSheet}}" class="sheet-mask" bindtap="closeUgCurriculumYearSheet">
    <view class="sheet" catchtap="noop">
      <view class="sheet-head">
        <view class="sheet-cancel" bindtap="closeUgCurriculumYearSheet">取消</view>
        <view class="sheet-title">选择 Curriculum Year</view>
        <view class="sheet-placeholder"></view>
      </view>
      <scroll-view class="sheet-list" scroll-y>
        <view
          wx:for="{{curriculumYears}}"
          wx:key="*this"
          class="sheet-option {{ugCurriculumYearIndex === index ? 'sheet-option-active' : ''}}"
          data-index="{{index}}"
          bindtap="selectUgCurriculumYear"
        >{{item}}</view>
      </scroll-view>
    </view>
  </view>

  <view wx:if="{{showCurrentYearSheet}}" class="sheet-mask" bindtap="closeCurrentYearSheet">
    <view class="sheet" catchtap="noop">
      <view class="sheet-head">
        <view class="sheet-cancel" bindtap="closeCurrentYearSheet">取消</view>
        <view class="sheet-title">选择当前年级</view>
        <view class="sheet-placeholder"></view>
      </view>
      <scroll-view class="sheet-list" scroll-y>
        <view
          wx:for="{{yearOptions}}"
          wx:key="*this"
          class="sheet-option {{currentYearIndex === index ? 'sheet-option-active' : ''}}"
          data-index="{{index}}"
          bindtap="selectCurrentYear"
        >Year {{item}}</view>
      </scroll-view>
    </view>
  </view>

  <view wx:if="{{showTpgUniversitySheet}}" class="sheet-mask" bindtap="closeTpgUniversitySheet">
    <view class="sheet" catchtap="noop">
      <view class="sheet-head">
        <view class="sheet-cancel" bindtap="closeTpgUniversitySheet">取消</view>
        <view class="sheet-title">选择大学</view>
        <view class="sheet-placeholder"></view>
      </view>
      <scroll-view class="sheet-list" scroll-y>
        <view
          wx:for="{{tpgUniversityOptions}}"
          wx:key="*this"
          class="sheet-option {{tpgUniversityIndex === index ? 'sheet-option-active' : ''}}"
          data-index="{{index}}"
          bindtap="selectTpgUniversity"
        >{{item}}</view>
      </scroll-view>
    </view>
  </view>

  <view wx:if="{{showTpgProgrammeSheet}}" class="sheet-mask" bindtap="closeTpgProgrammeSheet">
    <view class="sheet" catchtap="noop">
      <view class="sheet-head">
        <view class="sheet-cancel" bindtap="closeTpgProgrammeSheet">取消</view>
        <view class="sheet-title">选择 Programme</view>
        <view class="sheet-placeholder"></view>
      </view>
      <scroll-view class="sheet-list sheet-list-tall" scroll-y>
        <view
          wx:for="{{tpgProgrammeOptions}}"
          wx:key="*this"
          class="sheet-option sheet-option-multiline {{tpgProgrammeIndex === index ? 'sheet-option-active' : ''}}"
          data-index="{{index}}"
          bindtap="selectTpgProgrammeFromSheet"
        >{{item}}</view>
      </scroll-view>
    </view>
  </view>

  <view wx:if="{{showTpgTrackSheet}}" class="sheet-mask" bindtap="closeTpgTrackSheet">
    <view class="sheet" catchtap="noop">
      <view class="sheet-head">
        <view class="sheet-cancel" bindtap="closeTpgTrackSheet">取消</view>
        <view class="sheet-title">选择 Track</view>
        <view class="sheet-placeholder"></view>
      </view>
      <scroll-view class="sheet-list" scroll-y>
        <view
          wx:for="{{tpgTrackOptions}}"
          wx:key="*this"
          class="sheet-option {{tpgTrackIndex === index ? 'sheet-option-active' : ''}}"
          data-index="{{index}}"
          bindtap="selectTpgTrack"
        >{{item}}</view>
      </scroll-view>
    </view>
  </view>
</view>
