<view class="page">
  <view class="section">
    <view class="title">选择你的课程范围</view>
    <view class="subtitle">本科与授课硕士使用不同的培养方案结构，请先选择类型。</view>
  </view>

  <view class="section mode-switch">
    <view
      class="mode-option {{mode === 'undergraduate' ? 'mode-option-active' : ''}}"
      data-mode="undergraduate"
      bindtap="selectMode"
    >
      <view class="mode-mark">UG</view>
      <view>本科</view>
    </view>
    <view
      class="mode-option {{mode === 'tpg' ? 'mode-option-active' : ''}}"
      data-mode="tpg"
      bindtap="selectMode"
    >
      <view class="mode-mark">TPG</view>
      <view>授课硕士</view>
    </view>
  </view>

  <view wx:if="{{mode === 'undergraduate'}}" class="section panel">
    <view class="scope-note ug-note">
      选择你的大学、Programme 和 Major；课程清单未开放时，也可以先保存资料。
    </view>

    <view wx:if="{{savedUgProfile}}" class="saved-scope-card ug-saved-scope-card">
      <view class="saved-scope-mark">CURRENT</view>
      <view class="saved-scope-main">
        <view class="saved-scope-title">当前本机保存：{{savedUgProfile.programme.nameEn}}</view>
        <view class="saved-scope-copy">{{savedUgProfile.university.nameZh || savedUgProfile.university.code}} · {{savedUgProfile.major.nameEn}} · {{savedUgProfile.codedCourseCount ? '已开放 ' + savedUgProfile.codedCourseCount + ' 门课程' : '课程清单待开放'}}</view>
      </view>
    </view>

    <view wx:if="{{selectedUgCoverage}}" class="ug-coverage-card">
      <view>
        <view class="coverage-kicker">当前学校数据</view>
        <view class="coverage-title">{{selectedUniversity.nameZh}}</view>
        <view class="coverage-copy">{{selectedUgCoverage.programmeCount}} Programme · {{selectedUgCoverage.majorCount}} Major / Track</view>
      </view>
      <view class="coverage-status {{selectedUgCoverage.codedCourseCount ? 'coverage-status-ready' : ''}}">
        <view class="coverage-badge">{{selectedUgCoverage.badge}}</view>
        <view class="coverage-count">{{selectedUgCoverage.codedCourseCount ? selectedUgCoverage.codedCourseCount + ' codes' : '课程待开放'}}</view>
      </view>
    </view>

    <view class="field">
      <view class="label">大学</view>
      <picker range="{{universities}}" range-key="nameZh" bindchange="onUniversityChange">
        <view class="select">{{selectedUniversity.nameZh || '请选择大学'}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="label">Programme</view>
      <view class="programme-search">
        <input
          class="programme-input"
          value="{{ugKeyword}}"
          placeholder="搜索 Programme、代码、学院"
          confirm-type="search"
          bindinput="onUgKeyword"
        />
        <view wx:if="{{ugKeyword}}" class="programme-clear" bindtap="clearUgKeyword">×</view>
      </view>
      <picker range="{{filteredUgProgrammes}}" range-key="nameZh" bindchange="onProgrammeChange">
        <view class="select select-programme">
          <view class="select-programme-name">{{selectedProgramme.nameZh || '请选择 Programme'}}</view>
          <view class="select-programme-meta">{{filteredUgProgrammes.length}} 个匹配结果 · 当前 {{ugSelectedIndexLabel}}</view>
        </view>
      </picker>
    </view>

    <view wx:if="{{filteredUgProgrammes.length}}" class="programme-results">
      <view
        wx:for="{{visibleUgProgrammes}}"
        wx:key="id"
        class="programme-result {{selectedProgramme.id === item.id ? 'programme-result-active' : ''}}"
        data-id="{{item.id}}"
        bindtap="selectUgProgramme"
      >
        <view class="result-code">{{item.code || item.jupasCode || selectedUniversity.code}}</view>
        <view class="result-main">
          <view class="result-name">{{item.nameZh}}</view>
          <view class="result-meta">{{item.faculty || 'Faculty 待确认'}} · {{item.courseStatusLabel}}</view>
        </view>
      </view>
    </view>

    <view wx:else class="programme-empty">
      没有找到匹配 Programme。试试输入 Computer、Engineering、Business 或代码。
    </view>

    <view class="field">
      <view class="label">Major</view>
      <picker range="{{majors}}" range-key="nameZh" bindchange="onMajorChange">
        <view class="select">{{selectedMajor.nameZh || '请选择 Major'}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="label">Curriculum Year</view>
      <picker range="{{curriculumYears}}" bindchange="onCurriculumYearChange">
        <view class="select">{{curriculumYear}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="label">当前年级</view>
      <picker range="{{yearOptions}}" bindchange="onCurrentYearChange">
        <view class="select">Year {{currentYear}}</view>
      </picker>
    </view>

    <view class="ug-proof">
      <view class="proof-stamp">{{selectedUniversity.code || 'UG'}}</view>
      <view class="proof-main">
        <view class="proof-label">本科资料状态</view>
        <view class="proof-value">{{ugCourseStatus}}</view>
        <view class="proof-meta">{{selectedProgramme.nameEn || 'Programme 待选择'}} · {{selectedMajor.nameEn || 'Major 待选择'}}</view>
      </view>
    </view>

    <view class="button-space">
      <view class="button" bindtap="save">保存本科培养方案</view>
    </view>
  </view>

  <view wx:else class="section panel tpg-panel">
    <view class="scope-note tpg-note">选择学校与 Programme 后，已开放课程组的项目会显示课程结构；未开放的项目会保留资料来源。</view>

    <view wx:if="{{savedTpgProfile}}" class="saved-scope-card" bindtap="previewSavedTpgProgramme">
      <view class="saved-scope-mark">CURRENT</view>
      <view class="saved-scope-main">
        <view class="saved-scope-title">当前本机保存：{{savedTpgProfile.programme.name}}</view>
        <view class="saved-scope-copy">{{savedTpgProfile.schoolLabel}} · {{savedTpgProfile.yearLabel}} · {{savedTpgProfile.statusLabel}}</view>
      </view>
      <view class="saved-scope-arrow">›</view>
    </view>

    <view wx:if="{{selectedTpgCoverage}}" class="ug-coverage-card tpg-coverage-card">
      <view>
        <view class="coverage-kicker">当前学校数据</view>
        <view class="coverage-title">{{selectedTpgUniversity.shortName}}</view>
        <view class="coverage-copy">{{selectedTpgCoverage.programmeCount}} Programme · {{selectedTpgCoverage.programmeWithCoursesCount}} 个已开放课程组</view>
      </view>
      <view class="coverage-status {{selectedTpgCoverage.courseCount ? 'coverage-status-ready' : ''}}">
        <view class="coverage-badge">{{selectedTpgCoverage.badge}}</view>
        <view class="coverage-count">{{selectedTpgCoverage.courseCount ? selectedTpgCoverage.courseCount + ' courses' : '课程待开放'}}</view>
      </view>
    </view>

    <view class="field">
      <view class="label">大学</view>
      <picker range="{{tpgUniversities}}" range-key="shortName" bindchange="onTpgUniversityChange">
        <view class="select select-arrow">{{selectedTpgUniversity.shortName || '请选择大学'}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="label">Programme</view>
      <view class="programme-search">
        <input
          class="programme-input"
          value="{{tpgKeyword}}"
          placeholder="搜索 Programme 名称、代码或学院"
          confirm-type="search"
          bindinput="onTpgKeyword"
        />
        <view wx:if="{{tpgKeyword}}" class="programme-clear" bindtap="clearTpgKeyword">×</view>
      </view>
      <picker range="{{filteredTpgProgrammes}}" range-key="name" bindchange="onTpgProgrammeChange">
        <view class="select select-programme">
          <view class="select-programme-name">{{selectedTpgProgramme.name || '请选择 Programme'}}</view>
          <view class="select-programme-meta">{{filteredTpgProgrammes.length}} 个匹配结果 · 当前 {{tpgSelectedIndexLabel}}</view>
        </view>
      </picker>
    </view>

    <view wx:if="{{filteredTpgProgrammes.length}}" class="programme-results">
      <view
        wx:for="{{visibleTpgProgrammes}}"
        wx:key="id"
        class="programme-result {{selectedTpgProgramme.id === item.id ? 'programme-result-active' : ''}}"
        data-id="{{item.id}}"
        bindtap="selectTpgProgramme"
      >
        <view class="result-code">{{item.programmeCode || item.universityCode}}</view>
        <view class="result-main">
          <view class="result-name">{{item.name}}</view>
          <view class="result-meta">{{item.faculty || 'Faculty 待确认'}} · {{item.creditsRequired ? item.creditsRequired + ' credits / units' : '学分待确认'}} · {{item.courseStatusLabel}}</view>
        </view>
      </view>
    </view>

    <view wx:else class="programme-empty">
      没有找到匹配 Programme。试试输入 MSc、Finance、Computer 或学院关键词。
    </view>

    <view class="programme-proof">
      <view class="proof-stamp">{{selectedTpgUniversity.code}}</view>
      <view class="proof-main">
        <view class="proof-label">当前数据状态</view>
        <view class="proof-value">{{tpgCourseStatus}}</view>
        <view class="proof-meta">{{selectedTpgUniversity.academicYear}} · {{selectedTpgProgramme.creditsRequired ? selectedTpgProgramme.creditsRequired + ' credits / units' : '学分待确认'}}</view>
      </view>
    </view>

    <view class="tpg-explain">授课硕士通常以 Programme 或 Stream 区分方向，因此不再额外套用本科 Major。</view>

    <view class="button-space tpg-actions">
      <view class="preview-button" bindtap="previewTpgProgramme">预览 Programme</view>
      <view class="button" bindtap="save">保存授课硕士 Programme</view>
    </view>
  </view>
</view>
