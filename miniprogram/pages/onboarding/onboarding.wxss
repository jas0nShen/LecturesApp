.field {
  margin-bottom: 28rpx;
}

.label {
  color: #64716b;
  font-size: 24rpx;
  margin-bottom: 10rpx;
}

.select {
  align-items: center;
  background: #f8faf8;
  border: 1rpx solid #d7ded8;
  border-radius: 10rpx;
  box-sizing: border-box;
  display: flex;
  font-size: 28rpx;
  min-height: 84rpx;
  padding: 0 22rpx;
}

.button-space {
  margin-top: 34rpx;
}

.field { margin-bottom: 26rpx; }
.label {
  color: #52655c;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}
.select {
  background: #f5f8f6;
  border-color: #cedbd4;
  border-radius: 14rpx;
  min-height: 88rpx;
  padding: 0 24rpx;
}

.mode-switch {
  background: #dfe9e4;
  border-radius: 18rpx;
  display: flex;
  gap: 8rpx;
  padding: 8rpx;
}

.mode-option {
  align-items: center;
  border-radius: 13rpx;
  color: #66746d;
  display: flex;
  flex: 1;
  font-size: 26rpx;
  font-weight: 700;
  gap: 14rpx;
  justify-content: center;
  min-height: 78rpx;
}

.mode-option-active {
  background: #ffffff;
  box-shadow: 0 6rpx 18rpx rgba(33, 65, 53, 0.1);
  color: #113f34;
}

.mode-mark {
  border: 1rpx solid currentColor;
  font-size: 16rpx;
  letter-spacing: 2rpx;
  padding: 4rpx 7rpx;
}

.scope-note {
  background: #eef3f0;
  border-radius: 13rpx;
  color: #607068;
  font-size: 22rpx;
  line-height: 1.55;
  margin-bottom: 28rpx;
  padding: 20rpx 22rpx;
}

.ug-note {
  border: 1rpx dashed #c7d5ce;
}

.inline-link {
  color: #0b6b55;
  font-weight: 800;
  margin-top: 10rpx;
}

.tpg-note {
  background: #e4f0eb;
  color: #31594a;
}

.saved-scope-card {
  align-items: center;
  background: #fffaf0;
  border: 1rpx solid #e8d6ad;
  border-radius: 16rpx;
  display: flex;
  gap: 16rpx;
  margin: -10rpx 0 26rpx;
  padding: 20rpx;
}

.saved-scope-mark {
  border: 2rpx solid #9b7840;
  color: #795b2d;
  flex: none;
  font-size: 16rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
  padding: 8rpx 9rpx;
}

.saved-scope-main {
  flex: 1;
}

.saved-scope-title {
  color: #17352c;
  font-size: 23rpx;
  font-weight: 850;
  line-height: 1.35;
}

.saved-scope-copy {
  color: #786b50;
  font-size: 20rpx;
  line-height: 1.4;
  margin-top: 5rpx;
}

.saved-scope-arrow {
  color: #8a6a25;
  font-size: 36rpx;
}

.setup-guide {
  display: grid;
  gap: 10rpx;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin: -8rpx 0 26rpx;
}

.setup-guide-item {
  align-items: center;
  background: #f5f8f6;
  border: 1rpx solid #dce7e1;
  border-radius: 14rpx;
  color: #50645b;
  display: flex;
  flex-direction: column;
  font-size: 19rpx;
  font-weight: 750;
  justify-content: center;
  min-height: 112rpx;
  padding: 10rpx;
  text-align: center;
}

.guide-index {
  align-items: center;
  background: #0b6b55;
  border-radius: 50%;
  color: #ffffff;
  display: flex;
  font-size: 18rpx;
  font-weight: 850;
  height: 34rpx;
  justify-content: center;
  margin-bottom: 8rpx;
  width: 34rpx;
}

.select-programme {
  align-items: flex-start;
  line-height: 1.4;
  min-height: 110rpx;
  padding-bottom: 20rpx;
  padding-top: 20rpx;
  flex-direction: column;
  justify-content: center;
}

.select-programme-name {
  color: #172d25;
  font-size: 27rpx;
  font-weight: 750;
}

.select-programme-meta {
  color: #798880;
  font-size: 20rpx;
  margin-top: 8rpx;
}

.programme-search {
  margin-bottom: 14rpx;
  position: relative;
}

.programme-input {
  background: #ffffff;
  border: 1rpx solid #cfded6;
  border-radius: 14rpx;
  box-sizing: border-box;
  color: #172d25;
  font-size: 25rpx;
  min-height: 78rpx;
  padding: 0 72rpx 0 22rpx;
}

.programme-clear {
  align-items: center;
  background: #dfe8e4;
  border-radius: 50%;
  color: #60736a;
  display: flex;
  font-size: 28rpx;
  height: 36rpx;
  justify-content: center;
  position: absolute;
  right: 22rpx;
  top: 21rpx;
  width: 36rpx;
}

.programme-results {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin: -8rpx 0 24rpx;
}

.programme-result {
  align-items: flex-start;
  background: #f8fbf9;
  border: 1rpx solid #d8e4de;
  border-radius: 16rpx;
  display: flex;
  gap: 16rpx;
  padding: 18rpx;
}

.programme-result-active {
  background: #e4f0eb;
  border-color: #8fc7b1;
  box-shadow: 0 8rpx 20rpx rgba(11, 107, 85, 0.09);
}

.result-code {
  border: 1rpx solid #0b6b55;
  color: #0b6b55;
  font-size: 17rpx;
  font-weight: 850;
  letter-spacing: 1rpx;
  max-width: 110rpx;
  overflow: hidden;
  padding: 7rpx 8rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-main {
  flex: 1;
}

.result-name {
  color: #17352c;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.35;
}

.result-meta {
  color: #6f8178;
  font-size: 20rpx;
  line-height: 1.4;
  margin-top: 7rpx;
}

.programme-empty {
  background: #eef3f0;
  border: 1rpx dashed #b9d2c7;
  border-radius: 15rpx;
  color: #66786f;
  font-size: 22rpx;
  line-height: 1.5;
  margin: -8rpx 0 24rpx;
  padding: 22rpx;
}

.programme-proof {
  align-items: flex-start;
  background: #123f34;
  border-radius: 18rpx;
  color: #ffffff;
  display: flex;
  gap: 24rpx;
  margin-top: 10rpx;
  padding: 26rpx;
}

.proof-stamp {
  border: 2rpx solid #8fc7b1;
  color: #a8d4c3;
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  padding: 8rpx 9rpx;
  transform: rotate(-2deg);
}

.proof-main {
  flex: 1;
}

.proof-label {
  color: #9db9ae;
  font-size: 19rpx;
}

.proof-value {
  font-size: 27rpx;
  font-weight: 750;
  margin-top: 7rpx;
}

.proof-meta {
  color: #afc7bd;
  font-size: 20rpx;
  margin-top: 9rpx;
}

.tpg-explain {
  color: #708078;
  font-size: 21rpx;
  line-height: 1.55;
  margin-top: 20rpx;
}

.tpg-actions {
  display: grid;
  gap: 12rpx;
  grid-template-columns: 0.9fr 1.1fr;
}

.preview-button {
  align-items: center;
  background: #e4f0eb;
  border-radius: 14rpx;
  color: #0b6b55;
  display: flex;
  font-size: 26rpx;
  font-weight: 800;
  justify-content: center;
  min-height: 88rpx;
  text-align: center;
}
