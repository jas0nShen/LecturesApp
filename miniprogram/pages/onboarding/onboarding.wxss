.field {
  margin-bottom: 28rpx;
}

.label {
  color: #64716b;
  font-size: 24rpx;
  margin-bottom: 10rpx;
}

.select {
  align-items: center;
  background: #f8faf8;
  border: 1rpx solid #d7ded8;
  border-radius: 10rpx;
  box-sizing: border-box;
  display: flex;
  font-size: 28rpx;
  min-height: 84rpx;
  padding: 0 22rpx;
}

.button-space {
  margin-top: 34rpx;
}

.field { margin-bottom: 26rpx; }
.label {
  color: #52655c;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}
.select {
  background: #f5f8f6;
  border-color: #cedbd4;
  border-radius: 14rpx;
  min-height: 88rpx;
  padding: 0 24rpx;
}

.mode-switch {
  background: #dfe9e4;
  border-radius: 18rpx;
  display: flex;
  gap: 8rpx;
  padding: 8rpx;
}

.mode-option {
  align-items: center;
  border-radius: 13rpx;
  color: #66746d;
  display: flex;
  flex: 1;
  font-size: 26rpx;
  font-weight: 700;
  gap: 14rpx;
  justify-content: center;
  min-height: 78rpx;
}

.mode-option-active {
  background: #ffffff;
  box-shadow: 0 6rpx 18rpx rgba(33, 65, 53, 0.1);
  color: #113f34;
}

.mode-mark {
  border: 1rpx solid currentColor;
  font-size: 16rpx;
  letter-spacing: 2rpx;
  padding: 4rpx 7rpx;
}

.scope-note {
  background: #eef3f0;
  border-radius: 13rpx;
  color: #607068;
  font-size: 22rpx;
  line-height: 1.55;
  margin-bottom: 28rpx;
  padding: 20rpx 22rpx;
}

.ug-note {
  border: 1rpx dashed #c7d5ce;
}

.ug-coverage-card {
  align-items: center;
  background: #17352c;
  border-radius: 18rpx;
  box-shadow: 0 10rpx 24rpx rgba(8, 45, 35, 0.12);
  color: #ffffff;
  display: flex;
  gap: 18rpx;
  justify-content: space-between;
  margin: -8rpx 0 28rpx;
  padding: 24rpx;
}

.coverage-kicker {
  color: #9dc7b9;
  font-size: 17rpx;
  font-weight: 850;
  letter-spacing: 2rpx;
}

.coverage-title {
  font-size: 28rpx;
  font-weight: 850;
  margin-top: 7rpx;
}

.coverage-copy {
  color: #b8d0c7;
  font-size: 20rpx;
  margin-top: 7rpx;
}

.coverage-status {
  flex: none;
  text-align: right;
}

.coverage-badge {
  border: 1rpx solid #92c3b3;
  border-radius: 999rpx;
  color: #a9d4c7;
  display: inline-block;
  font-size: 16rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
  padding: 6rpx 13rpx;
}

.coverage-status-ready .coverage-badge {
  background: #dcebe5;
  border-color: #dcebe5;
  color: #0b6b55;
}

.coverage-count {
  color: #e2eee9;
  font-size: 19rpx;
  font-weight: 750;
  margin-top: 9rpx;
}

.tpg-coverage-card {
  background: #0b6b55;
}

.tpg-coverage-card .coverage-kicker,
.tpg-coverage-card .coverage-badge {
  color: #dcebe5;
}

.tpg-coverage-card .coverage-copy {
  color: #cce1d9;
}

.tpg-note {
  background: #e4f0eb;
  color: #31594a;
}

.saved-scope-card {
  align-items: center;
  background: #fffaf0;
  border: 1rpx solid #e8d6ad;
  border-radius: 16rpx;
  display: flex;
  gap: 16rpx;
  margin: -10rpx 0 26rpx;
  padding: 20rpx;
}

.ug-saved-scope-card {
  background: #eef6f2;
  border-color: #c7ddd2;
}

.ug-saved-scope-card .saved-scope-mark {
  border-color: #0b6b55;
  color: #0b6b55;
}

.ug-saved-scope-card .saved-scope-copy {
  color: #526b60;
}

.saved-scope-mark {
  border: 2rpx solid #9b7840;
  color: #795b2d;
  flex: none;
  font-size: 16rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
  padding: 8rpx 9rpx;
}

.saved-scope-main {
  flex: 1;
}

.saved-scope-title {
  color: #17352c;
  font-size: 23rpx;
  font-weight: 850;
  line-height: 1.35;
}

.saved-scope-copy {
  color: #786b50;
  font-size: 20rpx;
  line-height: 1.4;
  margin-top: 5rpx;
}

.saved-scope-arrow {
  color: #8a6a25;
  font-size: 36rpx;
}

.select-programme {
  align-items: flex-start;
  line-height: 1.4;
  min-height: 110rpx;
  padding-bottom: 20rpx;
  padding-top: 20rpx;
  flex-direction: column;
  justify-content: center;
}

.select-programme-name {
  color: #172d25;
  font-size: 27rpx;
  font-weight: 750;
}

.select-programme-meta {
  color: #798880;
  font-size: 20rpx;
  margin-top: 8rpx;
}

.programme-search {
  height: 78rpx;
  margin-bottom: 14rpx;
  overflow: hidden;
  position: relative;
  width: 100%;
}

.programme-input {
  background: #ffffff;
  border: 1rpx solid #cfded6;
  border-radius: 14rpx;
  box-sizing: border-box;
  color: #172d25;
  font-size: 25rpx;
  height: 78rpx;
  padding: 0 72rpx 0 22rpx;
  position: relative;
  width: 100%;
  z-index: 1;
}

.programme-clear {
  align-items: center;
  background: #dfe8e4;
  border-radius: 50%;
  color: #60736a;
  display: flex;
  font-size: 28rpx;
  height: 36rpx;
  justify-content: center;
  position: absolute;
  right: 22rpx;
  top: 21rpx;
  width: 36rpx;
  z-index: 2;
}

.programme-results {
  margin: -8rpx 0 24rpx;
}

.programme-results-head {
  align-items: center;
  color: #35564b;
  display: flex;
  font-size: 22rpx;
  font-weight: 800;
  justify-content: space-between;
  letter-spacing: 0.4rpx;
  padding: 0 4rpx 12rpx;
}

.programme-results-hint {
  color: #6f827a;
  font-size: 21rpx;
  font-weight: 650;
}

.programme-results-list {
  box-sizing: border-box;
  padding-right: 4rpx;
}

.programme-results-list-scrollable {
  height: 620rpx;
  overscroll-behavior: contain;
}

.programme-result {
  align-items: flex-start;
  background: #f8fbf9;
  border: 1rpx solid #d8e4de;
  border-radius: 16rpx;
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
  padding: 18rpx;
}

.programme-result-active {
  background: #e4f0eb;
  border-color: #8fc7b1;
  box-shadow: 0 8rpx 20rpx rgba(11, 107, 85, 0.09);
}

.result-code {
  border: 1rpx solid #0b6b55;
  color: #0b6b55;
  font-size: 17rpx;
  font-weight: 850;
  letter-spacing: 1rpx;
  max-width: 110rpx;
  overflow: hidden;
  padding: 7rpx 8rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-main {
  flex: 1;
}

.result-name {
  color: #17352c;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.35;
}

.result-meta {
  color: #6f8178;
  font-size: 20rpx;
  line-height: 1.4;
  margin-top: 7rpx;
}

.programme-empty {
  background: #eef3f0;
  border: 1rpx dashed #b9d2c7;
  border-radius: 15rpx;
  color: #66786f;
  font-size: 22rpx;
  line-height: 1.5;
  margin: -8rpx 0 24rpx;
  padding: 22rpx;
}

.programme-empty-action {
  color: #0b6b55;
  font-size: 22rpx;
  font-weight: 850;
  margin-top: 14rpx;
}

.programme-empty-copy {
  color: #7c8f86;
  font-size: 21rpx;
  margin-top: 6rpx;
}

.programme-proof,
.ug-proof {
  align-items: flex-start;
  background: #123f34;
  border-radius: 18rpx;
  color: #ffffff;
  display: flex;
  gap: 24rpx;
  margin-top: 10rpx;
  padding: 26rpx;
}

.ug-proof {
  background: #f8f3e7;
  border: 1rpx solid #e8d6ad;
  color: #17352c;
}

.ug-proof .proof-stamp {
  border-color: #9b7840;
  color: #795b2d;
}

.ug-proof .proof-label {
  color: #8a714f;
}

.ug-proof .proof-meta {
  color: #786b50;
}

.proof-stamp {
  border: 2rpx solid #8fc7b1;
  color: #a8d4c3;
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  padding: 8rpx 9rpx;
  transform: rotate(-2deg);
}

.proof-main {
  flex: 1;
}

.proof-label {
  color: #9db9ae;
  font-size: 19rpx;
}

.proof-value {
  font-size: 27rpx;
  font-weight: 750;
  margin-top: 7rpx;
}

.proof-meta {
  color: #afc7bd;
  font-size: 20rpx;
  margin-top: 9rpx;
}

.tpg-explain {
  color: #708078;
  font-size: 21rpx;
  line-height: 1.55;
  margin-top: 20rpx;
}

.tpg-actions {
  display: grid;
  gap: 12rpx;
  grid-template-columns: 0.9fr 1.1fr;
}

.preview-button {
  align-items: center;
  background: #e4f0eb;
  border-radius: 14rpx;
  color: #0b6b55;
  display: flex;
  font-size: 26rpx;
  font-weight: 800;
  justify-content: center;
  min-height: 88rpx;
  text-align: center;
}

.select-arrow {
  justify-content: space-between;
}

.select-arrow::after {
  color: #819089;
  content: '›';
  font-size: 34rpx;
  transform: rotate(90deg);
}

.sheet-mask {
  align-items: flex-end;
  background: rgba(0, 0, 0, 0.45);
  bottom: 0;
  display: flex;
  left: 0;
  position: fixed;
  right: 0;
  top: 0;
  z-index: 20;
}

.sheet {
  background: #ffffff;
  border-radius: 28rpx 28rpx 0 0;
  box-shadow: 0 -14rpx 34rpx rgba(8, 45, 35, 0.15);
  box-sizing: border-box;
  max-height: 70vh;
  padding-bottom: env(safe-area-inset-bottom);
  width: 100%;
}

.sheet-head {
  align-items: center;
  border-bottom: 1rpx solid #edf1ef;
  display: flex;
  min-height: 96rpx;
  padding: 0 28rpx;
}

.sheet-cancel,
.sheet-placeholder {
  color: #64746d;
  flex: 1;
  font-size: 28rpx;
}

.sheet-title {
  color: #172d25;
  flex: 1;
  font-size: 29rpx;
  font-weight: 850;
  text-align: center;
}

.sheet-placeholder {
  visibility: hidden;
}

.sheet-list {
  height: 560rpx;
  max-height: 560rpx;
}

.sheet-list-tall {
  height: 680rpx;
  max-height: 680rpx;
}

.sheet-option {
  align-items: center;
  border-bottom: 1rpx solid #f0f3f1;
  box-sizing: border-box;
  color: #253b33;
  display: flex;
  font-size: 29rpx;
  min-height: 92rpx;
  padding: 0 34rpx;
}

.sheet-option-multiline {
  align-items: flex-start;
  line-height: 1.35;
  min-height: 98rpx;
  padding-bottom: 24rpx;
  padding-top: 24rpx;
}

.sheet-option-active {
  background: #eef7f3;
  color: #0b6b55;
  font-weight: 850;
}
