.notes-head {
  background: #0b5d4b;
  border-radius: 22rpx;
  box-shadow: 0 14rpx 32rpx rgba(11, 72, 57, 0.15);
  padding: 34rpx;
}

.notes-head .title {
  color: #ffffff;
  margin-top: 12rpx;
}

.notes-head .subtitle {
  color: #c6ddd5;
}

.notes-kicker,
.notes-count {
  color: #9fd1c2;
  font-size: 19rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.notes-count {
  border-top: 1rpx solid #3b7a69;
  margin-top: 24rpx;
  padding-top: 20rpx;
}

.note-record {
  background: #fbfcfa;
  border: 1rpx solid #dce6e0;
  border-radius: 18rpx;
  display: grid;
  grid-template-columns: 180rpx minmax(0, 1fr);
  overflow: hidden;
}

.record-index {
  background: #e5f0eb;
  border-right: 1rpx solid #c8dbd2;
  padding: 27rpx 22rpx;
}

.record-code {
  color: #0b6b55;
  font-size: 26rpx;
  font-weight: 850;
  word-break: break-all;
}

.record-term {
  color: #71857c;
  font-size: 17rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  line-height: 1.4;
  margin-top: 10rpx;
}

.record-body {
  padding: 26rpx;
}

.record-title {
  color: #17352c;
  font-size: 27rpx;
  font-weight: 780;
  line-height: 1.35;
}

.record-note {
  color: #40534a;
  font-size: 25rpx;
  line-height: 1.65;
  margin-top: 18rpx;
  white-space: pre-wrap;
  word-break: break-word;
}

.record-actions {
  border-top: 1rpx solid #e4ebe7;
  display: flex;
  gap: 30rpx;
  margin-top: 22rpx;
  padding-top: 18rpx;
}

.record-open,
.record-delete {
  color: #0b6b55;
  font-size: 22rpx;
  font-weight: 700;
}

.record-delete {
  color: #9a5149;
}

.empty-card {
  background: #fbfcfa;
  border: 1rpx solid #dce6e0;
  border-radius: 20rpx;
  padding: 56rpx 36rpx 36rpx;
  text-align: center;
}

.empty-mark {
  color: #0b6b55;
  font-size: 56rpx;
}

.empty-title {
  color: #17352c;
  font-size: 31rpx;
  font-weight: 800;
  margin-top: 18rpx;
}

.empty-copy {
  color: #6d7c75;
  font-size: 24rpx;
  line-height: 1.6;
  margin: 12rpx auto 0;
  max-width: 520rpx;
}

.empty-action {
  margin-top: 30rpx;
}
