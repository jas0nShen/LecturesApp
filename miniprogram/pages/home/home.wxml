<view class="page">
  <view class="section hero">
    <view>
      <view class="title">香港大学生课程选择助手</view>
      <view class="subtitle">先从专业课程、已修课程和毕业要求检查开始，帮你快速看清下一步。</view>
    </view>
  </view>

  <view wx:if="{{!profile}}" class="section panel">
    <view class="panel-title">先设置你的专业</view>
    <view class="subtitle">MVP 当前内置 HKU BEng Computer Science 示例数据。</view>
    <view class="button-space">
      <view class="button" bindtap="goOnboarding">开始选择</view>
    </view>
  </view>

  <view wx:else class="section panel">
    <view class="row">
      <view>
        <view class="panel-title">{{profile.universityCode}} · {{profile.majorCode}}</view>
        <view class="subtitle">{{profile.programmeName}} · Year {{profile.currentYear}}</view>
      </view>
      <view class="edit-link" bindtap="goOnboarding">修改</view>
    </view>
  </view>

  <view class="section grid">
    <view class="action-card" bindtap="goCourses">
      <view class="action-title">查课程</view>
      <view class="action-copy">Core、Elective、Common Core</view>
    </view>
    <view class="action-card" bindtap="goAudit">
      <view class="action-title">毕业检查</view>
      <view class="action-copy">看看还差哪些要求</view>
    </view>
    <view class="action-card" bindtap="goFavorites">
      <view class="action-title">收藏课程</view>
      <view class="action-copy">保存想修的课程</view>
    </view>
    <view class="action-card" bindtap="goProfile">
      <view class="action-title">我的资料</view>
      <view class="action-copy">学校、专业、年级</view>
    </view>
  </view>

  <view class="section panel">
    <view class="panel-title">毕业进度预览</view>
    <view class="progress-wrap">
      <view class="progress-bar" style="width: {{audit.totalProgress}}%;"></view>
    </view>
    <view class="subtitle">已记录 {{audit.completedCredits}} / {{audit.totalCreditRequired}} credits</view>
    <view class="source-line">数据源：{{dataSource === 'api' ? '本地 API' : '本地缓存'}}</view>
  </view>
</view>
