<view class="page">
  <view class="section hero">
    <view>
      <view class="hero-kicker">COURSE DESK · {{profile.universityCode || '6 SCHOOLS TPG'}}</view>
      <view class="title">先找到你的 Programme。</view>
      <view class="subtitle">首发支持六校授课硕士 Programme 索引；已开放课程组的项目会显示课程结构。</view>
    </view>
  </view>

  <view wx:if="{{!profile}}" class="section tpg-start-card">
    <view class="start-kicker">FIRST SETUP</view>
    <view class="panel-title">选择你的授课硕士 Programme</view>
    <view class="subtitle">从港大、中大、科大、理大、城大、浸会的授课硕士资料开始；保存 Programme 后即可查看课程状态。</view>
    <view class="start-stats">
      <view>
        <view class="start-number">{{tpgCoverage.schoolCount}}</view>
        <view class="start-label">所大学</view>
      </view>
      <view>
        <view class="start-number">{{tpgCoverage.programmeCount}}</view>
        <view class="start-label">个 Programme</view>
      </view>
      <view>
        <view class="start-number">{{tpgCoverage.courseCount}}</view>
        <view class="start-label">门已拆课程</view>
      </view>
    </view>
    <view class="button-space start-actions">
      <view class="button" bindtap="goOnboarding">开始选择</view>
      <view class="secondary-button" bindtap="goTpgCatalog">先浏览资料库</view>
    </view>
  </view>

  <view wx:else class="section panel">
    <view class="row">
      <view>
        <view class="panel-title">{{profile.universityCode}} · {{isTpg ? 'TPG' : profile.majorCode}}</view>
        <view class="subtitle">{{profile.programmeName}}{{isTpg ? '' : ' · Year ' + profile.currentYear}}</view>
      </view>
      <view class="edit-link" bindtap="goOnboarding">修改</view>
    </view>
  </view>

  <view wx:if="{{!isTpg}}" class="section grid">
    <view class="action-card" bindtap="goCourses">
      <view class="action-index">01</view>
      <view class="action-title">查课程</view>
      <view class="action-copy">Core、Elective、Common Core</view>
    </view>
    <view class="action-card" bindtap="goAudit">
      <view class="action-index">02</view>
      <view class="action-title">毕业检查</view>
      <view class="action-copy">看看还差哪些要求</view>
    </view>
    <view class="action-card" bindtap="goFavorites">
      <view class="action-index">03</view>
      <view class="action-title">收藏课程</view>
      <view class="action-copy">保存想修的课程</view>
    </view>
    <view class="action-card" bindtap="goProfile">
      <view class="action-index">04</view>
      <view class="action-title">我的资料</view>
      <view class="action-copy">学校、专业、年级</view>
    </view>
    <view class="action-card plan-card" bindtap="goStudyPlan">
      <view class="action-index">PLAN · 4 YEARS</view>
      <view class="action-title">我的 Study Plan</view>
      <view class="action-copy">按学年和学期安排想修的课程</view>
    </view>
  </view>

  <view wx:if="{{isTpg}}" class="section tpg-entry selected-tpg" bindtap="goSelectedTpg">
    <view class="tpg-entry-mark">MY PROGRAMME · {{profile.curriculumYear}}</view>
    <view class="tpg-entry-title">查看课程结构</view>
    <view class="tpg-entry-copy">{{tpgProfile.statusLabel}}</view>
    <view class="tpg-entry-arrow">›</view>
  </view>

  <view wx:if="{{isTpg}}" class="section tpg-next-card">
    <view class="row">
      <view>
        <view class="start-kicker">MVP STATUS</view>
        <view class="panel-title">你的 Programme 现在可以这样用</view>
      </view>
      <view class="tpg-credits-pill">{{tpgProfile.creditsLabel}}</view>
    </view>
    <view class="tpg-step-list">
      <view wx:for="{{tpgNextSteps}}" wx:key="title" class="tpg-step">
        <view class="tpg-step-status {{item.status === 'READY' || item.status === 'DONE' ? 'tpg-step-status-ready' : ''}}">{{item.status}}</view>
        <view>
          <view class="tpg-step-title">{{item.title}}</view>
          <view class="tpg-step-copy">{{item.copy}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section tpg-entry" bindtap="goTpgCatalog">
    <view class="tpg-entry-mark">6 SCHOOLS · TPG</view>
    <view class="tpg-entry-title">授课硕士资料库</view>
    <view class="tpg-entry-copy">浏览六校 Programme，查看课程清单开放状态</view>
    <view class="tpg-entry-arrow">›</view>
  </view>

  <view wx:if="{{recentCourses.length}}" class="section recent-section">
    <view class="recent-heading">
      <view class="panel-title">最近查看</view>
      <view class="recent-caption">继续上次的课程</view>
    </view>
    <view wx:for="{{recentCourses}}" wx:key="courseCode" class="recent-course" data-code="{{item.courseCode}}" bindtap="goRecentCourse">
      <view>
        <view class="recent-code">{{item.courseCode}}</view>
        <view class="recent-title">{{item.title}}</view>
      </view>
      <view class="recent-term">Sem {{item.termLabel}} ›</view>
    </view>
  </view>

  <view wx:if="{{!isTpg}}" class="section panel">
    <view class="progress-heading">
      <view class="panel-title">毕业进度预览</view>
      <view class="progress-number">{{audit.totalProgress}}%</view>
    </view>
    <view class="progress-wrap">
      <view class="progress-bar" style="width: {{audit.totalProgress}}%;"></view>
    </view>
    <view class="subtitle">已记录 {{audit.completedCredits}} / {{audit.totalCreditRequired}} credits</view>
    <view class="source-line">数据源：{{dataSource === 'api' ? '开发环境服务' : '离线数据'}}</view>
  </view>
</view>
