.hero {
  background: #0b5d4b;
  border-radius: 26rpx;
  box-shadow: 0 18rpx 38rpx rgba(11, 72, 57, 0.18);
  margin-bottom: 28rpx;
  overflow: hidden;
  padding: 42rpx 34rpx 40rpx;
  position: relative;
}

.hero::after {
  border: 2rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 50%;
  content: "";
  height: 220rpx;
  position: absolute;
  right: -80rpx;
  top: -92rpx;
  width: 220rpx;
}

.hero-kicker {
  color: #9fd1c2;
  font-size: 20rpx;
  font-weight: 750;
  letter-spacing: 3rpx;
  margin-bottom: 18rpx;
}

.hero .title {
  color: #ffffff;
  font-size: 46rpx;
  max-width: 560rpx;
}

.hero .subtitle {
  color: #c8ded6;
  max-width: 570rpx;
}

.panel-title {
  color: #17352c;
  font-size: 30rpx;
  font-weight: 800;
}

.button-space {
  margin-top: 24rpx;
}

.tpg-start-card {
  background: #fbfcfa;
  border: 1rpx solid #dce6e0;
  border-radius: 22rpx;
  box-shadow: 0 10rpx 26rpx rgba(15, 64, 51, 0.06);
  padding: 30rpx;
}

.start-kicker {
  color: #0b6b55;
  font-size: 18rpx;
  font-weight: 850;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.start-stats {
  background: #e8f1ed;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-top: 24rpx;
  padding: 20rpx;
}

.start-stats > view + view {
  border-left: 1rpx solid #c7d9d1;
  padding-left: 16rpx;
}

.start-number {
  color: #0b6b55;
  font-size: 36rpx;
  font-weight: 900;
}

.start-label {
  color: #718079;
  font-size: 20rpx;
  margin-top: 2rpx;
}

.start-actions {
  display: grid;
  gap: 12rpx;
  grid-template-columns: 1.2fr 1fr;
}

.secondary-button {
  align-items: center;
  background: #e4f0eb;
  border-radius: 14rpx;
  color: #0b6b55;
  display: flex;
  font-size: 26rpx;
  font-weight: 800;
  justify-content: center;
  min-height: 88rpx;
}

.launch-guide-card {
  background: #ffffff;
  border: 1rpx solid #dce6e0;
  border-radius: 22rpx;
  box-shadow: 0 10rpx 26rpx rgba(15, 64, 51, 0.055);
  padding: 30rpx;
}

.guide-badge {
  background: #17352c;
  border-radius: 999rpx;
  color: #d6ebe4;
  font-size: 20rpx;
  font-weight: 850;
  padding: 10rpx 16rpx;
}

.guide-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 22rpx;
}

.guide-row {
  align-items: flex-start;
  background: #f5f8f6;
  border: 1rpx solid #e3ebe7;
  border-radius: 16rpx;
  display: grid;
  gap: 16rpx;
  grid-template-columns: 58rpx 1fr;
  padding: 18rpx;
}

.guide-mark {
  align-items: center;
  background: #e0eee8;
  border-radius: 50%;
  color: #0b6b55;
  display: flex;
  font-size: 18rpx;
  font-weight: 900;
  height: 50rpx;
  justify-content: center;
  width: 50rpx;
}

.guide-title {
  color: #17352c;
  font-size: 24rpx;
  font-weight: 850;
}

.guide-copy {
  color: #68776f;
  font-size: 21rpx;
  line-height: 1.45;
  margin-top: 5rpx;
}

.guide-actions {
  display: grid;
  gap: 12rpx;
  grid-template-columns: 1fr 1fr;
  margin-top: 20rpx;
}

.guide-primary,
.guide-secondary {
  align-items: center;
  border-radius: 14rpx;
  display: flex;
  font-size: 24rpx;
  font-weight: 850;
  height: 78rpx;
  justify-content: center;
}

.guide-primary {
  background: #0b6b55;
  color: #ffffff;
}

.guide-secondary {
  background: #e7f0ec;
  color: #0b6b55;
}

.edit-link {
  background: #e3efe9;
  border-radius: 999rpx;
  color: #0b6b55;
  font-size: 26rpx;
  font-weight: 700;
  padding: 10rpx 18rpx;
}

.grid {
  display: grid;
  gap: 16rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.action-card {
  background: #fbfcfa;
  border: 1rpx solid #dbe5df;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 22rpx rgba(15, 64, 51, 0.045);
  min-height: 184rpx;
  padding: 25rpx;
  position: relative;
}

.action-card:active {
  background: #f2f7f4;
  transform: scale(0.985);
}

.action-index {
  color: #93a89f;
  font-size: 19rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  margin-bottom: 22rpx;
}

.action-title {
  color: #17352c;
  font-size: 29rpx;
  font-weight: 800;
}

.action-copy {
  color: #708078;
  font-size: 22rpx;
  line-height: 1.4;
  margin-top: 12rpx;
}

.plan-card {
  background: #e3efe9;
  border-color: #bdd7cb;
  grid-column: 1 / -1;
  min-height: 142rpx;
}

.plan-card .action-index {
  color: #0b6b55;
  margin-bottom: 12rpx;
}

.tpg-entry {
  background: #eaf5f0;
  border: 1rpx solid #b9d7cc;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(24, 75, 61, 0.06);
  overflow: hidden;
  padding: 28rpx 32rpx;
  position: relative;
}

.tpg-entry::after {
  border: 1rpx solid rgba(11, 93, 75, 0.16);
  border-radius: 50%;
  bottom: -44rpx;
  content: "";
  height: 150rpx;
  position: absolute;
  right: -36rpx;
  width: 150rpx;
}

.tpg-entry-mark {
  color: #0b6b55;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
}

.tpg-entry-title {
  color: #17372f;
  font-size: 32rpx;
  font-weight: 700;
  margin-top: 8rpx;
}

.tpg-entry-copy {
  color: #64756e;
  font-size: 23rpx;
  line-height: 1.5;
  margin-top: 8rpx;
  padding-right: 56rpx;
}

.tpg-entry-arrow {
  color: #0b6b55;
  font-size: 44rpx;
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
}

.tpg-next-card {
  background: #fbfcfa;
  border: 1rpx solid #dbe5df;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 22rpx rgba(15, 64, 51, 0.045);
  padding: 28rpx;
}

.tpg-credits-pill {
  background: #e4f0eb;
  border-radius: 999rpx;
  color: #0b6b55;
  font-size: 20rpx;
  font-weight: 800;
  max-width: 210rpx;
  padding: 10rpx 15rpx;
  text-align: right;
}

.tpg-step-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 22rpx;
}

.tpg-step {
  background: #f3f7f5;
  border: 1rpx solid #e0e8e4;
  border-radius: 16rpx;
  display: grid;
  gap: 16rpx;
  grid-template-columns: 108rpx 1fr;
  padding: 18rpx;
}

.tpg-step-status {
  align-self: flex-start;
  background: #e6ece8;
  border-radius: 999rpx;
  color: #68776f;
  font-size: 17rpx;
  font-weight: 850;
  letter-spacing: 1rpx;
  padding: 7rpx 0;
  text-align: center;
}

.tpg-step-status-ready {
  background: #0b6b55;
  color: #ffffff;
}

.tpg-step-title {
  color: #17352c;
  font-size: 25rpx;
  font-weight: 800;
}

.tpg-step-copy {
  color: #68776f;
  font-size: 21rpx;
  line-height: 1.45;
  margin-top: 6rpx;
}

.recent-section {
  background: #fbfcfa;
  border: 1rpx solid #dbe5df;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 22rpx rgba(15, 64, 51, 0.045);
  padding: 28rpx;
}
.recent-heading { align-items: baseline; display: flex; justify-content: space-between; margin-bottom: 8rpx; }
.recent-caption { color: #8a9891; font-size: 20rpx; }
.recent-course { align-items: center; border-top: 1rpx solid #e6ece8; display: flex; justify-content: space-between; padding: 20rpx 0; }
.recent-course:first-of-type { border-top: 0; }
.recent-code { color: #0b6b55; font-size: 22rpx; font-weight: 850; }
.recent-title { font-size: 24rpx; font-weight: 700; line-height: 1.35; margin-top: 5rpx; max-width: 390rpx; }
.recent-term { color: #718079; font-size: 20rpx; margin-left: 16rpx; white-space: nowrap; }

.progress-wrap {
  background: #e1e9e5;
  border-radius: 999rpx;
  height: 14rpx;
  margin-top: 22rpx;
  overflow: hidden;
}

.progress-bar {
  background: #0b6b55;
  height: 100%;
}

.progress-heading {
  align-items: baseline;
  display: flex;
  justify-content: space-between;
}

.progress-number {
  color: #0b6b55;
  font-size: 32rpx;
  font-weight: 850;
}

.source-line {
  color: #87928d;
  font-size: 22rpx;
  margin-top: 10rpx;
}
