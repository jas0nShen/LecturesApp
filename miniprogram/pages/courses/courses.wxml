<view class="page">
  <view class="catalog-switch">
    <view class="catalog-option {{viewMode === 'curriculum' ? 'active' : ''}}" data-value="curriculum" bindtap="onModeTap">
      <view class="catalog-label">培养方案</view>
      <view class="catalog-copy">用于毕业检查</view>
    </view>
    <view class="catalog-option {{viewMode === 'offerings' ? 'active' : ''}}" data-value="offerings" bindtap="onModeTap">
      <view class="catalog-label">官方开课</view>
      <view class="catalog-copy">HKU · 2025–26</view>
    </view>
  </view>

  <view class="section">
    <view class="search-field">
      <input class="input" value="{{keyword}}" placeholder="搜索 Course Code 或课程名" confirm-type="search" bindinput="onKeyword" bindconfirm="onSearchConfirm" />
      <view wx:if="{{keyword}}" class="keyword-clear" bindtap="clearKeyword">×</view>
    </view>
    <view wx:if="{{!keyword}}" class="search-aids">
      <view wx:if="{{searchHistory.length}}" class="aid-group">
        <view class="aid-heading">
          <view>最近搜索</view>
          <view class="aid-clear" bindtap="clearSearchHistory">清除</view>
        </view>
        <view class="aid-chips">
          <view wx:for="{{searchHistory}}" wx:key="*this" class="aid-chip history" data-keyword="{{item}}" bindtap="applySearch">{{item}}</view>
        </view>
      </view>
      <view class="aid-group">
        <view class="aid-heading">快捷查找</view>
        <view class="aid-chips">
          <view wx:for="{{quickSearches}}" wx:key="*this" class="aid-chip" data-keyword="{{item}}" bindtap="applySearch">{{item}}</view>
        </view>
      </view>
    </view>
    <view class="source-line {{searching ? 'searching' : ''}}">
      <block wx:if="{{searching}}">正在搜索…</block>
      <block wx:else>数据源：{{dataSource === 'api' ? '本地 API' : '本地缓存'}}</block>
    </view>
  </view>

  <block wx:if="{{viewMode === 'curriculum'}}">
  <scroll-view class="tabs" scroll-x>
    <view wx:for="{{types}}" wx:key="value" class="tab {{courseType === item.value ? 'active' : ''}}" data-value="{{item.value}}" bindtap="onTypeTap">{{item.label}}</view>
  </scroll-view>

  <view class="section filter-row">
    <view class="filter-chip {{hasPrerequisite === null ? 'active' : ''}}" data-value="all" bindtap="onPrereqTap">全部</view>
    <view class="filter-chip {{hasPrerequisite === false ? 'active' : ''}}" data-value="no" bindtap="onPrereqTap">无先修</view>
    <view class="filter-chip {{hasPrerequisite === true ? 'active' : ''}}" data-value="yes" bindtap="onPrereqTap">有先修</view>
  </view>

  <view class="section">
    <view wx:for="{{courses}}" wx:key="id" class="course-card" data-id="{{item.id}}" bindtap="goDetail">
      <view class="row">
        <view class="code">{{item.courseCode}}</view>
        <view class="card-status">
          <view wx:if="{{item.favorite}}" class="favorite-mark"><text class="favorite-star">★</text> 已收藏</view>
          <view wx:if="{{item.completed}}" class="completed-mark">✓ 已修</view>
          <view class="credits">{{item.credits}} credits</view>
        </view>
      </view>
      <view class="course-title">{{item.titleEn}}</view>
      <view class="subtitle">{{item.titleZh}} · {{item.semester}}</view>
      <view class="meta">
        <text class="tag">{{typeLabels[item.courseType]}}</text>
        <text class="tag">Year {{item.recommendedYear}}</text>
      </view>
    </view>
    <view wx:if="{{courses.length === 0}}" class="empty">
      <view class="empty-mark">NO MATCH</view>
      <view class="empty-title">没有找到匹配课程</view>
      <view class="empty-copy">试试只输入课程代码前缀，或清除当前筛选条件。</view>
      <view class="empty-actions">
        <view class="empty-action" bindtap="clearKeyword">清除关键词</view>
        <view class="empty-action primary" bindtap="resetFilters">重置全部筛选</view>
      </view>
    </view>
  </view>
  </block>

  <block wx:else>
    <scroll-view class="tabs offering-tabs" scroll-x>
      <view wx:for="{{offeringTerms}}" wx:key="value" class="tab {{offeringTerm === item.value ? 'active' : ''}}" data-value="{{item.value}}" bindtap="onOfferingTermTap">{{item.label}}</view>
    </scroll-view>

    <view class="offering-filter-bar">
      <picker range="{{offeringCategories}}" range-key="label" value="{{offeringCategoryIndex}}" bindchange="onOfferingCategoryChange">
        <view class="filter-select">{{offeringCategories[offeringCategoryIndex].label}} <text class="filter-arrow">⌄</text></view>
      </picker>
      <picker range="{{offeringYears}}" range-key="label" value="{{offeringYearIndex}}" bindchange="onOfferingYearChange">
        <view class="filter-select">{{offeringYears[offeringYearIndex].label}} <text class="filter-arrow">⌄</text></view>
      </picker>
    </view>

    <view class="section source-stamp">
      <view class="stamp-mark">HKU OFFICIAL</view>
      <view>
        <view class="stamp-title">{{offeringMeta.provider}}</view>
        <view class="stamp-copy">{{offerings.length}} 门匹配课程 · 点击查看开课详情</view>
      </view>
    </view>

    <view class="section">
      <view wx:for="{{offerings}}" wx:key="courseCode" class="course-card offering-card" data-code="{{item.courseCode}}" bindtap="goOfferingDetail">
        <view class="row">
          <view class="code">{{item.courseCode}}</view>
          <view class="card-status">
            <view wx:if="{{item.favorite}}" class="favorite-mark"><text class="favorite-star">★</text> 已收藏</view>
            <view wx:if="{{item.completed}}" class="completed-mark">✓ 已修</view>
            <view wx:if="{{item.planned}}" class="planned-mark">◆ 已计划</view>
            <view class="term-badge">Sem {{item.termLabel}}</view>
          </view>
        </view>
        <view class="course-title">{{item.title}}</view>
        <view class="offering-footer">
          <text>{{item.categoryLabel}}</text>
          <text>{{item.sectionCount}} 个班次</text>
        </view>
      </view>
      <view wx:if="{{offerings.length === 0}}" class="empty">
        <view class="empty-mark">NO OFFERING</view>
        <view class="empty-title">没有匹配的官方开课</view>
        <view class="empty-copy">课程可能在另一学期开设，也可以尝试只搜索 Course Code。</view>
        <view class="empty-actions">
          <view class="empty-action" bindtap="clearKeyword">清除关键词</view>
          <view class="empty-action primary" bindtap="resetFilters">重置全部筛选</view>
        </view>
      </view>
    </view>
  </block>
</view>
