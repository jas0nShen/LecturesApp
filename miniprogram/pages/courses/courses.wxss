.tabs {
  margin-bottom: 22rpx;
  white-space: nowrap;
  width: 100%;
}

.source-line {
  color: #87928d;
  font-size: 22rpx;
  margin-top: 10rpx;
}

.tab {
  background: #fbfcfa;
  border: 1rpx solid #d5e0da;
  border-radius: 999rpx;
  color: #53615a;
  display: inline-flex;
  font-size: 24rpx;
  margin-right: 14rpx;
  padding: 16rpx 22rpx;
}

.tab.active {
  background: #0b6b55;
  border-color: #0b6b55;
  box-shadow: 0 6rpx 16rpx rgba(11, 107, 85, 0.14);
  color: #ffffff;
}

.filter-row {
  display: flex;
  gap: 14rpx;
}

.filter-chip {
  background: #ffffff;
  border: 1rpx solid #dfe5df;
  border-radius: 10rpx;
  color: #53615a;
  font-size: 24rpx;
  padding: 14rpx 18rpx;
}

.filter-chip.active {
  background: #e7f0ec;
  border-color: #b8d5c9;
  color: #1f6f5b;
}

.course-card {
  background: #fbfcfa;
  border: 1rpx solid #dae5df;
  border-radius: 18rpx;
  box-shadow: 0 7rpx 20rpx rgba(15, 64, 51, 0.045);
  margin-bottom: 16rpx;
  padding: 26rpx;
  position: relative;
}

.course-card:active {
  background: #f4f8f6;
  transform: scale(0.992);
}

.code {
  color: #0b6b55;
  font-size: 28rpx;
  font-weight: 800;
}

.credits {
  color: #64716b;
  font-size: 24rpx;
}

.card-status {
  align-items: flex-end;
  display: flex;
  flex-direction: column;
  gap: 7rpx;
}

.favorite-mark {
  color: #a06a13;
  font-size: 20rpx;
  font-weight: 700;
}

.favorite-star {
  font-size: 22rpx;
}

.completed-mark {
  color: #1f6f5b;
  font-size: 20rpx;
  font-weight: 700;
}

.planned-mark {
  color: #3f5d75;
  font-size: 20rpx;
  font-weight: 700;
}

.course-title {
  color: #132a22;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
  margin-top: 12rpx;
}

.meta {
  margin-top: 18rpx;
}

.empty {
  color: #64716b;
  font-size: 28rpx;
  padding: 80rpx 0;
  text-align: center;
}
.catalog-switch {
  background: #dfeae5;
  display: grid;
  gap: 8rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin: 24rpx 28rpx 8rpx;
  padding: 8rpx;
  border-radius: 20rpx;
}

.catalog-option {
  border-radius: 16rpx;
  color: #64716b;
  padding: 18rpx 20rpx;
}

.catalog-option.active {
  background: #fbfcfa;
  box-shadow: 0 4rpx 16rpx rgba(31, 111, 91, 0.1);
  color: #173d33;
}

.catalog-label {
  font-size: 28rpx;
  font-weight: 750;
}

.catalog-copy {
  font-size: 21rpx;
  margin-top: 4rpx;
}

.offering-tabs {
  border-top: 1rpx solid #edf0ed;
}

.offering-filter-bar {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin: -4rpx 0 20rpx;
}

.filter-select {
  align-items: center;
  background: #fbfcfa;
  border: 1rpx solid #d5e0da;
  border-radius: 13rpx;
  color: #40534a;
  display: flex;
  font-size: 23rpx;
  justify-content: space-between;
  min-height: 72rpx;
  padding: 0 20rpx;
}

.filter-arrow {
  color: #829088;
  font-size: 24rpx;
}

.source-stamp {
  align-items: center;
  background: #e4f0eb;
  border: 1rpx solid #bcd7cb;
  border-radius: 14rpx;
  display: flex;
  gap: 20rpx;
}

.stamp-mark {
  border: 2rpx solid #0b6b55;
  color: #0b6b55;
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  padding: 10rpx;
  transform: rotate(-2deg);
}

.stamp-title {
  color: #173d33;
  font-size: 24rpx;
  font-weight: 700;
}

.stamp-copy {
  color: #64716b;
  font-size: 21rpx;
  margin-top: 5rpx;
}

.term-badge {
  color: #1f6f5b;
  font-size: 22rpx;
  font-weight: 650;
}

.offering-footer {
  color: #75817b;
  display: flex;
  font-size: 21rpx;
  justify-content: space-between;
  margin-top: 18rpx;
}

.catalog-switch { margin: 4rpx 0 22rpx; padding: 7rpx; }
.catalog-option { padding: 20rpx 22rpx; }
.filter-chip { background: #fbfcfa; border-radius: 999rpx; }
.filter-chip.active { background: #dfeee7; border-color: #a9cdbd; color: #0b6b55; }
.source-line { color: #87978f; }
.source-line.searching { color: #0b6b55; font-weight: 650; }
.term-badge { color: #0b6b55; }
.completed-mark { color: #0b6b55; }

.search-field { position: relative; }
.search-field .input { padding-right: 76rpx; }
.keyword-clear {
  align-items: center;
  background: #dfe8e4;
  border-radius: 50%;
  color: #60736a;
  display: flex;
  font-size: 28rpx;
  height: 36rpx;
  justify-content: center;
  position: absolute;
  right: 22rpx;
  top: 25rpx;
  width: 36rpx;
}
.search-aids { border-bottom: 1rpx solid #e0e7e3; padding: 18rpx 0 8rpx; }
.aid-group { margin-bottom: 16rpx; }
.aid-heading { color: #78877f; display: flex; font-size: 20rpx; justify-content: space-between; }
.aid-clear { color: #0b6b55; font-weight: 700; }
.aid-chips { display: flex; flex-wrap: wrap; gap: 9rpx; margin-top: 10rpx; }
.aid-chip {
  border: 1rpx solid #b9d2c7;
  border-radius: 999rpx;
  color: #0b6b55;
  font-size: 21rpx;
  padding: 10rpx 15rpx;
}
.aid-chip.history { background: #e7efeb; border-color: #e7efeb; color: #53675e; }
.empty {
  background: #e8f1ed;
  border: 1rpx dashed #b9d2c7;
  border-radius: 18rpx;
  padding: 48rpx 28rpx;
}
.empty-mark { color: #799187; font-size: 17rpx; font-weight: 850; letter-spacing: 2rpx; }
.empty-title { color: #17352c; font-size: 29rpx; font-weight: 800; margin-top: 12rpx; }
.empty-copy { color: #6c7d75; font-size: 22rpx; line-height: 1.55; margin-top: 9rpx; }
.empty-actions { display: flex; gap: 10rpx; justify-content: center; margin-top: 22rpx; }
.empty-action {
  border: 1rpx solid #9fbdb0;
  border-radius: 11rpx;
  color: #0b6b55;
  font-size: 21rpx;
  font-weight: 700;
  padding: 13rpx 18rpx;
}
.empty-action.primary { background: #0b6b55; border-color: #0b6b55; color: #ffffff; }

.setup-card {
  background: #17352c;
  border-radius: 24rpx;
  box-shadow: 0 16rpx 34rpx rgba(8, 45, 35, 0.18);
  color: #ffffff;
  overflow: hidden;
  padding: 34rpx 30rpx;
  position: relative;
}

.setup-card::after {
  border: 1rpx solid rgba(180, 215, 203, 0.32);
  border-radius: 50%;
  content: '';
  height: 210rpx;
  position: absolute;
  right: -74rpx;
  top: -70rpx;
  width: 210rpx;
}

.setup-kicker {
  color: #9fd1c2;
  font-size: 20rpx;
  font-weight: 850;
  letter-spacing: 2rpx;
}

.setup-title {
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 850;
  letter-spacing: -1rpx;
  line-height: 1.18;
  margin-top: 16rpx;
  position: relative;
  z-index: 1;
}

.setup-copy {
  color: #bdd6ce;
  font-size: 23rpx;
  line-height: 1.55;
  margin-top: 14rpx;
}

.setup-stats {
  background: rgba(232, 241, 237, 0.09);
  border: 1rpx solid rgba(143, 196, 180, 0.22);
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-top: 26rpx;
  padding: 20rpx;
}

.setup-stats > view + view {
  border-left: 1rpx solid rgba(143, 196, 180, 0.28);
  padding-left: 16rpx;
}

.setup-number {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 900;
}

.setup-label {
  color: #a8c5bb;
  font-size: 19rpx;
}

.setup-actions {
  display: grid;
  gap: 14rpx;
  grid-template-columns: 1.1fr 0.9fr;
  margin-top: 26rpx;
}

.setup-action {
  align-items: center;
  background: #e4f0eb;
  border-radius: 14rpx;
  color: #0b6b55;
  display: flex;
  font-size: 25rpx;
  font-weight: 800;
  justify-content: center;
  min-height: 82rpx;
  text-align: center;
}

.setup-action.primary {
  background: #ffffff;
  color: #0b5d4b;
}

.tpg-hero {
  background: #17352c;
  border-radius: 24rpx;
  box-shadow: 0 16rpx 34rpx rgba(8, 45, 35, 0.18);
  color: #ffffff;
  margin-bottom: 18rpx;
  overflow: hidden;
  padding: 34rpx 30rpx;
  position: relative;
}

.tpg-hero::after {
  border: 1rpx solid rgba(180, 215, 203, 0.32);
  border-radius: 50%;
  content: '';
  height: 210rpx;
  position: absolute;
  right: -74rpx;
  top: -70rpx;
  width: 210rpx;
}

.tpg-eyebrow {
  color: #9fd1c2;
  font-size: 20rpx;
  font-weight: 850;
  letter-spacing: 2rpx;
}

.tpg-title {
  font-size: 39rpx;
  font-weight: 850;
  letter-spacing: -1rpx;
  line-height: 1.18;
  margin-top: 16rpx;
  position: relative;
  z-index: 1;
}

.tpg-subtitle {
  color: #bdd6ce;
  font-size: 23rpx;
  line-height: 1.45;
  margin-top: 14rpx;
}

.tpg-hero-foot {
  align-items: flex-end;
  border-top: 1rpx solid #426258;
  display: flex;
  justify-content: space-between;
  margin-top: 28rpx;
  padding-top: 22rpx;
}

.tpg-number {
  font-size: 54rpx;
  font-weight: 900;
  letter-spacing: -2rpx;
}

.tpg-number-label {
  color: #a9c1b8;
  font-size: 20rpx;
}

.tpg-seal {
  border: 2rpx solid #82b4a5;
  color: #dcebe5;
  font-size: 18rpx;
  font-weight: 850;
  letter-spacing: 1rpx;
  padding: 11rpx 14rpx;
  transform: rotate(3deg);
}

.tpg-status {
  align-items: center;
  background: #e4f0eb;
  border: 1rpx solid #bcd7cb;
  border-radius: 16rpx;
  display: flex;
  gap: 20rpx;
}

.tpg-status-copy {
  flex: 1;
}

.tpg-course-card {
  background: #ffffff;
}

.tpg-course-card .term-badge {
  max-width: 250rpx;
  overflow: hidden;
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tpg-empty {
  margin-top: 0;
}

.tpg-actions {
  display: grid;
  gap: 14rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 18rpx;
}

.tpg-action {
  background: #e4f0eb;
  border-radius: 14rpx;
  color: #0b6b55;
  font-size: 25rpx;
  font-weight: 800;
  padding: 24rpx 18rpx;
  text-align: center;
}

.tpg-action.primary {
  background: #0b6b55;
  color: #ffffff;
}

.tpg-catalog-link {
  color: #53665d;
  font-size: 23rpx;
  margin-top: 22rpx;
  text-align: center;
  text-decoration: underline;
  text-decoration-color: #b7cbc2;
}
