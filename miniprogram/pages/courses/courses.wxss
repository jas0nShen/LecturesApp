.tabs {
  margin-bottom: 22rpx;
  white-space: nowrap;
  width: 100%;
}

.source-line {
  color: #87928d;
  font-size: 22rpx;
  margin-top: 10rpx;
}

.tab {
  background: #fbfcfa;
  border: 1rpx solid #d5e0da;
  border-radius: 999rpx;
  color: #53615a;
  display: inline-flex;
  font-size: 24rpx;
  margin-right: 14rpx;
  padding: 16rpx 22rpx;
}

.tab.active {
  background: #0b6b55;
  border-color: #0b6b55;
  box-shadow: 0 6rpx 16rpx rgba(11, 107, 85, 0.14);
  color: #ffffff;
}

.filter-row {
  display: flex;
  gap: 14rpx;
}

.filter-chip {
  background: #ffffff;
  border: 1rpx solid #dfe5df;
  border-radius: 10rpx;
  color: #53615a;
  font-size: 24rpx;
  padding: 14rpx 18rpx;
}

.filter-chip.active {
  background: #e7f0ec;
  border-color: #b8d5c9;
  color: #1f6f5b;
}

.course-card {
  background: #fbfcfa;
  border: 1rpx solid #dae5df;
  border-radius: 18rpx;
  box-shadow: 0 7rpx 20rpx rgba(15, 64, 51, 0.045);
  margin-bottom: 16rpx;
  padding: 26rpx;
  position: relative;
}

.course-card:active {
  background: #f4f8f6;
  transform: scale(0.992);
}

.code {
  color: #0b6b55;
  font-size: 28rpx;
  font-weight: 800;
}

.credits {
  color: #64716b;
  font-size: 24rpx;
}

.card-status {
  align-items: flex-end;
  display: flex;
  flex-direction: column;
  gap: 7rpx;
}

.favorite-mark {
  color: #a06a13;
  font-size: 20rpx;
  font-weight: 700;
}

.favorite-star {
  font-size: 22rpx;
}

.completed-mark {
  color: #1f6f5b;
  font-size: 20rpx;
  font-weight: 700;
}

.planned-mark {
  color: #3f5d75;
  font-size: 20rpx;
  font-weight: 700;
}

.course-title {
  color: #132a22;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
  margin-top: 12rpx;
}

.meta {
  margin-top: 18rpx;
}

.empty {
  color: #64716b;
  font-size: 28rpx;
  padding: 80rpx 0;
  text-align: center;
}
.catalog-switch {
  background: #dfeae5;
  display: grid;
  gap: 8rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin: 24rpx 28rpx 8rpx;
  padding: 8rpx;
  border-radius: 20rpx;
}

.catalog-option {
  border-radius: 16rpx;
  color: #64716b;
  padding: 18rpx 20rpx;
}

.catalog-option.active {
  background: #fbfcfa;
  box-shadow: 0 4rpx 16rpx rgba(31, 111, 91, 0.1);
  color: #173d33;
}

.catalog-label {
  font-size: 28rpx;
  font-weight: 750;
}

.catalog-copy {
  font-size: 21rpx;
  margin-top: 4rpx;
}

.offering-tabs {
  border-top: 1rpx solid #edf0ed;
}

.source-stamp {
  align-items: center;
  background: #e4f0eb;
  border: 1rpx solid #bcd7cb;
  border-radius: 14rpx;
  display: flex;
  gap: 20rpx;
}

.stamp-mark {
  border: 2rpx solid #0b6b55;
  color: #0b6b55;
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  padding: 10rpx;
  transform: rotate(-2deg);
}

.stamp-title {
  color: #173d33;
  font-size: 24rpx;
  font-weight: 700;
}

.stamp-copy {
  color: #64716b;
  font-size: 21rpx;
  margin-top: 5rpx;
}

.term-badge {
  color: #1f6f5b;
  font-size: 22rpx;
  font-weight: 650;
}

.offering-footer {
  color: #75817b;
  display: flex;
  font-size: 21rpx;
  justify-content: space-between;
  margin-top: 18rpx;
}

.catalog-switch { margin: 4rpx 0 22rpx; padding: 7rpx; }
.catalog-option { padding: 20rpx 22rpx; }
.filter-chip { background: #fbfcfa; border-radius: 999rpx; }
.filter-chip.active { background: #dfeee7; border-color: #a9cdbd; color: #0b6b55; }
.source-line { color: #87978f; }
.term-badge { color: #0b6b55; }
.completed-mark { color: #0b6b55; }
