.tabs {
  margin-bottom: 22rpx;
  white-space: nowrap;
  width: 100%;
}

.source-line {
  color: #87928d;
  font-size: 22rpx;
  margin-top: 10rpx;
}

.tab {
  background: #ffffff;
  border: 1rpx solid #dfe5df;
  border-radius: 999rpx;
  color: #53615a;
  display: inline-flex;
  font-size: 24rpx;
  margin-right: 14rpx;
  padding: 16rpx 22rpx;
}

.tab.active {
  background: #1f6f5b;
  border-color: #1f6f5b;
  color: #ffffff;
}

.filter-row {
  display: flex;
  gap: 14rpx;
}

.filter-chip {
  background: #ffffff;
  border: 1rpx solid #dfe5df;
  border-radius: 10rpx;
  color: #53615a;
  font-size: 24rpx;
  padding: 14rpx 18rpx;
}

.filter-chip.active {
  background: #e7f0ec;
  border-color: #b8d5c9;
  color: #1f6f5b;
}

.course-card {
  background: #ffffff;
  border: 1rpx solid #e2e7e1;
  border-radius: 12rpx;
  margin-bottom: 18rpx;
  padding: 24rpx;
}

.code {
  color: #1f6f5b;
  font-size: 28rpx;
  font-weight: 800;
}

.credits {
  color: #64716b;
  font-size: 24rpx;
}

.course-title {
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
  margin-top: 12rpx;
}

.meta {
  margin-top: 18rpx;
}

.empty {
  color: #64716b;
  font-size: 28rpx;
  padding: 80rpx 0;
  text-align: center;
}
