page {
  background:
    radial-gradient(circle at 100% 0%, rgba(219, 229, 223, 0.48) 0, rgba(219, 229, 223, 0) 30%),
    linear-gradient(180deg, #fafbf9 0%, #f4f6f3 54%, #f8f9f7 100%);
  color: #1b3027;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Helvetica Neue", Arial, sans-serif;
}

.page {
  padding-left: 28rpx;
  padding-right: 28rpx;
}

.tabs {
  margin-bottom: 24rpx;
  white-space: nowrap;
  width: 100%;
}

.source-line {
  color: #87928d;
  font-size: 22rpx;
  margin-top: 10rpx;
}

.tab {
  background: rgba(255, 255, 252, 0.72);
  border: 1rpx solid #d9e2db;
  border-radius: 999rpx;
  color: #5c6b63;
  display: inline-flex;
  font-size: 23rpx;
  font-weight: 650;
  letter-spacing: 0.1rpx;
  margin-right: 14rpx;
  padding: 15rpx 22rpx;
}

.tab.active {
  background: #245d4c;
  border-color: #245d4c;
  box-shadow: 0 8rpx 18rpx rgba(36, 93, 76, 0.16);
  color: #ffffff;
}

.filter-row {
  display: flex;
  gap: 14rpx;
}

.filter-chip {
  background: rgba(255, 255, 252, 0.76);
  border: 1rpx solid #dce5df;
  border-radius: 999rpx;
  color: #607067;
  font-size: 23rpx;
  font-weight: 650;
  padding: 14rpx 19rpx;
}

.filter-chip.active {
  background: #e1ece5;
  border-color: #b9d0c4;
  color: #245d4c;
}

.course-card {
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(218, 225, 219, 0.9);
  border-radius: 18rpx;
  box-shadow:
    0 10rpx 26rpx rgba(29, 47, 38, 0.025),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.92);
  margin-bottom: 16rpx;
  padding: 24rpx 26rpx 23rpx;
  position: relative;
}

.course-card:active {
  background: #f7faf6;
  transform: scale(0.992);
}

.code {
  color: #285f4e;
  font-family: "SF Mono", "Menlo", "Consolas", monospace;
  font-size: 22rpx;
  font-weight: 740;
  letter-spacing: 0.22rpx;
}

.credits {
  color: #64716b;
  font-size: 24rpx;
}

.card-status {
  align-items: flex-end;
  display: flex;
  flex-direction: column;
  gap: 7rpx;
}

.favorite-mark {
  color: #a06a13;
  font-size: 20rpx;
  font-weight: 700;
}

.favorite-star {
  font-size: 22rpx;
}

.completed-mark {
  color: #1f6f5b;
  font-size: 20rpx;
  font-weight: 700;
}

.planned-mark {
  color: #3f5d75;
  font-size: 20rpx;
  font-weight: 700;
}

.course-title {
  color: #193027;
  font-family: "Avenir Next", -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Helvetica Neue", sans-serif;
  font-size: 27rpx;
  font-weight: 650;
  letter-spacing: -0.2rpx;
  line-height: 1.42;
  margin-top: 11rpx;
}

.meta {
  margin-top: 18rpx;
}

.empty {
  color: #64716b;
  font-size: 28rpx;
  padding: 80rpx 0;
  text-align: center;
}
.catalog-switch {
  background: #dfeae5;
  display: grid;
  gap: 8rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin: 24rpx 28rpx 8rpx;
  padding: 8rpx;
  border-radius: 20rpx;
}

.catalog-option {
  border-radius: 16rpx;
  color: #64716b;
  padding: 18rpx 20rpx;
}

.catalog-option.active {
  background: #fbfcfa;
  box-shadow: 0 4rpx 16rpx rgba(31, 111, 91, 0.1);
  color: #173d33;
}

.catalog-label {
  font-size: 28rpx;
  font-weight: 750;
}

.catalog-copy {
  font-size: 21rpx;
  margin-top: 4rpx;
}

.offering-tabs {
  border-top: 1rpx solid #edf0ed;
}

.offering-filter-bar {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin: -4rpx 0 20rpx;
}

.filter-select {
  align-items: center;
  background: #fbfcfa;
  border: 1rpx solid #d5e0da;
  border-radius: 13rpx;
  color: #40534a;
  display: flex;
  font-size: 23rpx;
  justify-content: space-between;
  min-height: 72rpx;
  padding: 0 20rpx;
}

.filter-arrow {
  color: #829088;
  font-size: 24rpx;
}

.source-stamp {
  align-items: center;
  background: #e4f0eb;
  border: 1rpx solid #bcd7cb;
  border-radius: 14rpx;
  display: flex;
  gap: 20rpx;
}

.stamp-mark {
  border: 2rpx solid #0b6b55;
  color: #0b6b55;
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  padding: 10rpx;
  transform: rotate(-2deg);
}

.stamp-title {
  color: #173d33;
  font-size: 24rpx;
  font-weight: 700;
}

.stamp-copy {
  color: #64716b;
  font-size: 21rpx;
  margin-top: 5rpx;
}

.term-badge {
  color: #1f6f5b;
  font-size: 22rpx;
  font-weight: 650;
}

.offering-footer {
  color: #75817b;
  display: flex;
  font-size: 21rpx;
  justify-content: space-between;
  margin-top: 18rpx;
}

.catalog-switch { margin: 4rpx 0 22rpx; padding: 7rpx; }
.catalog-option { padding: 20rpx 22rpx; }
.source-line {
  color: #8a948e;
  font-size: 21rpx;
  letter-spacing: 0.1rpx;
}
.source-line.searching { color: #245d4c; font-weight: 650; }
.term-badge {
  background: rgba(242, 244, 239, 0.86);
  border: 1rpx solid #dfe5dd;
  border-radius: 999rpx;
  color: #65746c;
  font-size: 18rpx;
  font-weight: 620;
  padding: 7rpx 12rpx;
}
.completed-mark { color: #245d4c; }

.search-field { position: relative; }
.search-field::before {
  color: #99a49d;
  content: '⌕';
  font-size: 28rpx;
  left: 24rpx;
  line-height: 1;
  position: absolute;
  top: 28rpx;
  z-index: 1;
}
.search-field .input {
  background: rgba(255, 255, 253, 0.86);
  border-color: rgba(208, 216, 209, 0.92);
  border-radius: 16rpx;
  box-shadow:
    0 6rpx 16rpx rgba(45, 58, 51, 0.018),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  color: #1b2a24;
  font-size: 24rpx;
  height: 90rpx;
  padding-left: 62rpx;
  padding-right: 76rpx;
}
.keyword-clear {
  align-items: center;
  background: #e7efea;
  border-radius: 50%;
  color: #6f7f77;
  display: flex;
  font-size: 27rpx;
  height: 36rpx;
  justify-content: center;
  position: absolute;
  right: 22rpx;
  top: 27rpx;
  width: 36rpx;
}
.search-aids { border-bottom: 1rpx solid #e0e7e3; padding: 18rpx 0 8rpx; }
.aid-group { margin-bottom: 16rpx; }
.aid-heading { color: #78877f; display: flex; font-size: 20rpx; justify-content: space-between; }
.aid-clear { color: #0b6b55; font-weight: 700; }
.aid-chips { display: flex; flex-wrap: wrap; gap: 9rpx; margin-top: 10rpx; }
.aid-chip {
  border: 1rpx solid #b9d2c7;
  border-radius: 999rpx;
  color: #0b6b55;
  font-size: 21rpx;
  padding: 10rpx 15rpx;
}
.aid-chip.history { background: #e7efeb; border-color: #e7efeb; color: #53675e; }
.empty {
  background: #e8f1ed;
  border: 1rpx dashed #b9d2c7;
  border-radius: 18rpx;
  padding: 48rpx 28rpx;
}
.empty-mark { color: #799187; font-size: 17rpx; font-weight: 850; letter-spacing: 2rpx; }
.empty-title { color: #17352c; font-size: 29rpx; font-weight: 800; margin-top: 12rpx; }
.empty-copy { color: #6c7d75; font-size: 22rpx; line-height: 1.55; margin-top: 9rpx; }
.empty-actions { display: flex; gap: 10rpx; justify-content: center; margin-top: 22rpx; }
.empty-action {
  border: 1rpx solid #9fbdb0;
  border-radius: 11rpx;
  color: #0b6b55;
  font-size: 21rpx;
  font-weight: 700;
  padding: 13rpx 18rpx;
}
.empty-action.primary { background: #0b6b55; border-color: #0b6b55; color: #ffffff; }

.setup-card {
  background: #17352c;
  border-radius: 24rpx;
  box-shadow: 0 16rpx 34rpx rgba(8, 45, 35, 0.18);
  color: #ffffff;
  overflow: hidden;
  padding: 34rpx 30rpx;
  position: relative;
}

.setup-card::after {
  border: 1rpx solid rgba(180, 215, 203, 0.32);
  border-radius: 50%;
  content: '';
  height: 210rpx;
  position: absolute;
  right: -74rpx;
  top: -70rpx;
  width: 210rpx;
}

.setup-kicker {
  color: #9fd1c2;
  font-size: 20rpx;
  font-weight: 850;
  letter-spacing: 2rpx;
}

.setup-title {
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 850;
  letter-spacing: -1rpx;
  line-height: 1.18;
  margin-top: 16rpx;
  position: relative;
  z-index: 1;
}

.setup-copy {
  color: #bdd6ce;
  font-size: 23rpx;
  line-height: 1.55;
  margin-top: 14rpx;
}

.setup-stats {
  background: rgba(232, 241, 237, 0.09);
  border: 1rpx solid rgba(143, 196, 180, 0.22);
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-top: 26rpx;
  padding: 20rpx;
}

.setup-stats > view + view {
  border-left: 1rpx solid rgba(143, 196, 180, 0.28);
  padding-left: 16rpx;
}

.setup-number {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 900;
}

.setup-label {
  color: #a8c5bb;
  font-size: 19rpx;
}

.setup-actions {
  display: grid;
  gap: 14rpx;
  grid-template-columns: 1.1fr 0.9fr;
  margin-top: 26rpx;
}

.setup-action {
  align-items: center;
  background: #e4f0eb;
  border-radius: 14rpx;
  color: #0b6b55;
  display: flex;
  font-size: 25rpx;
  font-weight: 800;
  justify-content: center;
  min-height: 82rpx;
  text-align: center;
}

.setup-action.primary {
  background: #ffffff;
  color: #0b5d4b;
}

.tpg-hero {
  background:
    linear-gradient(142deg, rgba(255, 255, 254, 0.98) 0%, rgba(244, 247, 243, 0.97) 100%);
  border: 1rpx solid rgba(207, 218, 210, 0.86);
  border-radius: 22rpx;
  box-shadow:
    0 14rpx 34rpx rgba(35, 53, 43, 0.04),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.98);
  color: #20372e;
  margin-bottom: 14rpx;
  overflow: hidden;
  padding: 29rpx 30rpx 22rpx;
  position: relative;
}

.tpg-hero::before {
  background: #789a89;
  border-radius: 999rpx;
  content: '';
  height: 42rpx;
  left: 27rpx;
  position: absolute;
  top: 23rpx;
  width: 4rpx;
}

.tpg-hero::after {
  border: 1rpx solid rgba(104, 137, 119, 0.18);
  display: block;
  border-radius: 999rpx;
  bottom: auto;
  content: '';
  height: 114rpx;
  position: absolute;
  right: -58rpx;
  top: -52rpx;
  width: 114rpx;
}

.tpg-eyebrow {
  color: #587163;
  font-family: "SF Mono", "Menlo", "Consolas", monospace;
  font-size: 16rpx;
  font-weight: 720;
  letter-spacing: 1.5rpx;
  padding-left: 15rpx;
  text-transform: uppercase;
}

.tpg-title {
  color: #172e25;
  display: -webkit-box;
  font-family: "Avenir Next", -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Helvetica Neue", sans-serif;
  font-size: 30rpx;
  font-weight: 620;
  letter-spacing: -0.38rpx;
  line-height: 1.38;
  margin-top: 15rpx;
  overflow: hidden;
  position: relative;
  text-overflow: ellipsis;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  z-index: 1;
}

.tpg-subtitle {
  color: #708076;
  display: -webkit-box;
  font-size: 18rpx;
  font-weight: 500;
  line-height: 1.5;
  margin-top: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
}

.ug-course-hero .tpg-subtitle {
  -webkit-line-clamp: 1;
}

.tpg-hero-foot {
  align-items: flex-end;
  background: transparent;
  border: 0;
  border-radius: 0;
  border-top: 1rpx solid rgba(137, 163, 148, 0.2);
  display: flex;
  justify-content: space-between;
  margin-top: 17rpx;
  padding: 14rpx 0 0;
  position: relative;
  z-index: 1;
}

.tpg-number {
  color: #335347;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
  font-size: 22rpx;
  font-weight: 650;
  letter-spacing: -0.12rpx;
}

.tpg-number.text-status {
  color: #587166;
  font-size: 22rpx;
  letter-spacing: 0;
}

.tpg-number-label {
  color: #829087;
  font-size: 15rpx;
  letter-spacing: 0.15rpx;
  margin-top: 4rpx;
}

.tpg-seal {
  background: rgba(237, 242, 238, 0.82);
  border: 1rpx solid rgba(185, 202, 191, 0.7);
  border-radius: 999rpx;
  color: #466658;
  font-size: 16rpx;
  font-weight: 650;
  letter-spacing: 0.45rpx;
  padding: 7rpx 14rpx;
}

.tpg-status {
  align-items: center;
  background: transparent;
  border: 0;
  border-radius: 0;
  box-shadow: none;
  display: flex;
  gap: 12rpx;
  padding: 2rpx 2rpx 14rpx;
}

.tpg-status .stamp-mark {
  background: #eef4f0;
  border: 1rpx solid #cfdfd5;
  border-radius: 999rpx;
  color: #4f6d5e;
  flex-shrink: 0;
  font-size: 14rpx;
  font-weight: 650;
  letter-spacing: 0.18rpx;
  padding: 7rpx 10rpx;
  transform: none;
}

.tpg-status .stamp-title {
  color: #50675b;
  font-size: 19rpx;
  font-weight: 620;
}

.tpg-status .stamp-copy {
  color: #849087;
  font-size: 16rpx;
  line-height: 1.5;
}

.tpg-status-copy {
  flex: 1;
}

.tpg-course-card {
  background: rgba(255, 255, 253, 0.94);
}

.tpg-course-card .term-badge {
  max-width: 250rpx;
  overflow: hidden;
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ug-source-link {
  border-top: 1rpx solid #e6ece5;
  color: #2d6857;
  font-size: 21rpx;
  font-weight: 700;
  margin-top: 18rpx;
  padding-top: 18rpx;
}

.tpg-empty {
  margin-top: 0;
}

.tpg-actions {
  display: grid;
  gap: 14rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 18rpx;
}

.tpg-action {
  background: rgba(232, 241, 236, 0.92);
  border: 1rpx solid #d3e3da;
  border-radius: 18rpx;
  color: #245d4c;
  font-size: 25rpx;
  font-weight: 760;
  padding: 24rpx 18rpx;
  text-align: center;
}

.tpg-action.primary {
  background: #245d4c;
  border-color: #245d4c;
  box-shadow: 0 10rpx 22rpx rgba(36, 93, 76, 0.16);
  color: #ffffff;
}

.tpg-catalog-link {
  color: #53665d;
  font-size: 23rpx;
  margin-top: 22rpx;
  text-align: center;
  text-decoration: underline;
  text-decoration-color: #b7cbc2;
}
