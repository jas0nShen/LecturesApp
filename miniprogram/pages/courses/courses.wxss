page {
  background:
    radial-gradient(circle at 8% -8%, rgba(205, 217, 209, 0.34) 0%, rgba(248, 248, 243, 0) 34%),
    radial-gradient(circle at 100% 2%, rgba(224, 214, 190, 0.14) 0%, rgba(248, 248, 243, 0) 32%),
    linear-gradient(180deg, #faf9f3 0%, #f4f7f3 46%, #fcfbf6 100%);
  color: #18241f;
  font-family: "SF Pro Text", -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Helvetica Neue", sans-serif;
}

.page {
  padding-left: 28rpx;
  padding-right: 28rpx;
}

.tabs {
  margin-bottom: 24rpx;
  white-space: nowrap;
  width: 100%;
}

.source-line {
  color: #87928d;
  font-size: 22rpx;
  margin-top: 10rpx;
}

.tab {
  background: rgba(255, 255, 252, 0.72);
  border: 1rpx solid #d9e2db;
  border-radius: 999rpx;
  color: #5c6b63;
  display: inline-flex;
  font-size: 23rpx;
  font-weight: 650;
  letter-spacing: 0.1rpx;
  margin-right: 14rpx;
  padding: 15rpx 22rpx;
}

.tab.active {
  background: #245d4c;
  border-color: #245d4c;
  box-shadow: 0 8rpx 18rpx rgba(36, 93, 76, 0.16);
  color: #ffffff;
}

.filter-row {
  display: flex;
  gap: 14rpx;
}

.filter-chip {
  background: rgba(255, 255, 252, 0.76);
  border: 1rpx solid #dce5df;
  border-radius: 999rpx;
  color: #607067;
  font-size: 23rpx;
  font-weight: 650;
  padding: 14rpx 19rpx;
}

.filter-chip.active {
  background: #e1ece5;
  border-color: #b9d0c4;
  color: #245d4c;
}

.course-card {
  background: rgba(255, 255, 253, 0.98);
  border: 1rpx solid rgba(215, 221, 213, 0.82);
  border-radius: 18rpx;
  box-shadow:
    0 8rpx 22rpx rgba(44, 63, 54, 0.028),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.86);
  margin-bottom: 16rpx;
  padding: 24rpx 26rpx 23rpx;
  position: relative;
}

.course-card:active {
  background: #f7faf6;
  transform: scale(0.992);
}

.code {
  color: #2d695b;
  font-family: "SF Mono", "Menlo", "Consolas", monospace;
  font-size: 22rpx;
  font-weight: 740;
  letter-spacing: 0.22rpx;
}

.credits {
  color: #64716b;
  font-size: 24rpx;
}

.card-status {
  align-items: flex-end;
  display: flex;
  flex-direction: column;
  gap: 7rpx;
}

.favorite-mark {
  color: #a06a13;
  font-size: 20rpx;
  font-weight: 700;
}

.favorite-star {
  font-size: 22rpx;
}

.completed-mark {
  color: #1f6f5b;
  font-size: 20rpx;
  font-weight: 700;
}

.planned-mark {
  color: #3f5d75;
  font-size: 20rpx;
  font-weight: 700;
}

.course-title {
  color: #172720;
  font-size: 26rpx;
  font-weight: 650;
  letter-spacing: -0.18rpx;
  line-height: 1.5;
  margin-top: 12rpx;
}

.meta {
  margin-top: 18rpx;
}

.empty {
  color: #64716b;
  font-size: 28rpx;
  padding: 80rpx 0;
  text-align: center;
}
.catalog-switch {
  background: #dfeae5;
  display: grid;
  gap: 8rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin: 24rpx 28rpx 8rpx;
  padding: 8rpx;
  border-radius: 20rpx;
}

.catalog-option {
  border-radius: 16rpx;
  color: #64716b;
  padding: 18rpx 20rpx;
}

.catalog-option.active {
  background: #fbfcfa;
  box-shadow: 0 4rpx 16rpx rgba(31, 111, 91, 0.1);
  color: #173d33;
}

.catalog-label {
  font-size: 28rpx;
  font-weight: 750;
}

.catalog-copy {
  font-size: 21rpx;
  margin-top: 4rpx;
}

.offering-tabs {
  border-top: 1rpx solid #edf0ed;
}

.offering-filter-bar {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin: -4rpx 0 20rpx;
}

.filter-select {
  align-items: center;
  background: #fbfcfa;
  border: 1rpx solid #d5e0da;
  border-radius: 13rpx;
  color: #40534a;
  display: flex;
  font-size: 23rpx;
  justify-content: space-between;
  min-height: 72rpx;
  padding: 0 20rpx;
}

.filter-arrow {
  color: #829088;
  font-size: 24rpx;
}

.source-stamp {
  align-items: center;
  background: #e4f0eb;
  border: 1rpx solid #bcd7cb;
  border-radius: 14rpx;
  display: flex;
  gap: 20rpx;
}

.stamp-mark {
  border: 2rpx solid #0b6b55;
  color: #0b6b55;
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  padding: 10rpx;
  transform: rotate(-2deg);
}

.stamp-title {
  color: #173d33;
  font-size: 24rpx;
  font-weight: 700;
}

.stamp-copy {
  color: #64716b;
  font-size: 21rpx;
  margin-top: 5rpx;
}

.term-badge {
  color: #1f6f5b;
  font-size: 22rpx;
  font-weight: 650;
}

.offering-footer {
  color: #75817b;
  display: flex;
  font-size: 21rpx;
  justify-content: space-between;
  margin-top: 18rpx;
}

.catalog-switch { margin: 4rpx 0 22rpx; padding: 7rpx; }
.catalog-option { padding: 20rpx 22rpx; }
.source-line {
  color: #8a948e;
  font-size: 21rpx;
  letter-spacing: 0.1rpx;
}
.source-line.searching { color: #245d4c; font-weight: 650; }
.term-badge {
  background: rgba(242, 244, 239, 0.86);
  border: 1rpx solid #dfe5dd;
  border-radius: 999rpx;
  color: #65746c;
  font-size: 18rpx;
  font-weight: 620;
  padding: 7rpx 12rpx;
}
.completed-mark { color: #245d4c; }

.search-field { position: relative; }
.search-field::before {
  color: #99a49d;
  content: '⌕';
  font-size: 28rpx;
  left: 24rpx;
  line-height: 1;
  position: absolute;
  top: 28rpx;
  z-index: 1;
}
.search-field .input {
  background: rgba(255, 255, 253, 0.98);
  border-color: rgba(211, 217, 210, 0.9);
  border-radius: 16rpx;
  box-shadow:
    0 6rpx 16rpx rgba(45, 58, 51, 0.018),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  color: #1b2a24;
  font-size: 24rpx;
  height: 90rpx;
  padding-left: 62rpx;
  padding-right: 76rpx;
}
.keyword-clear {
  align-items: center;
  background: #e7efea;
  border-radius: 50%;
  color: #6f7f77;
  display: flex;
  font-size: 27rpx;
  height: 36rpx;
  justify-content: center;
  position: absolute;
  right: 22rpx;
  top: 27rpx;
  width: 36rpx;
}
.search-aids { border-bottom: 1rpx solid #e0e7e3; padding: 18rpx 0 8rpx; }
.aid-group { margin-bottom: 16rpx; }
.aid-heading { color: #78877f; display: flex; font-size: 20rpx; justify-content: space-between; }
.aid-clear { color: #0b6b55; font-weight: 700; }
.aid-chips { display: flex; flex-wrap: wrap; gap: 9rpx; margin-top: 10rpx; }
.aid-chip {
  border: 1rpx solid #b9d2c7;
  border-radius: 999rpx;
  color: #0b6b55;
  font-size: 21rpx;
  padding: 10rpx 15rpx;
}
.aid-chip.history { background: #e7efeb; border-color: #e7efeb; color: #53675e; }
.empty {
  background: #e8f1ed;
  border: 1rpx dashed #b9d2c7;
  border-radius: 18rpx;
  padding: 48rpx 28rpx;
}
.empty-mark { color: #799187; font-size: 17rpx; font-weight: 850; letter-spacing: 2rpx; }
.empty-title { color: #17352c; font-size: 29rpx; font-weight: 800; margin-top: 12rpx; }
.empty-copy { color: #6c7d75; font-size: 22rpx; line-height: 1.55; margin-top: 9rpx; }
.empty-actions { display: flex; gap: 10rpx; justify-content: center; margin-top: 22rpx; }
.empty-action {
  border: 1rpx solid #9fbdb0;
  border-radius: 11rpx;
  color: #0b6b55;
  font-size: 21rpx;
  font-weight: 700;
  padding: 13rpx 18rpx;
}
.empty-action.primary { background: #0b6b55; border-color: #0b6b55; color: #ffffff; }

.setup-card {
  background: #17352c;
  border-radius: 24rpx;
  box-shadow: 0 16rpx 34rpx rgba(8, 45, 35, 0.18);
  color: #ffffff;
  overflow: hidden;
  padding: 34rpx 30rpx;
  position: relative;
}

.setup-card::after {
  border: 1rpx solid rgba(180, 215, 203, 0.32);
  border-radius: 50%;
  content: '';
  height: 210rpx;
  position: absolute;
  right: -74rpx;
  top: -70rpx;
  width: 210rpx;
}

.setup-kicker {
  color: #9fd1c2;
  font-size: 20rpx;
  font-weight: 850;
  letter-spacing: 2rpx;
}

.setup-title {
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 850;
  letter-spacing: -1rpx;
  line-height: 1.18;
  margin-top: 16rpx;
  position: relative;
  z-index: 1;
}

.setup-copy {
  color: #bdd6ce;
  font-size: 23rpx;
  line-height: 1.55;
  margin-top: 14rpx;
}

.setup-stats {
  background: rgba(232, 241, 237, 0.09);
  border: 1rpx solid rgba(143, 196, 180, 0.22);
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-top: 26rpx;
  padding: 20rpx;
}

.setup-stats > view + view {
  border-left: 1rpx solid rgba(143, 196, 180, 0.28);
  padding-left: 16rpx;
}

.setup-number {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 900;
}

.setup-label {
  color: #a8c5bb;
  font-size: 19rpx;
}

.setup-actions {
  display: grid;
  gap: 14rpx;
  grid-template-columns: 1.1fr 0.9fr;
  margin-top: 26rpx;
}

.setup-action {
  align-items: center;
  background: #e4f0eb;
  border-radius: 14rpx;
  color: #0b6b55;
  display: flex;
  font-size: 25rpx;
  font-weight: 800;
  justify-content: center;
  min-height: 82rpx;
  text-align: center;
}

.setup-action.primary {
  background: #ffffff;
  color: #0b5d4b;
}

.tpg-hero {
  background:
    linear-gradient(90deg, rgba(132, 157, 143, 0.1) 0%, rgba(132, 157, 143, 0) 36%),
    linear-gradient(135deg, rgba(255, 255, 253, 0.99) 0%, rgba(249, 248, 241, 0.99) 60%, rgba(241, 246, 241, 0.99) 100%);
  border: 1rpx solid rgba(212, 220, 212, 0.92);
  border-radius: 22rpx;
  box-shadow:
    0 10rpx 28rpx rgba(47, 61, 54, 0.042),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85);
  color: #1b2923;
  margin-bottom: 12rpx;
  overflow: hidden;
  padding: 27rpx 28rpx 24rpx;
  position: relative;
}

.tpg-hero::before {
  background: linear-gradient(180deg, #d4b16e 0%, rgba(212, 177, 110, 0.18) 100%);
  border-radius: 999rpx;
  content: '';
  height: 72rpx;
  left: 0;
  position: absolute;
  top: 28rpx;
  width: 5rpx;
}

.tpg-hero::after {
  background: rgba(43, 76, 66, 0.045);
  border-radius: 999rpx;
  bottom: auto;
  content: '';
  height: 92rpx;
  position: absolute;
  right: -48rpx;
  top: -40rpx;
  width: 92rpx;
}

.tpg-eyebrow {
  color: #7c877f;
  font-family: "SF Mono", "Menlo", "Consolas", monospace;
  font-size: 16rpx;
  font-weight: 680;
  letter-spacing: 1.7rpx;
  text-transform: uppercase;
}

.tpg-title {
  color: #152720;
  display: -webkit-box;
  font-family: "SF Pro Display", -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 31rpx;
  font-weight: 720;
  letter-spacing: -0.5rpx;
  line-height: 1.26;
  margin-top: 12rpx;
  overflow: hidden;
  position: relative;
  text-overflow: ellipsis;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  z-index: 1;
}

.tpg-subtitle {
  color: #5f6f66;
  display: -webkit-box;
  font-size: 20rpx;
  font-weight: 430;
  line-height: 1.48;
  margin-top: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.ug-course-hero .tpg-subtitle {
  -webkit-line-clamp: 1;
}

.tpg-hero-foot {
  align-items: center;
  background: rgba(248, 250, 246, 0.74);
  border: 1rpx solid rgba(222, 227, 219, 0.8);
  border-radius: 16rpx;
  display: flex;
  justify-content: space-between;
  margin-top: 17rpx;
  padding: 13rpx 15rpx;
  position: relative;
  z-index: 1;
}

.tpg-number {
  color: #2e4f45;
  font-family: "SF Pro Display", -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 23rpx;
  font-weight: 700;
  letter-spacing: -0.1rpx;
}

.tpg-number.text-status {
  color: #5d6c64;
  font-size: 21rpx;
  letter-spacing: 0;
}

.tpg-number-label {
  color: #8b958f;
  font-size: 17rpx;
  margin-top: 3rpx;
}

.tpg-seal {
  background: rgba(255, 255, 252, 0.92);
  border: 1rpx solid rgba(211, 218, 210, 0.95);
  border-radius: 999rpx;
  color: #607168;
  font-size: 17rpx;
  font-weight: 640;
  letter-spacing: 0.35rpx;
  padding: 8rpx 13rpx;
}

.tpg-status {
  align-items: flex-start;
  background: rgba(255, 255, 253, 0.82);
  border: 1rpx solid rgba(216, 224, 216, 0.82);
  border-radius: 15rpx;
  box-shadow: none;
  display: flex;
  gap: 13rpx;
  padding: 14rpx 16rpx;
}

.tpg-status .stamp-mark {
  background: rgba(247, 248, 243, 0.9);
  border: 1rpx solid rgba(216, 224, 216, 0.9);
  border-radius: 999rpx;
  color: #51665d;
  flex-shrink: 0;
  font-size: 16rpx;
  font-weight: 620;
  letter-spacing: 0.18rpx;
  padding: 8rpx 11rpx;
  transform: none;
}

.tpg-status .stamp-title {
  color: #31443c;
  font-size: 22rpx;
  font-weight: 660;
}

.tpg-status .stamp-copy {
  color: #737f78;
  font-size: 19rpx;
  line-height: 1.45;
}

.tpg-status-copy {
  flex: 1;
}

.tpg-course-card {
  background: #ffffff;
}

.tpg-course-card .term-badge {
  max-width: 250rpx;
  overflow: hidden;
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ug-source-link {
  border-top: 1rpx solid #e6ece5;
  color: #2d6857;
  font-size: 21rpx;
  font-weight: 700;
  margin-top: 18rpx;
  padding-top: 18rpx;
}

.tpg-empty {
  margin-top: 0;
}

.tpg-actions {
  display: grid;
  gap: 14rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 18rpx;
}

.tpg-action {
  background: rgba(232, 241, 236, 0.92);
  border: 1rpx solid #d3e3da;
  border-radius: 18rpx;
  color: #245d4c;
  font-size: 25rpx;
  font-weight: 760;
  padding: 24rpx 18rpx;
  text-align: center;
}

.tpg-action.primary {
  background: #245d4c;
  border-color: #245d4c;
  box-shadow: 0 10rpx 22rpx rgba(36, 93, 76, 0.16);
  color: #ffffff;
}

.tpg-catalog-link {
  color: #53665d;
  font-size: 23rpx;
  margin-top: 22rpx;
  text-align: center;
  text-decoration: underline;
  text-decoration-color: #b7cbc2;
}
