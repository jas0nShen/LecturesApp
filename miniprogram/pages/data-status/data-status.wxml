<view class="page" wx:if="{{status}}">
  <view class="section release-card">
    <view class="release-kicker">RELEASE · {{releaseInfo.version}}</view>
    <view class="release-title">{{releaseInfo.target}}</view>
    <view class="release-copy">{{releaseInfo.dataMode}} · {{releaseInfo.releaseNote}}</view>
  </view>

  <view class="section status-head {{status.status}}">
    <view class="status-seal">{{status.status === 'current' ? 'VERIFIED' : 'REVIEW'}}</view>
    <view>
      <view class="status-kicker">DATA PASSPORT · HKU</view>
      <view class="title">{{status.statusLabel}}</view>
      <view class="subtitle">{{status.status === 'current' ? '本地资料在设定的 90 天复核周期内。' : '资料已超过 90 天复核周期，使用前请核对官网。'}}</view>
    </view>
  </view>

  <view class="section runtime-card">
    <view>
      <view class="runtime-kicker">RUNTIME MODE</view>
      <view class="runtime-title">{{status.runtime.envLabel}} · {{status.runtime.modeLabel}}</view>
      <view class="runtime-copy">{{status.runtime.apiEnabled ? '开发环境会优先连接本机服务，连接失败时自动读取离线数据。' : '体验版与正式版直接读取随小程序发布的离线数据。'}}</view>
    </view>
    <view class="runtime-light {{status.runtime.apiEnabled ? 'online' : 'offline'}}"></view>
  </view>

  <view class="section tpg-passport" wx:if="{{tpgStatus}}">
    <view class="tpg-passport-head">
      <view>
        <view class="status-kicker">TPG DATA PASSPORT</view>
        <view class="tpg-title">授课硕士资料库</view>
        <view class="tpg-copy">用于当前版本的 Programme 索引；已开放课程组的项目会显示课程结构。</view>
      </view>
      <view class="tpg-seal">PDF<br/>IMPORT</view>
    </view>
    <view class="tpg-note-line">已开放课程组的 Programme 会显示课程结构；其余 Programme 先展示索引与来源，暂不生成毕业判断。</view>
    <view class="source-action tpg-source-action" bindtap="copyTpgSources">复制 PDF 来源清单</view>
  </view>

  <view class="section tpg-passport ug-passport" wx:if="{{ugStatus}}">
    <view class="tpg-passport-head">
      <view>
        <view class="status-kicker">UG DATA PASSPORT</view>
        <view class="tpg-title">本科资料库</view>
        <view class="tpg-copy">用于本科 Programme / Major 选择；课程代码和毕业规则会按公开资料复核后逐步开放。</view>
      </view>
      <view class="tpg-seal">JSON<br/>IMPORT</view>
    </view>
    <view class="tpg-metrics">
      <view class="tpg-metric">
        <view class="stat-value">{{ugStatus.universityCount}}</view>
        <view class="stat-label">所大学</view>
      </view>
      <view class="tpg-metric">
        <view class="stat-value">{{ugStatus.sourceProgrammeCount}}</view>
        <view class="stat-label">Programme</view>
      </view>
      <view class="tpg-metric">
        <view class="stat-value">{{ugStatus.majorCount}}</view>
        <view class="stat-label">Major / Track</view>
      </view>
    </view>
    <view class="tpg-note-line">当前已录入 {{ugStatus.codedCourseCount}} 条本科课程代码；未开放课程的 Programme 只展示索引与来源，暂不生成毕业判断。</view>
    <view class="ug-overall-line">本科总覆盖率：{{ugStatus.programmeWithCoursesCount}}/{{ugStatus.sourceProgrammeCount}} Programme 已开放 · {{ugStatus.coveragePercent}}% · {{ugStatus.pendingProgrammeCount}} 个待补</view>
    <view class="ug-readiness-line">待补来源状态：{{ugStatus.sourceReadinessLabel}}</view>
    <view class="data-updated-line">本科数据更新时间：{{ugStatus.generatedDate || '待确认'}}</view>
    <view class="ug-school-list" wx:if="{{ugSchools.length}}">
      <view wx:for="{{ugSchools}}" wx:key="code" class="ug-school-row">
        <view class="ug-school-main">
          <view class="ug-school-code">{{item.code}}</view>
          <view class="ug-school-name">{{item.nameZh || item.nameEn}}</view>
          <view class="ug-school-meta">{{item.programmeWithCoursesCount}}/{{item.programmeCount}} Programme 已开放 · {{item.pendingProgrammeCount}} 个待补</view>
          <view class="ug-school-meta readiness">{{item.sourceReadinessLabel}}</view>
          <view class="ug-school-meta muted">{{item.majorCount}} Major / Track · {{item.coverageLabel}}</view>
          <view class="ug-school-updated">{{item.updatedLabel}}</view>
        </view>
        <view class="ug-school-side">
          <view class="ug-school-percent">{{item.coveragePercent}}%</view>
          <view class="ug-school-badge {{item.codedCourseCount ? 'ready' : ''}}">{{item.badge}}</view>
          <view class="ug-school-course">{{item.codedCourseCount ? item.codedCourseCount + ' codes' : '待开放'}}</view>
        </view>
      </view>
    </view>
    <view class="ug-source-actions">
      <view class="source-action tpg-source-action" bindtap="copyUgSummary">复制本科数据状态</view>
      <view class="source-action tpg-source-action" bindtap="copyUgPendingCollection">复制待补资料清单</view>
      <view class="source-action tpg-source-action" bindtap="copyUgIndexOnlyCollection">复制仅索引清单</view>
      <view class="source-action tpg-source-action" bindtap="copyUgNoSourceCollection">复制缺来源清单</view>
    </view>
  </view>

  <view class="section source-card">
    <view class="source-index">01</view>
    <view class="source-kicker">COURSE OFFERINGS</view>
    <view class="source-title">官方开课目录 · {{status.offering.academicYear}}</view>
    <view class="source-grid">
      <view class="source-stat">
        <view class="stat-value">{{status.offering.courseCount}}</view>
        <view class="stat-label">门课程</view>
      </view>
      <view class="source-stat">
        <view class="stat-value">{{status.offering.detailCount}}</view>
        <view class="stat-label">门含完整详情</view>
      </view>
    </view>
    <view class="source-row">
      <view class="row-label">抓取日期</view>
      <view>{{status.offering.updatedDate}}</view>
    </view>
    <view class="source-row">
      <view class="row-label">距今</view>
      <view>{{status.offering.ageDays}} 天</view>
    </view>
    <view class="source-action" data-url="{{status.offering.sourceUrl}}" bindtap="copySource">复制官方开课来源</view>
  </view>

  <view class="section source-card">
    <view class="source-index">02</view>
    <view class="source-kicker">CURRICULUM</view>
    <view class="source-title">BEng(CompSc) · {{status.curriculum.curriculumYear}}</view>
    <view class="source-grid">
      <view class="source-stat">
        <view class="stat-value">{{status.curriculum.totalCredits}}</view>
        <view class="stat-label">总学分</view>
      </view>
      <view class="source-stat">
        <view class="stat-value">{{status.curriculum.categoryCount}}</view>
        <view class="stat-label">个学分类别</view>
      </view>
    </view>
    <view class="source-row">
      <view class="row-label">核验日期</view>
      <view>{{status.curriculum.verifiedDate}}</view>
    </view>
    <view class="source-row">
      <view class="row-label">距今</view>
      <view>{{status.curriculum.ageDays}} 天</view>
    </view>
    <view class="source-action" data-url="{{status.curriculum.sourceUrl}}" bindtap="copySource">复制官方培养方案来源</view>
  </view>

  <view class="section method-note">
    <view class="method-title">状态如何判断</view>
    <view class="method-copy">页面显示的是随小程序发布的本地数据快照。任一主要来源超过 90 天未复核，就会标记为“需要复核”。这不代表 HKU 官网资料有误，只表示本地缓存可能需要更新。</view>
  </view>
</view>
