.release-card {
  background: #fbfcfa;
  border: 1rpx solid #dce6e0;
  border-radius: 18rpx;
  box-shadow: 0 8rpx 22rpx rgba(15, 64, 51, 0.045);
  padding: 26rpx;
}

.release-kicker {
  color: #0b6b55;
  font-size: 18rpx;
  font-weight: 850;
  letter-spacing: 2rpx;
}

.release-title {
  color: #17352c;
  font-size: 30rpx;
  font-weight: 850;
  margin-top: 8rpx;
}

.release-copy {
  color: #667970;
  font-size: 21rpx;
  line-height: 1.5;
  margin-top: 8rpx;
}

.status-head {
  align-items: center;
  background: #17352c;
  border-radius: 22rpx;
  box-shadow: 0 14rpx 32rpx rgba(8, 45, 35, 0.18);
  display: flex;
  gap: 24rpx;
  padding: 32rpx;
}

.status-head.review {
  background: #65401e;
}

.status-seal {
  border: 3rpx double #8fc4b4;
  color: #a9d4c7;
  flex: none;
  font-size: 17rpx;
  font-weight: 850;
  letter-spacing: 1rpx;
  padding: 14rpx 8rpx;
  transform: rotate(-4deg);
}

.status-head.review .status-seal {
  border-color: #d7b88e;
  color: #ecd2ae;
}

.status-kicker {
  color: #91c4b5;
  font-size: 17rpx;
  font-weight: 850;
  letter-spacing: 2rpx;
}

.status-head .title {
  color: #ffffff;
  font-size: 36rpx;
  margin-top: 8rpx;
}

.status-head .subtitle {
  color: #b9d0c8;
  font-size: 21rpx;
}

.runtime-card {
  align-items: center;
  background: #e7efeb;
  border: 1rpx solid #c5d8cf;
  border-radius: 16rpx;
  display: flex;
  justify-content: space-between;
  padding: 24rpx 26rpx;
}

.runtime-kicker {
  color: #71867c;
  font-size: 16rpx;
  font-weight: 850;
  letter-spacing: 2rpx;
}

.runtime-title {
  color: #17352c;
  font-size: 25rpx;
  font-weight: 800;
  margin-top: 6rpx;
}

.runtime-copy {
  color: #6c7d75;
  font-size: 20rpx;
  line-height: 1.45;
  margin-top: 6rpx;
  max-width: 540rpx;
}

.runtime-light {
  background: #74887f;
  border: 7rpx solid #d5e1dc;
  border-radius: 50%;
  flex: none;
  height: 20rpx;
  margin-left: 18rpx;
  width: 20rpx;
}

.runtime-light.online {
  background: #0b6b55;
}

.tpg-passport {
  background: #17352c;
  border-radius: 22rpx;
  box-shadow: 0 14rpx 32rpx rgba(8, 45, 35, 0.18);
  color: #ffffff;
  padding: 32rpx;
}

.tpg-passport-head {
  align-items: flex-start;
  display: flex;
  gap: 22rpx;
  justify-content: space-between;
}

.tpg-title {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 850;
  letter-spacing: -1rpx;
  margin-top: 8rpx;
}

.tpg-copy {
  color: #b9d0c8;
  font-size: 21rpx;
  line-height: 1.5;
  margin-top: 8rpx;
}

.tpg-seal {
  border: 3rpx double #8fc4b4;
  color: #a9d4c7;
  flex: none;
  font-size: 17rpx;
  font-weight: 850;
  letter-spacing: 1rpx;
  line-height: 1.2;
  padding: 14rpx 10rpx;
  text-align: center;
  transform: rotate(4deg);
}

.tpg-metrics {
  background: rgba(232, 241, 237, 0.09);
  border: 1rpx solid rgba(143, 196, 180, 0.22);
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-top: 26rpx;
  padding: 20rpx;
}

.tpg-metric + .tpg-metric {
  border-left: 1rpx solid rgba(143, 196, 180, 0.28);
  padding-left: 18rpx;
}

.tpg-passport .stat-value {
  color: #ffffff;
}

.tpg-passport .stat-label {
  color: #a8c5bb;
}

.tpg-note-line {
  color: #a9c1b8;
  font-size: 21rpx;
  line-height: 1.55;
  margin-top: 18rpx;
}

.data-updated-line {
  background: rgba(232, 241, 237, 0.08);
  border: 1rpx solid rgba(143, 196, 180, 0.18);
  border-radius: 999rpx;
  color: #dcebe5;
  display: inline-flex;
  font-size: 19rpx;
  font-weight: 750;
  margin-top: 16rpx;
  padding: 9rpx 16rpx;
}

.ug-school-list {
  border: 1rpx solid rgba(143, 196, 180, 0.22);
  border-radius: 16rpx;
  margin-top: 20rpx;
  overflow: hidden;
}

.ug-school-row {
  align-items: center;
  background: rgba(232, 241, 237, 0.07);
  display: flex;
  gap: 18rpx;
  justify-content: space-between;
  padding: 18rpx 20rpx;
}

.ug-school-row + .ug-school-row {
  border-top: 1rpx solid rgba(143, 196, 180, 0.18);
}

.ug-school-code {
  color: #a9d4c7;
  font-size: 18rpx;
  font-weight: 850;
  letter-spacing: 2rpx;
}

.ug-school-name {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
  margin-top: 4rpx;
}

.ug-school-meta {
  color: #a8c5bb;
  font-size: 19rpx;
  margin-top: 4rpx;
}

.ug-school-meta.muted {
  color: rgba(220, 235, 229, 0.68);
  font-size: 18rpx;
}

.ug-school-side {
  flex: none;
  text-align: right;
}

.ug-school-percent {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  letter-spacing: -1rpx;
  margin-bottom: 8rpx;
}

.ug-school-badge {
  border: 1rpx solid rgba(169, 212, 199, 0.5);
  border-radius: 999rpx;
  color: #a9d4c7;
  display: inline-block;
  font-size: 16rpx;
  font-weight: 850;
  letter-spacing: 1rpx;
  padding: 5rpx 12rpx;
}

.ug-school-badge.ready {
  background: #dcebe5;
  border-color: #dcebe5;
  color: #0b6b55;
}

.ug-school-course {
  color: #dcebe5;
  font-size: 19rpx;
  font-weight: 750;
  margin-top: 8rpx;
}

.tpg-source-action {
  border-top: 1rpx solid #426258;
  color: #dcebe5;
  margin-top: 18rpx;
  padding-top: 18rpx;
}

.source-card {
  background: #fbfcfa;
  border: 1rpx solid #dce6e0;
  border-radius: 18rpx;
  padding: 28rpx;
  position: relative;
}

.source-index {
  color: #d5e1dc;
  font-size: 64rpx;
  font-weight: 850;
  position: absolute;
  right: 24rpx;
  top: 18rpx;
}

.source-kicker {
  color: #0b6b55;
  font-size: 18rpx;
  font-weight: 850;
  letter-spacing: 2rpx;
}

.source-title {
  color: #17352c;
  font-size: 29rpx;
  font-weight: 800;
  margin-top: 8rpx;
  padding-right: 70rpx;
}

.source-grid {
  background: #e8f1ed;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 24rpx;
  padding: 20rpx;
}

.source-stat + .source-stat {
  border-left: 1rpx solid #c7d9d1;
  padding-left: 22rpx;
}

.stat-value {
  color: #0b6b55;
  font-size: 36rpx;
  font-weight: 850;
}

.stat-label {
  color: #718079;
  font-size: 20rpx;
}

.source-row {
  border-top: 1rpx solid #e5ebe8;
  display: flex;
  font-size: 23rpx;
  justify-content: space-between;
  padding: 18rpx 0;
}

.row-label {
  color: #78877f;
}

.source-action {
  color: #0b6b55;
  font-size: 22rpx;
  font-weight: 750;
  padding-top: 8rpx;
}

.method-note {
  border-left: 5rpx solid #8aa99c;
  padding: 8rpx 0 8rpx 22rpx;
}

.method-title {
  color: #43584f;
  font-size: 24rpx;
  font-weight: 800;
}

.method-copy {
  color: #708078;
  font-size: 21rpx;
  line-height: 1.6;
  margin-top: 8rpx;
}
