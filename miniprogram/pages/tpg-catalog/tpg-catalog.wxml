<view class="page">
  <view class="hero">
    <view class="hero-index">TPG PROGRAMMES</view>
    <view class="hero-title">先找到你的 Programme</view>
    <view class="hero-copy">从已整理的授课硕士资料中查找 Programme。必修与选修课程仍在逐项核验，页面会明确标记课程组开放状态。</view>
  </view>

  <view wx:if="{{selectedProfile}}" class="selected-card" bindtap="goSelectedProgramme">
    <view class="selected-mark">CURRENT PROGRAMME</view>
    <view class="selected-title">{{selectedProfile.programme.name}}</view>
    <view class="selected-copy">{{selectedProfile.schoolLabel}} · {{selectedProfile.yearLabel}} · {{selectedProfile.statusLabel}}</view>
    <view class="selected-arrow">›</view>
  </view>

  <scroll-view class="school-strip" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="school-row">
      <view
        class="school-chip {{selectedUniversity === 'ALL' ? 'school-chip-active' : ''}}"
        data-code="ALL"
        bindtap="selectUniversity"
      >全部</view>
      <view
        wx:for="{{universities}}"
        wx:key="code"
        class="school-chip {{selectedUniversity === item.code ? 'school-chip-active' : ''}}"
        data-code="{{item.code}}"
        bindtap="selectUniversity"
      >
        <text>{{item.code}}</text>
      </view>
    </view>
  </scroll-view>

  <view class="search-box">
    <input
      class="search-input"
      value="{{keyword}}"
      placeholder="搜索 Programme、课程或代码"
      confirm-type="search"
      bindinput="onKeywordInput"
      bindconfirm="commitKeywordSearch"
    />
    <view wx:if="{{keyword}}" class="search-clear" bindtap="clearKeyword">清除</view>
  </view>

  <view wx:if="{{!keyword && searchHistory.length}}" class="history-row">
    <view class="history-label">最近搜索</view>
    <view class="history-chips">
      <view
        wx:for="{{searchHistory}}"
        wx:key="*this"
        class="history-chip"
        data-keyword="{{item}}"
        bindtap="useHistoryKeyword"
      >{{item}}</view>
    </view>
    <view class="history-clear" bindtap="clearSearchHistory">清空</view>
  </view>

  <view class="availability-row">
    <view
      wx:for="{{availabilityFilters}}"
      wx:key="value"
      class="availability-chip {{availabilityFilter === item.value ? 'availability-chip-active' : ''}}"
      data-value="{{item.value}}"
      bindtap="selectAvailability"
    >{{item.label}}</view>
  </view>

  <view wx:if="{{courseSearchLoadError}}" class="empty">
    <view class="empty-title">课程搜索数据加载失败</view>
    <view class="empty-copy">Programme 名称仍可搜索；课程名称和代码结果可能不完整。</view>
    <button class="secondary-button" bindtap="retryCourseSearchLoad">重新加载</button>
  </view>

  <view class="result-head">
    <view>
      <view class="result-count">{{resultCount}} 个结果</view>
      <view class="result-scope">{{resultScope}}</view>
    </view>
    <view class="result-note">{{resultHint}}</view>
  </view>

  <view class="programme-list">
    <view
      wx:for="{{visibleProgrammes}}"
      wx:key="id"
      class="programme-card {{item.selected ? 'programme-card-selected' : ''}}"
      data-id="{{item.id}}"
      bindtap="goProgramme"
      hover-class="programme-card-active"
    >
      <view class="programme-top">
        <view class="school-stamp">{{item.universityCode}}</view>
        <view class="programme-badges">
          <view wx:if="{{item.selected}}" class="selected-badge">已选择</view>
          <view class="data-level {{item.courseCount ? 'data-level-ready' : ''}}">{{item.statusBadge}}</view>
          <view class="programme-arrow">›</view>
        </view>
      </view>
      <view class="programme-name">{{item.name}}</view>
      <view wx:if="{{item.faculty}}" class="programme-faculty">{{item.faculty}}</view>
      <view class="programme-status">
        <view class="status-pill {{item.courseCount ? 'status-pill-ready' : ''}}">{{item.statusLabel}}</view>
        <view class="status-year">{{item.academicYear}}</view>
      </view>
      <view class="programme-meta">
        <text wx:if="{{item.programmeCode}}">{{item.programmeCode}}</text>
        <text wx:if="{{item.creditsRequired}}">{{item.creditsRequired}} credits / units</text>
        <text wx:if="{{!item.programmeCode && !item.creditsRequired}}">课程清单待开放</text>
      </view>
    </view>
  </view>

  <view wx:if="{{resultCount > visibleProgrammes.length}}" class="limit-note">
    已显示前 {{visibleProgrammes.length}} 项。{{limitHint}}
  </view>

  <view wx:if="{{resultCount === 0}}" class="empty">
    <view class="empty-title">没有匹配的 Programme</view>
    <view class="empty-copy">换一个英文关键词，或切换学校后再试。</view>
  </view>
</view>
