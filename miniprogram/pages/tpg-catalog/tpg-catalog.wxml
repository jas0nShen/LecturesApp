<view class="page">
  <view class="hero">
    <view class="hero-index">TPG / SIX SCHOOLS</view>
    <view class="hero-title">先找到你的 Programme</view>
    <view class="hero-copy">已从六校资料建立 Programme 索引。必修与选修课程仍在逐项核验，页面会明确标记资料完整度。</view>
    <view class="hero-stats">
      <view class="hero-stat">
        <view class="hero-stat-value">{{universities.length}}</view>
        <view class="hero-stat-label">所大学</view>
      </view>
      <view class="hero-stat">
        <view class="hero-stat-value">{{totalProgrammes}}</view>
        <view class="hero-stat-label">个 Programme</view>
      </view>
    </view>
  </view>

  <scroll-view class="school-strip" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="school-row">
      <view
        class="school-chip {{selectedUniversity === 'ALL' ? 'school-chip-active' : ''}}"
        data-code="ALL"
        bindtap="selectUniversity"
      >全部</view>
      <view
        wx:for="{{universities}}"
        wx:key="code"
        class="school-chip {{selectedUniversity === item.code ? 'school-chip-active' : ''}}"
        data-code="{{item.code}}"
        bindtap="selectUniversity"
      >{{item.code}}</view>
    </view>
  </scroll-view>

  <view class="search-box">
    <input
      class="search-input"
      value="{{keyword}}"
      placeholder="搜索 Programme、课程或代码"
      bindinput="onKeywordInput"
    />
    <view wx:if="{{keyword}}" class="search-clear" bindtap="clearKeyword">清除</view>
  </view>

  <view class="result-head">
    <view class="result-count">{{resultCount}} 个结果</view>
    <view class="result-note">PDF 导入 · 待官网复核</view>
  </view>

  <view class="programme-list">
    <view
      wx:for="{{visibleProgrammes}}"
      wx:key="id"
      class="programme-card"
      data-id="{{item.id}}"
      bindtap="goProgramme"
      hover-class="programme-card-active"
    >
      <view class="programme-top">
        <view class="school-stamp">{{item.universityCode}}</view>
        <view class="programme-badges">
          <view class="data-level">{{item.dataLevel === 'structure' ? '含结构' : '索引'}}</view>
          <view class="programme-arrow">›</view>
        </view>
      </view>
      <view class="programme-name">{{item.name}}</view>
      <view wx:if="{{item.faculty}}" class="programme-faculty">{{item.faculty}}</view>
      <view class="programme-meta">
        <text wx:if="{{item.programmeCode}}">{{item.programmeCode}}</text>
        <text wx:if="{{item.creditsRequired}}">{{item.creditsRequired}} credits / units</text>
        <text wx:if="{{!item.programmeCode && !item.creditsRequired}}">课程结构整理中</text>
      </view>
    </view>
  </view>

  <view wx:if="{{resultCount > visibleProgrammes.length}}" class="limit-note">
    当前先展示前 {{visibleProgrammes.length}} 项，请使用学校筛选或关键词缩小范围。
  </view>

  <view wx:if="{{resultCount === 0}}" class="empty">
    <view class="empty-title">没有匹配的 Programme</view>
    <view class="empty-copy">换一个英文关键词，或切换学校后再试。</view>
  </view>
</view>
