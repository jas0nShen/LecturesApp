.page {
  background: #f2f6f3;
  box-sizing: border-box;
  color: #17231f;
  min-height: 100vh;
  padding: 24rpx 24rpx 64rpx;
}

.hero {
  background: #123f34;
  border-radius: 24rpx;
  color: #f7fbf8;
  overflow: hidden;
  padding: 38rpx 34rpx 32rpx;
  position: relative;
}

.hero::after {
  border: 2rpx solid rgba(179, 222, 205, 0.22);
  border-radius: 50%;
  box-shadow: 0 0 0 30rpx rgba(179, 222, 205, 0.06);
  content: "";
  height: 220rpx;
  position: absolute;
  right: -50rpx;
  top: -54rpx;
  width: 220rpx;
}

.hero-index {
  color: #a8d4c3;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  position: relative;
  z-index: 1;
}

.hero-title {
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
  margin-top: 14rpx;
  max-width: 520rpx;
  position: relative;
  z-index: 1;
}

.hero-copy {
  color: #c7d9d1;
  font-size: 24rpx;
  line-height: 1.65;
  margin-top: 16rpx;
  max-width: 570rpx;
  position: relative;
  z-index: 1;
}

.hero-stats {
  border-top: 1rpx solid rgba(219, 239, 231, 0.18);
  display: flex;
  gap: 50rpx;
  margin-top: 28rpx;
  padding-top: 22rpx;
  position: relative;
  z-index: 1;
}

.hero-stat {
  align-items: baseline;
  display: flex;
  gap: 10rpx;
}

.hero-stat-value {
  font-size: 36rpx;
  font-weight: 800;
}

.hero-stat-label {
  color: #a8bdb4;
  font-size: 21rpx;
}

.school-strip {
  margin: 24rpx -24rpx 0;
  white-space: nowrap;
  width: calc(100% + 48rpx);
}

.school-row {
  display: inline-flex;
  gap: 14rpx;
  padding: 0 24rpx;
}

.school-chip {
  background: #ffffff;
  border: 1rpx solid #cedbd5;
  border-radius: 999rpx;
  color: #53635c;
  font-size: 23rpx;
  font-weight: 600;
  padding: 17rpx 25rpx;
}

.school-chip-active {
  background: #0b6b55;
  border-color: #0b6b55;
  color: #ffffff;
}

.search-box {
  align-items: center;
  background: #ffffff;
  border: 1rpx solid #d6e0db;
  border-radius: 18rpx;
  display: flex;
  margin-top: 22rpx;
  padding: 0 26rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  height: 88rpx;
}

.search-clear {
  color: #0b6b55;
  font-size: 23rpx;
  font-weight: 600;
  padding: 20rpx 0 20rpx 20rpx;
}

.result-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin: 28rpx 4rpx 16rpx;
}

.result-count {
  font-size: 27rpx;
  font-weight: 700;
}

.result-note {
  color: #7b8983;
  font-size: 20rpx;
}

.programme-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.programme-card {
  background: #ffffff;
  border: 1rpx solid #d8e2dd;
  border-radius: 18rpx;
  padding: 24rpx 26rpx 25rpx;
  transition: background 120ms ease, transform 120ms ease;
}

.programme-card-active {
  background: #f7faf8;
  transform: scale(0.99);
}

.programme-top {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.school-stamp {
  color: #0b6b55;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.data-level {
  background: #edf4f0;
  border-radius: 999rpx;
  color: #65756e;
  font-size: 18rpx;
  padding: 6rpx 13rpx;
}

.programme-badges {
  align-items: center;
  display: flex;
  gap: 15rpx;
}

.programme-arrow {
  color: #0b6b55;
  font-size: 34rpx;
  font-weight: 500;
  line-height: 1;
}

.programme-name {
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.38;
  margin-top: 14rpx;
}

.programme-faculty {
  color: #65736d;
  font-size: 22rpx;
  line-height: 1.45;
  margin-top: 9rpx;
}

.programme-meta {
  color: #0b6b55;
  display: flex;
  font-size: 21rpx;
  font-weight: 600;
  gap: 24rpx;
  margin-top: 16rpx;
}

.limit-note,
.empty {
  background: #e7efeb;
  border-radius: 18rpx;
  color: #68776f;
  font-size: 22rpx;
  line-height: 1.55;
  margin-top: 20rpx;
  padding: 28rpx;
  text-align: center;
}

.empty-title {
  color: #263a32;
  font-size: 27rpx;
  font-weight: 700;
}

.empty-copy {
  margin-top: 8rpx;
}
