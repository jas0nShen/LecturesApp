.page {
  background: #f2f6f3;
  box-sizing: border-box;
  color: #17231f;
  min-height: 100vh;
  padding: 24rpx 24rpx 64rpx;
}

.hero {
  background: #123f34;
  border-radius: 24rpx;
  color: #f7fbf8;
  overflow: hidden;
  padding: 38rpx 34rpx 32rpx;
  position: relative;
}

.hero::after {
  border: 2rpx solid rgba(179, 222, 205, 0.22);
  border-radius: 50%;
  box-shadow: 0 0 0 30rpx rgba(179, 222, 205, 0.06);
  content: "";
  height: 220rpx;
  position: absolute;
  right: -50rpx;
  top: -54rpx;
  width: 220rpx;
}

.hero-index {
  color: #a8d4c3;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  position: relative;
  z-index: 1;
}

.hero-title {
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
  margin-top: 14rpx;
  max-width: 520rpx;
  position: relative;
  z-index: 1;
}

.hero-copy {
  color: #c7d9d1;
  font-size: 24rpx;
  line-height: 1.65;
  margin-top: 16rpx;
  max-width: 570rpx;
  position: relative;
  z-index: 1;
}

.selected-card {
  background: #fffaf0;
  border: 1rpx solid #e8d6ad;
  border-radius: 20rpx;
  box-shadow: 0 10rpx 24rpx rgba(111, 82, 28, 0.08);
  margin-top: 22rpx;
  padding: 26rpx 78rpx 26rpx 28rpx;
  position: relative;
}

.selected-mark {
  color: #8a6a25;
  font-size: 18rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.selected-title {
  color: #17352c;
  font-size: 29rpx;
  font-weight: 850;
  line-height: 1.35;
  margin-top: 9rpx;
}

.selected-copy {
  color: #786b50;
  font-size: 22rpx;
  line-height: 1.45;
  margin-top: 8rpx;
}

.selected-arrow {
  color: #8a6a25;
  font-size: 44rpx;
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
}

.school-strip {
  margin: 24rpx -24rpx 0;
  white-space: nowrap;
  width: calc(100% + 48rpx);
}

.school-row {
  display: inline-flex;
  gap: 14rpx;
  padding: 0 24rpx;
}

.school-chip {
  align-items: center;
  background: #ffffff;
  border: 1rpx solid #cedbd5;
  border-radius: 999rpx;
  color: #53635c;
  display: inline-flex;
  font-size: 23rpx;
  font-weight: 600;
  padding: 17rpx 25rpx;
}

.school-chip-active {
  background: #0b6b55;
  border-color: #0b6b55;
  color: #ffffff;
}

.search-box {
  align-items: center;
  background: #ffffff;
  border: 1rpx solid #d6e0db;
  border-radius: 18rpx;
  display: flex;
  margin-top: 22rpx;
  padding: 0 26rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  height: 88rpx;
}

.search-clear {
  color: #0b6b55;
  font-size: 23rpx;
  font-weight: 600;
  padding: 20rpx 0 20rpx 20rpx;
}

.history-row {
  align-items: flex-start;
  background: #ffffff;
  border: 1rpx solid #e2eae6;
  border-radius: 16rpx;
  display: flex;
  gap: 14rpx;
  margin-top: 14rpx;
  padding: 18rpx;
}

.history-label,
.history-clear {
  color: #718079;
  flex: none;
  font-size: 20rpx;
  font-weight: 750;
  line-height: 48rpx;
}

.history-chips {
  display: flex;
  flex: 1;
  flex-wrap: wrap;
  gap: 10rpx;
}

.history-chip {
  background: #edf4f0;
  border-radius: 999rpx;
  color: #0b6b55;
  font-size: 21rpx;
  font-weight: 750;
  max-width: 260rpx;
  overflow: hidden;
  padding: 10rpx 16rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-clear {
  color: #8a714f;
}

.availability-row {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
}

.availability-chip {
  background: #ffffff;
  border: 1rpx solid #d6e0db;
  border-radius: 999rpx;
  color: #60736a;
  flex: 1;
  font-size: 22rpx;
  font-weight: 750;
  line-height: 66rpx;
  text-align: center;
}

.availability-chip-active {
  background: #17352c;
  border-color: #17352c;
  color: #ffffff;
}

.result-head {
  align-items: flex-end;
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
  margin: 28rpx 4rpx 16rpx;
}

.result-count {
  font-size: 27rpx;
  font-weight: 700;
}

.result-note {
  color: #7b8983;
  font-size: 20rpx;
  line-height: 1.45;
  max-width: 360rpx;
  text-align: right;
}

.result-scope {
  color: #0b6b55;
  font-size: 21rpx;
  font-weight: 650;
  line-height: 1.45;
  margin-top: 5rpx;
}

.programme-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.programme-card {
  background: #ffffff;
  border: 1rpx solid #d8e2dd;
  border-radius: 18rpx;
  padding: 24rpx 26rpx 25rpx;
  transition: background 120ms ease, transform 120ms ease;
}

.programme-card-selected {
  border-color: #d8bd70;
  box-shadow: 0 10rpx 24rpx rgba(111, 82, 28, 0.08);
}

.programme-card-active {
  background: #f7faf8;
  transform: scale(0.99);
}

.programme-top {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.school-stamp {
  color: #0b6b55;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.data-level {
  background: #edf4f0;
  border-radius: 999rpx;
  color: #65756e;
  font-size: 18rpx;
  padding: 6rpx 13rpx;
}

.data-level-ready {
  background: #dceee7;
  color: #0b6b55;
}

.programme-badges {
  align-items: center;
  display: flex;
  gap: 15rpx;
}

.selected-badge {
  background: #fff3cf;
  border-radius: 999rpx;
  color: #8a6a25;
  font-size: 18rpx;
  font-weight: 850;
  padding: 6rpx 13rpx;
}

.programme-arrow {
  color: #0b6b55;
  font-size: 34rpx;
  font-weight: 500;
  line-height: 1;
}

.programme-name {
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.38;
  margin-top: 14rpx;
}

.programme-faculty {
  color: #65736d;
  font-size: 22rpx;
  line-height: 1.45;
  margin-top: 9rpx;
}

.programme-status {
  align-items: center;
  display: flex;
  gap: 12rpx;
  margin-top: 15rpx;
}

.status-pill {
  background: #eef3f0;
  border: 1rpx solid #d3e0da;
  border-radius: 999rpx;
  color: #60736a;
  font-size: 20rpx;
  font-weight: 750;
  padding: 8rpx 14rpx;
}

.status-pill-ready {
  background: #0b6b55;
  border-color: #0b6b55;
  color: #ffffff;
}

.status-year {
  color: #7e8d86;
  font-size: 20rpx;
}

.programme-meta {
  color: #0b6b55;
  display: flex;
  font-size: 21rpx;
  font-weight: 600;
  gap: 24rpx;
  margin-top: 16rpx;
}

.limit-note,
.empty {
  background: #e7efeb;
  border-radius: 18rpx;
  color: #68776f;
  font-size: 22rpx;
  line-height: 1.55;
  margin-top: 20rpx;
  padding: 28rpx;
  text-align: center;
}

.empty-title {
  color: #263a32;
  font-size: 27rpx;
  font-weight: 700;
}

.empty-copy {
  margin-top: 8rpx;
}
